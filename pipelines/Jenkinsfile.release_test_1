        stage ('Beanstalk Load Test - Vote in secondary nodes') {
        // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script{
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node2Address} --nonce=100 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node3Address} --nonce=150 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node4Address} --nonce=200 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node5Address} --nonce=250 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node6Address} --nonce=300 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node7Address} --nonce=350 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE6.HOST}:${NODE_DATA.NODE6.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node8Address} --nonce=400 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE6.HOST}:${NODE_DATA.NODE6.PORT},${NODE_DATA.NODE7.HOST}:${NODE_DATA.NODE7.PORT} --https"
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "8" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
            }
        }

        stage ('Beanstalk Load Test - Run app on secondary nodes') {
            parallel {
