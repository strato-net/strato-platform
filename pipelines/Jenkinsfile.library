def createContractAndGetContractAddress(NODE_HOST, NODE_PORT, SERVICE_TOKEN) {
 def CONTRACT_ADDRESS = sh(
  returnStdout: true,
  script: "curl -s -X 'POST' \
    'https://${NODE_HOST}:${NODE_PORT}/strato/v2.3/transaction?resolve=true' \
    -H \"Authorization: Bearer ${SERVICE_TOKEN}\"  \
    -H 'Accept: application/json;charset=utf-8' \
    -H 'Content-Type: application/json' \
    --data-binary '{\"txs\":[{\"payload\":{\"contract\":\"SimpleStorage\",\"src\":\"pragma solidvm 3.0; contract SimpleStorage {  uint storedData;  function SimpleStorage() {    storedData = 1;  }  function set(uint x) {    storedData = x;  }  function get() constant returns (uint) {    return storedData;  }}\",\"args\":{},\"metadata\":{\"VM\":\"SolidVM\",\"history\":\"SimpleStorage\",\"index\":\"SimpleStorage\"}},\"type\":\"CONTRACT\"}]}' \
    | jq '.[].txResult.contractsCreated'"
  ).trim()
  return CONTRACT_ADDRESS
 }

def getContractBlockNumber(NODE_HOST, NODE_PORT, CONTRACT_ADDRESS, SERVICE_TOKEN) {
 def BLOCK_NUMBER = sh(
  returnStdout: true,
  script: "curl -s -X 'GET' \
    \"https://${NODE_HOST}:${NODE_PORT}/cirrus/search/SimpleStorage?address=eq.${CONTRACT_ADDRESS}\" \
    -H \"Authorization: Bearer ${SERVICE_TOKEN}\"  \
    -H 'Accept: application/json;charset=utf-8' \
    -H 'Content-Type: application/json;charset=utf-8' \
    | jq -r '.[].block_number'"
  ).trim()
  return BLOCK_NUMBER
 }

def waitForHealthyNetwork() {
  // TODO: the monitor deployment should be a part of the pipeline
  // TODO: also check if the number of private chains is same as on another tech node (monitor should provide hooks for that)
  def secondsForEachAgreement = "10"
  sh """
    set -x
    waitForContinousHealth() {
      isNowHealthy() {
        if [ "\$(curl -s https://multinode305.ci.blockapps.net/health | jq .needsAttention)" = "false" ]; then exit 0; else exit 1; fi
      }
      if \$(isNowHealthy); then
        sleep 5
        if \$(isNowHealthy); then
          sleep 5
          if \$(isNowHealthy); then
            exit 0
          else exit 1
          fi
        else exit 1
        fi
      else exit 1
      fi
    }
    counter=0
    until \$(waitForContinousHealth)
    do
      # wait for (batchSize x batchCount x secondsForEachAgreement) seconds:
      if [ "\$counter" -gt \$(expr ${env.BEANSTALK_LOADTEST_BATCH_SIZE} \\* ${env.BEANSTALK_LOADTEST_BATCH_COUNT} \\* ${secondsForEachAgreement}) ]
      then
        echo "STRATO network took too long to become healthy! Apparently something went wrong with load test."
        exit 73
      fi
      echo 'Waiting for network to become healthy...'
      counter=\$((counter+1))
      sleep 1
    done
  """
}

def removeBeanstalkApp() {
  dir("beanstalk") {
    sh 'sudo docker-compose down -v -t 0 --remove-orphans'
  }
}

return this
