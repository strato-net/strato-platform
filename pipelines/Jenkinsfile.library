def waitForHealthySync(NODE_MONITOR_HEALTH_URL) {
  script {
    echo "Waiting for network nodes to be in-sync and healthy..."
    int counter = 0
    int restartEveryThirtyMins = 0
    for (int i = 0; i < 6000; i++) {
      if (sh(returnStatus: true, script: "curl --silent ${NODE_MONITOR_HEALTH_URL} | grep '\"needsAttention\":false'") != 0) {
        // Restart strato container once sync is done or every 30 mins
        if ( (sh(returnStatus: true, script: "curl --silent ${NODE_MONITOR_HEALTH_URL} | grep '\"hasSyncingNodes\":true'") != 0 && sh(returnStatus: true, script: "curl --silent ${NODE_MONITOR_HEALTH_URL} | grep '\"isOverallHealthy\":false'") != 0 && counter == 60 ) || restartEveryThirtyMins == 900) {
            sh "sudo docker restart strato_strato_1"
        }
        if(counter != 60) {
            counter = counter + 1
        }
        restartEveryThirtyMins = restartEveryThirtyMins + 1
        if(restartEveryThirtyMins == 901) {
          restartEveryThirtyMins = 1
        }
        sleep 2
      } else {
        // If healthy - check in few seconds again to make sure it wasn't temporary while syncned to the same block number. Monitor should probably be handling this itself in the future before showing network healthy.
        sleep 20
        if (sh(returnStatus: true, script: "curl --silent ${NODE_MONITOR_HEALTH_URL} | grep '\"needsAttention\":false'") != 0) {
          sleep 2
        } else {
          sleep 20
          if (sh(returnStatus: true, script: "curl --silent ${NODE_MONITOR_HEALTH_URL} | grep '\"needsAttention\":false'") != 0) {
            sleep 2
          } else {
            return true
          }
        }
      }
    }
    error ("Failed to get the STRATO nodes healthy after sync attempt")
  }
}

def runBeanstalkLoadTest(loadTestBatchSize, loadTestBatchCount) {
  checkUnhealthyContainers()
  sleep(time:5,unit:"SECONDS") // let the updates related to transactions just posted get to the monitor and potentially flip it to unhealthy before we check for the first time
  waitForHealthyNetwork()
  sh "sudo docker exec beanstalk_backend_1 bash -c \"cp /config/config.yaml config/generated.config.yaml && echo \\\"batchSize: ${loadTestBatchSize}\\\">>config/generated.config.yaml && echo \\\"batchCount: ${loadTestBatchCount}\\\">>config/generated.config.yaml && SERVER=generated yarn test:agreement:load\""
  sleep(time:5,unit:"SECONDS") // we wait some time to make sure nothing crashed yet and before starting monitoring the network health to see when blocks stop being created and network is healthy
  checkUnhealthyContainers()
  waitForHealthyNetwork() // Important on the larger batchSizes when the network keeps getting new blocks after some time.
  waitForCirrus()
}

def checkUnhealthyContainers() {
  sh 'if bash -c "docker ps | grep unhealthy"; then exit 43; else echo "all containers are healthy"; fi'
}

def waitForCirrus() {
  // TODO: Ideally - make a direct check if cirrus still has data to index and is active. For now, just let it rest for some time to make sure cirrus has enough time to finish indexing once all blocks are created:
  sleep(time:180,unit:"SECONDS")
}

