def createContractAndGetContractAddress(NODE_HOST, NODE_PORT, SERVICE_TOKEN) {
 script {
  CONTRACT_ADDRESS=$(curl "https://${NODE_HOST}:${NODE_PORT}/strato/v2.3/transaction?resolve=true" \
    -X 'POST' \
    -H "Authorization: Bearer $SERVICE_TOKEN"  \
    -H 'Accept: application/json;charset=utf-8' \
    -H 'Content-Type: application/json' \
    --data-binary '{
      "txs":[{
        "payload":{
          "contract":"SimpleStorage",
          "src":"pragma solidvm 3.0; contract SimpleStorage {\n  uint storedData;\n\n  function SimpleStorage() {\n    storedData = 1;\n  }\n\n  function set(uint x) {\n    storedData = x;\n  }\n\n  function get() constant returns (uint) {\n    return storedData;\n  }\n}\n",
          "args":{},
          "metadata":{
            "VM":"SolidVM",
            "history":"SimpleStorage",
            "index":"SimpleStorage"
          }
        },
        "type":"CONTRACT"
      }]
    }' \
    | jq '.[] | .txResult."contractsCreated"')
  return "${CONTRACT_ADDRESS}"
 }
}

def getContractBlockNumber(NODE_HOST, NODE_PORT, CONTRACT_ADDRESS, SERVICE_TOKEN) {
 script {
  BLOCK_NUMBER=$(curl -X 'GET' \
    "https://${NODE_HOST}:${NODE_PORT}/cirrus/search/SimpleStorage?address=eq.${CONTRACT_ADDRESS}" \
    -H "Authorization: Bearer $SERVICE_TOKEN"  \
    -H 'accept: application/json;charset=utf-8' \
    -H 'Content-Type: application/json;charset=utf-8' \
    | jq '.[] | .block_number')
  return "${BLOCK_NUMBER}"
 }
}

return this