def cleanNode(wipeVault = null) {
  // Cleanup STRATO and volumes
  sh 'sudo docker rm -f $(sudo docker ps -aq) || true'
  sh 'sudo docker system prune -f --volumes || true'
}

def getServiceToken(nodeData) {
  script {
    def b64string = sh(returnStdout: true, script: "python -c \"import base64; print(base64.b64encode('${nodeData.BEANSTALK.OAUTH_CLIENT_ID}:${nodeData.BEANSTALK.OAUTH_CLIENT_SECRET}'))\"").trim()
    def tokenEndpoint = sh(returnStdout: true, script: "curl -s  ${nodeData.BEANSTALK.OAUTH_DISCOVERY_URL} | jq .token_endpoint | tr -d '\"'").trim()
    def serviceToken = sh(
        returnStdout: true,
        script: "curl -s -X POST '${tokenEndpoint}' " +
            "-H 'Content-Type: application/x-www-form-urlencoded' -H 'Authorization: Basic ${b64string}' " +
            "--data-urlencode 'grant_type=client_credentials' | jq -r .access_token"
    ).trim()
    if ("${serviceToken}" == null ) {
      echo "Unable to obtain service token"
      currentBuild.result = 'FAILURE'
      sh "exit 1"
    }
    echo "serviceToken: ${serviceToken}"
    return "${serviceToken}"
  }
}

def waitForHealthyBeanstalkContainers() {
  script {
    echo "Waiting for the 4 beanstalk containers to become healthy..."
    for (int i = 0; i < 50; i++) {
      if (sh(returnStdout: true, script: "sudo docker-compose --log-level ERROR ps | grep '(healthy)' | wc -l").trim() == "4") {
        return true
      } else {
        sleep 2
      }
    }
    error ("Failed to get exactly 4 beanstalk containers healthy")
  }
}

def createBeanstalkUser(fullHost, serviceToken, authCookieName) {
  script {
    // Should return 404 when user has no membership and 200 when user has one:
    def successExitCodes = [0, 22]
    def exitCode = sh(returnStatus: true, script: "curl -I --location --request GET 'https://${fullHost}/api/v1/users/me' --header 'Cookie: ${authCookieName}=${serviceToken}' --fail")
    if (!successExitCodes.contains(exitCode)) {
      echo "unexpected result for beanstalk user creation"
      currentBuild.result = 'FAILURE'
      sh "exit 1"
    }
  }
}

def requestMembership(serviceToken, role) {
  sh "sudo docker exec beanstalk_backend_1 npm run membership-util -- request --role '${role}' --token '${serviceToken}'"
}


def approveAllMemberships() {
  script {
    def membershipRequests = sh(returnStdout: true, script: "sudo docker exec beanstalk_backend_1 bash -c \"npm run membership-util -- ls | grep 'Requested' | grep '│'\" | awk '{print \$6,\$8}'").trim()
    echo "${membershipRequests}"
    sh """#!/bin/bash -le
      while IFS= read -r request; do
        echo \$request
        USERNAME=\$(echo "\${request}" | awk '{print \$1}')
        NODE_LABEL=\$(echo "\${request}" | awk '{print \$2}')
        echo "Approving membership for user: '\$USERNAME' on node with label: '\$NODE_LABEL'"
        # Approve
        sudo docker exec beanstalk_backend_1 npm run membership-util -- approve --username "\${USERNAME}" --node-label "\${NODE_LABEL}"
        # Process
        sudo docker exec beanstalk_backend_1 npm run membership-util -- process --username "\${USERNAME}" --node-label "\${NODE_LABEL}"
      done <<< '''${membershipRequests}'''
    """
  }
}

