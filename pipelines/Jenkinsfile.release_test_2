        stage ('Redeployed Contract Test') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    SERVICE_TOKEN = lib.getServiceToken(NODE_DATA.NODE1)
                    FIRST_CONTRACT_ADDRESS = lib.createContractAndGetContractAddress(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT, SERVICE_TOKEN)
                    SECOND_CONTRACT_ADDRESS = lib.createContractAndGetContractAddress(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT, SERVICE_TOKEN)
                    FIRST_BLOCK_NUMBER = lib.getContractBlockNumber(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT, FIRST_CONTRACT_ADDRESS, SERVICE_TOKEN)
                    SECOND_BLOCK_NUMBER = lib.getContractBlockNumber(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT, SECOND_CONTRACT_ADDRESS, SERVICE_TOKEN)
                    if (SECOND_BLOCK_NUMBER != FIRST_BLOCK_NUMBER+1) {
                        sh 'exit 1'
                    }
                    def ATTRIBUTE_CONTRACT_ADDRESS = sh(
                        returnStdout: true,
                        script: "curl -X 'GET' \
                        'https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/cirrus/search/Attribute' \
                        -H \"Authorization: Bearer ${SERVICE_TOKEN}\"  \
                        -H 'Accept: application/json;charset=utf-8' \
                        -H 'Content-Type: application/json;charset=utf-8' \
                        | jq '.[0] | .address'"
                        ).trim()
                    def response = sh(
                        returnStdout: true,
                        script: "curl -X 'POST' \
                        'https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/transaction/parallel?resolve=true' \
                        -H \"Authorization: Bearer ${SERVICE_TOKEN}\"  \
                        -H 'Accept: application/json;charset=utf-8' \
                        -H 'Content-Type: application/json;charset=utf-8' \
                        -d '{\"txs\": [{\"payload\": {\"contractName\": \"Attribute\",\"contractAddress\": \"${ATTRIBUTE_CONTRACT_ADDRESS}\",\"method\": \"deleteContract\",\"args\": {}},\"type\": \"FUNCTION\"}],\"txParams\": {\"gasLimit\": 32100000000,\"gasPrice\": 1}}'"
                        ).trim()
                    if (!response.contains("Only the attribute's owner can delete the attribute")) {
                        sh 'exit 1'
                    lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                    }
                }
            }
        }

