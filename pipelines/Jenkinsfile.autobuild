//                  sh 'sudo ./strato --wipe'
//                  sh 'sudo ./vault --wipe'
//                  sh './run-vault.sh'
//                  // run again but connecting to helium (testnet) this time
//                  sh 'sed -i "s|useCustomGenesis=true|useCustomGenesis=false|" run.sh'
//                  sh "sed -i 's|./strato --single|network=helium ./strato|' run.sh"
//                  sh './run.sh'
//                  sh './check_availability.sh'
//                  script{
//                    lib.runSyncTester()
//                  }
//                }
/* TODO: uncomment to enable the slipstream data integrity test, when the 'strato/indexer/slipstream/integrity_tests/slipstream_sync.py' is updated to not rely on the testnet2-specific contracts (e.g. BlockApps-PaymentService.Order) */
