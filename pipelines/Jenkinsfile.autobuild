//                        usernamePassword(credentialsId: 'keycloak-mercata-localhost-client', passwordVariable: 'KEYCLOAK_MERCATA_LOCALHOST_SECRET', usernameVariable: 'KEYCLOAK_MERCATA_LOCALHOST_ID'),
//                   ]) {
//                    sh "pip3 install -r requirements.txt"
//                    sh "python3 slipstream_sync.py '${KEYCLOAK_STRATODEVEL_DEV_ID}' '${KEYCLOAK_MERCATA_LOCALHOST_ID}' '${KEYCLOAK_STRATODEVEL_DEV_SECRET}' '${KEYCLOAK_MERCATA_LOCALHOST_SECRET}' 'strato-devel' 'mercata' 40 30 'https://node2.mercata-testnet.blockapps.net'"
//                  }
//                }
//              }
//              post {
//                always {
//                  sh 'sudo docker system prune -fa' // remove older unused images to save diskspace
//                  dir('strato-getting-started') {
//                    sh 'sudo rm -rf strato_logs*'
//                    sh 'sudo ./fetchlogs'
//                    sh 'sudo chmod 777 strato_logs.zip'
//                    sh 'mv strato_logs.zip strato_logs_testsync.zip'
//                    archiveArtifacts artifacts: 'strato_logs_testsync.zip', fingerprint: true, allowEmptyArchive: true
//                    sh 'sudo rm -rf strato_logs_testsync.zip'
//                  }
//                }
//              }
//            }
            
            stage('Deploy to Testnet') {
              // only deploy if building develop branch
              when {
                beforeAgent true
                allOf {
                  branch "develop"
                }
              }
              agent { label "testnet-build1" }
              steps {
                withCredentials([
                    usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'),
                ]) {
                  sh "sudo docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000"
                }
                unstash 'bootstrapDocker'
                dir("bootstrap-docker"){
                  withCredentials([usernamePassword(credentialsId: 'testnet-buildtest-client', passwordVariable: 'BUILDTEST_CLIENT_SECRET', usernameVariable: 'BUILDTEST_CLIENT_ID'),
                                   string(credentialsId: 'buildtest-rpc-url-sepolia', variable: 'BUILDTEST_RPC_URL_SEPOLIA'),
                                   string(credentialsId: 'buildtest-rpc-url-sepolia-fallback', variable: 'BUILDTEST_RPC_URL_SEPOLIA_FALLBACK'),
                                   string(credentialsId: 'buildtest-stripe-secret-key', variable: 'BUILDTEST_STRIPE_SECRET_KEY'),
                                   string(credentialsId: 'buildtest-stripe-publishable-key', variable: 'BUILDTEST_STRIPE_PUBLISHABLE_KEY'),
                                   string(credentialsId: 'buildtest-stripe-webhook-secret', variable: 'BUILDTEST_STRIPE_WEBHOOK_SECRET'),
                                   string(credentialsId: 'buildtest-onramp-hot-wallet-address', variable: 'BUILDTEST_ONRAMP_HOT_WALLET_ADDRESS'),
                                   usernamePassword(credentialsId: 'buildtest-bridge-admin', passwordVariable: 'BUILDTEST_BA_PASSWORD', usernameVariable: 'BUILDTEST_BA_USERNAME'),
                                   ]) {
                    writeFile file: "strato-run.sh", text: """#!/bin/bash
                        NODE_HOST='buildtest.testnet.strato.nexus' \\
                          network='helium' \\
                          OAUTH_CLIENT_ID='$BUILDTEST_CLIENT_ID' \\
                          OAUTH_CLIENT_SECRET='$BUILDTEST_CLIENT_SECRET' \\
                          RPC_URL_SEPOLIA='$BUILDTEST_RPC_URL_SEPOLIA' \\
                          RPC_URL_SEPOLIA_FALLBACK='$BUILDTEST_RPC_URL_SEPOLIA_FALLBACK' \\
                          STRIPE_SECRET_KEY='$BUILDTEST_STRIPE_SECRET_KEY' \\
                          STRIPE_PUBLISHABLE_KEY='$BUILDTEST_STRIPE_PUBLISHABLE_KEY' \\
                          STRIPE_WEBHOOK_SECRET='$BUILDTEST_STRIPE_WEBHOOK_SECRET' \\
                          ONRAMP_HOT_WALLET_ADDRESS='$BUILDTEST_ONRAMP_HOT_WALLET_ADDRESS' \\
                          BA_USERNAME='$BUILDTEST_BA_USERNAME' \\
                          BA_PASSWORD='$BUILDTEST_BA_PASSWORD' \\
                          ssl='true' \\
                          ./strato
                    """
                    
                    // Copy .pem and .key for SSL
                    sh 'cp /home/ec2-user/cloudflare-ssl/server.pem ssl/certs/'
                    sh 'cp /home/ec2-user/cloudflare-ssl/server.key ssl/private/'
                    
                    sh "sudo ./strato --pull"
                    sh "sudo ./strato --wipe"
                    sh "sudo ./strato-run.sh"
                    script {
                      lib.waitLocalNodeIsSynced()
                    }
                  }
                }
              }
              post {
                success {
                  script {
                    def VERSION = sh(
                        returnStdout: true,
                        script: "grep -oP \"#strato-version:\\\\K[^#]*\" bootstrap-docker/docker-compose.yml"
                    ).trim()
                    slackSend(
                        channel: '#engineering',
                        color: 'good',
                        message: "buildtest.testnet.strato.nexus was redeployed from develop with STRATO v.${VERSION}"
                    )
                  }

                }
              }
            }
            
          }
        }
        
        stage('Node Status') {
          steps{
            script{
              lib.checkNodeStatusHealth()
            }
          }
        }
        
//        stage('Apex tests') {
//          steps{
//            sh '''#!/bin/bash -le
//              set -x
//              echo "Running apex unit tests"
//              APEX_CONTAINER=$(docker ps --format '{{.Names}}' | grep 'apex.*1')
//              # TEMPORARY DISABLING APEX TESTS UNTIL THEY ARE CLEANED UP AND FIXED
//              # docker exec -t -e NODE_ENV=test "$APEX_CONTAINER" ./run-tests.sh
//            '''
//          }
//        }
        
        stage('Contract tests') {
          steps {
            script {
              def WORKDIR = pwd()
              catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                sh """#!/bin/bash -lex
                  find mercata/contracts/tests -name '*.test.sol' -print0 | xargs -0 -I {} sh -c 'echo "Running test: {}" && cd "\$(dirname "{}")" && $WORKDIR/.docker-work/usr/local/bin/solid-vm-cli test "\$(basename "{}")"'
                """
              }
            }
          }
        }

//        stage('Strato unit tests') {
//          steps {
//            withCredentials([
//            string(credentialsId: 'DEV_EXT_STORAGE_S3_ACCESS_KEY_ID', variable:'DEV_EXT_STORAGE_S3_ACCESS_KEY_ID'),
