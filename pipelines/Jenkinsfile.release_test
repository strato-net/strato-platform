                    script {
                        sh 'sudo ./strato --drop-chains'
                        lib.deployStratoWithApp(null, NODE_DATA.NODE1, 'beanstalk', false)
                        sh 'until curl --silent localhost:8080; do sleep 1; done'
                        sh 'sudo docker ps'
                        lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Confirm Chain Sync was Successful') {
            steps {
                script{
                    def numOfPrivChains = sh(
                        returnStdout: true,
                        script: "sudo docker exec strato_postgres_1 psql -U postgres -d `sudo docker exec strato_postgres_1 psql -U postgres -t -c \"select datname from pg_database where datname like '%eth_%';\" | tr -d \"[:space:]\"` -t -c \"select count(*) from chain_info_ref;\" | tr -d -c 0-9"
                    ).trim()

                    if(numOfPrivChains != 1) {
                        assert condition : "Build failed to sync private chains"
                    }
                }
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Shut off voted out node') {
            agent { label "multinode102" }
            steps {
                script {
                    lib.cleanNode()
                }
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Redeploy Monitor w/ 4 nodes') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'removedChainUpgrade')
                }                
            }
        }


        /* DEVNET SYNC TESTS */
        stage ('Single Node Sync with Devnet - Clean Node') {
             // agent { label "multinode101" } // is default
            steps { 
                script {
                    lib.cleanNode()
                }
            }
        }

        stage ('Single Node Sync with Devnet - Deploy Node') {
            steps {
                script {
                    lib.deployStrato(NODE_DATA.NODE1)
                }
            }
        }

        stage('Single Node Sync with Devnet - Deploy Monitor') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GITHUB_TOKEN', usernameVariable: 'GITHUB_USERNAME'),
                ]) {
                    script {
                        sh "rm -rf monitor"
                        sh "git clone https://${GITHUB_USERNAME}:${GITHUB_TOKEN}@github.com/blockapps/monitor/"
                        lib.runMonitor(NODE_DATA.NODE1, null)
                    }
                }
            }
        }

        stage('Single Node Sync with Devnet - Wait for Healthy Network') {
            steps {
                script {
                    lib.waitForHealthySync(NODE_DATA.LOAD_TEST_HEALTH_URL)
                }
            }
        }

        /* Stability Test - Restart Node */
        stage('Restart Node after Devnet Sync') {
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --stop'
                        sh 'sudo ./strato --start'
                        sh 'PASSWORD=123 ./strato --set-password'
                    }
                }
            }
        }

        stage('Wait For Restarted Node to Sync') {
            steps {
                script {
                    lib.waitForHealthySync(NODE_DATA.MONITOR)
                }
            }
        }

        /* Performance Test - Sync Network to Devnet */

        stage('Sync Network To Devnet - Redeploy Monitor w/ 4 nodes') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'networkSynctoDevnet')
                }                
            }
        }
        
    }
