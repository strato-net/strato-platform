        stage ('Redeployed Contract Test') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    SERVICE_TOKEN = lib.getServiceToken(NODE_DATA.NODE1)
                    FIRST_CONTRACT_ADDRESS = lib.createContractAndGetContractAddress(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT)
                    SECOND_CONTRACT_ADDRESS = lib.createContractAndGetContractAddress(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT)
                    FIRST_BLOCK_NUMBER = lib.getContractBlockNumber(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT, FIRST_CONTRACT_ADDRESS)
                    SECOND_BLOCK_NUMBER = lib.getContractBlockNumber(NODE_DATA.NODE1.HOST, NODE_DATA.NODE1.PORT, SECOND_CONTRACT_ADDRESS)
                    sh """
                    set -x

                    if [ $SECOND_BLOCK_NUMBER -ne ${((FIRST_BLOCK_NUMBER+1))} ]; then exit 1; fi

                    ATTRIBUTE_CONTRACT_ADDRESS=${(curl -X 'GET' \
                        'https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/cirrus/search/Attribute' \
                        -H "Authorization: Bearer $SERVICE_TOKEN"  \
                        -H 'accept: application/json;charset=utf-8' \
                        -H 'Content-Type: application/json;charset=utf-8' \
                        | jq '.[0] | .address')}

                    response=${(curl -X 'POST' \
                        'https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/transaction/parallel?resolve=true' \
                        -H "Authorization: Bearer $SERVICE_TOKEN"  \
                        -H 'accept: application/json;charset=utf-8' \
                        -H 'Content-Type: application/json;charset=utf-8' \
                        -d '{
                            "txs": [
                                    {
                                        "payload": {
                                            "contractName": "Attribute",
                                            "contractAddress": "${ATTRIBUTE_CONTRACT_ADDRESS}",
                                            "method": "deleteContract",
                                            "args": {}
                                        },
                                        "type": "FUNCTION"
                                    }
                                   ],
                            "txParams": {
                                "gasLimit": 32100000000,
                                "gasPrice": 1
                            }}')}
                    if [[ $response != *"Only the attribute's owner can delete the attribute"* ]]; then
                      exit 1
                    fi
                    """
                }
            }
        }

