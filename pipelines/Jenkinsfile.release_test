pipeline {
    agent {
        label "multinode101"
    }

    parameters {
        string(name: 'STRATO_BUILD', defaultValue: 'latest', description: 'The STRATO version to be used for deployment (where to fetch the docker-compose.yml from). \n' +
            'Default: "latest" (latest public release).\n\n' +
            'Formats supported:\n' +
            ' - "latest" - for latest public release\n' +
            ' - "X.Y.Z" (i.e. "7.5.0") - for specific public release version\n' +
            ' - "branch_name/build_number" (i.e. "develop/206") - for the custom build of STRATO_autobuild multibranch job in Jenkins.'
        )
        string(name: 'BEANSTALK_LOADTEST_BATCH_SIZE', defaultValue: '25', description: 'Number of agreements in a single batch in load test')
        string(name: 'BEANSTALK_LOADTEST_BATCH_COUNT', defaultValue: '5', description: 'Number of batches to create in load test')
    }

    stages {
        stage('Prep') {
            steps {
                sh "sudo rm -rf strato-getting-started"
                sh "git clone https://github.com/blockapps/strato-getting-started"
                dir('strato-getting-started') {
                    script {
                        if (env.STRATO_BUILD == 'latest') {
                            sh 'sudo ./strato --compose'
                            }
                        else {
                            if (env.STRATO_BUILD.contains(".") && !env.STRATO_BUILD.contains("/")) {
                                sh "curl -s -L https://github.com/blockapps/strato-getting-started/releases/${env.STRATO_BUILD} | egrep -o '/blockapps/strato-getting-started/releases/download/.*/docker-compose.yml' | wget --base=http://github.com/ -i - -O docker-compose.yml"
                                }
                            else {
                                if (!env.STRATO_BUILD.contains("/")) {
                                    echo "Unexpected STRATO_BUILD format: ${env.STRATO_BUILD}"
                                    currentBuild.result = 'FAILURE'
                                    sh "exit 1"
                                    }
                                def (AUTOBUILD_JOB_BRANCH_NAME, AUTOBUILD_JOB_BUILD_NUMBER) = "${env.STRATO_BUILD}".tokenize( '/' )
                
                                // Fetching artifact from STRATO_autobuild multibranch job
                                step([
                                    $class: 'CopyArtifact',
                                    fingerprintArtifacts: true,
                                    flatten: true,
                                    projectName: "STRATO_autobuild/${AUTOBUILD_JOB_BRANCH_NAME}",
                                    selector: [$class: 'SpecificBuildSelector', buildNumber: "${AUTOBUILD_JOB_BUILD_NUMBER}"],
                                    filter: "docker-compose.yml",
                                    target: '.',
                                    optional: false
                                ])
                                }
                            }
                        }
                    withCredentials([
                        usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'),
                    ]) {
                        sh "sudo docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000"
                        }
                    }
                stash includes: 'strato-getting-started/**', name: 'stratoGettingStarted'
            }
        }

        stage('Init') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GITHUB_TOKEN', usernameVariable: 'GITHUB_USERNAME'),
                ]) {
                    script {
                        sh "rm -rf beanstalk"
                        sh "git clone -b develop https://${GITHUB_USERNAME}:${GITHUB_TOKEN}@github.com/blockapps/beanstalk/"
                        lib = load("${env.WORKSPACE}/pipelines/Jenkinsfile.library")
                        NODE_DATA = load("${env.WORKSPACE}/pipelines/Jenkinsfile.release_config").NODE_DATA
                    }
                }
            }
        }

        /* Run Beanstalk Load Test */

        stage('Beanstalk Load Test - Clean all nodes') {
            parallel {
                stage('Clean test-multinode101') {
                    // agent { label "test-multinode101" } // is default
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode102') {
                    agent { label "test-multinode102" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode103') {
                agent { label "test-multinode103" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode104') {
                agent { label "test-multinode104" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean additional-node301') {
                agent { label "test-multinode301" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean additional-node302') {
                agent { label "test-multinode302" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode303') {
                agent { label "test-multinode303" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode304') {
                agent { label "test-multinode304" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
            }
        }
        stage('Beanstalk Load Test - Deploy SGS boot') {
            // agent { label "test-multinode101" } // is default
            steps { 
                script {
                    rootNodeAddress = lib.deployStratoWithApp(null, NODE_DATA.NODE1, 'beanstalk', false)
                }
            }            
        }

        stage('Beanstalk Load Test - Launch other nodes') {
            parallel {
                stage('Deploy SGS multinode102') {
                    agent { label "test-multinode102" }
                    steps {
                        script {
                            node2Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE2, 'beanstalk', false)
                        }
                    }
                }
                stage('Deploy SGS multinode103') {
                    agent { label "test-multinode103" }
                    steps {
                        script {
                            node3Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE3, 'beanstalk', false)
                        }
                    }
                }
                stage('Deploy SGS multinode104') {
                    agent { label "test-multinode104" }
                    steps {
                        script {
                            node4Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE4, 'beanstalk', false)
                        }
                    }
                }
                stage('Deploy SGS multinode301') {
                    agent { label "test-multinode301" }
                    steps {
                        script {
                            node5Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE5, 'beanstalk', false)
                        }
                    }
                }
                stage('Deploy SGS multinode302') {
                    agent { label "test-multinode302" }
                    steps {
                        script {
                            node6Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE6, 'beanstalk', false)
                        }
                    }
                }
                stage('Deploy SGS multinode303') {
                    agent { label "test-multinode303" }
                    steps {
                        script {
                            node7Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE7, 'beanstalk', false)
                        }
                    }
                }
                stage('Deploy SGS multinode304') {
                    agent { label "test-multinode304" }
                    steps {
                        script {
                            node8Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE8, 'beanstalk', false)
                        }
                    }
                }
            }
        }

        stage ('Beanstalk Load Test -  Run beanstalk app on bootnode') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    lib.runAppBootNode(NODE_DATA.NODE1, null, null, null, 'beanstalk')
                }
            }
        }

        stage ('Beanstalk Load Test -  Vote in secondary nodes') {
        // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script{
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node2Address} --nonce=100 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node3Address} --nonce=150 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node4Address} --nonce=200 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node5Address} --nonce=250 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node6Address} --nonce=300 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node7Address} --nonce=350 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE6.HOST}:${NODE_DATA.NODE6.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node8Address} --nonce=400 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE6.HOST}:${NODE_DATA.NODE6.PORT},${NODE_DATA.NODE7.HOST}:${NODE_DATA.NODE7.PORT} --https"
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "8" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
            }
        }

        stage ('Beanstalk Load Test - Run app on secondary nodes') {
            parallel {
                stage('Run app on multinode102') {
                agent { label "multinode102" }
                steps {
                    script {
                    lib.runAppSecondaryNode(NODE_DATA.NODE2, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode103') {
                agent { label "multinode103" }
                steps {
                    script{
                    lib.runAppSecondaryNode(NODE_DATA.NODE3, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode104') {
                agent { label "multinode104" }
                steps {
                    script {
                    lib.runAppSecondaryNode(NODE_DATA.NODE4, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode301') {
                agent { label "multinode301" }
                steps {
                    script {
                    lib.runAppSecondaryNode(NODE_DATA.NODE5, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode302') {
                agent { label "multinode302" }
                    steps {
                        script {
                            lib.runAppSecondaryNode(NODE_DATA.NODE6, null, null, null, 'beanstalk')
                        }
                    }
                }
                stage('Run app on multinode303') {
                    agent { label "multinode303" }
                    steps {
                        script { 
                            lib.runAppSecondaryNode(NODE_DATA.NODE7, null, null, null, 'beanstalk')
                        }
                    }
                }
                stage('Run app on multinode304') {
                    agent { label "multinode304" }
                    steps {
                        script {
                            lib.runAppSecondaryNode(NODE_DATA.NODE8, null, null, null, 'beanstalk')
                        }
                    }
                }
            }
        }

        stage ('Beanstalk Load Test - Approve memberships of secondary nodes') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    lib.approveAllMemberships()
                }
            }
        }
        stage ('Beanstalk load test') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    if (params.DEBUG_MODE) {
                        sh 'until [ -f /home/ubuntu/step2 ]; do sleep 5; echo "wait for file /home/ubuntu/step2 to be created by user"; done; echo "File found - continuing."'
                    }
                    lib.runBeanstalkLoadTest(${params.BEANSTALK_LOADTEST_BATCH_SIZE}, ${params.BEANSTALK_LOADTEST_BATCH_COUNT})
                }
            }
        }

        /* Run Upgradability Sync Test */

        /* Clean All Nodes */
        stage('Upgradability Sync Test - Clean all nodes') {
            parallel {
                stage('Clean test-multinode101') {
                    // agent { label "test-multinode101" } // is default
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode102') {
                    agent { label "test-multinode102" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode103') {
                agent { label "test-multinode103" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode104') {
                agent { label "test-multinode104" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean additional-node301') {
                agent { label "test-multinode301" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean additional-node302') {
                agent { label "test-multinode302" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode303') {
                agent { label "test-multinode303" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode304') {
                agent { label "test-multinode304" }
                    steps {
                        script {
                            lib.cleanNode()
                        }
                    }
                }
            }
        }

        /* Deploy SGS Boot Node */
        stage('Upgradability Sync Test - Deploy SGS boot') {
            // agent { label "test-multinode101" } // is default
            steps {
                script {
                rootNodeAddress = lib.deployStratoWithApp(null, NODE_DATA.NODE1, 'beanstalk', true)
                }
            }
        }

        /* Deploy SGS On Secondary Nodes */
        stage('Upgradability Sync Test - Launch other nodes') {
            parallel {
                stage('Deploy SGS multinode102') {
                    agent { label "test-multinode102" }
                    steps {
                        script {
                            node2Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE2, 'beanstalk', true)
                        }
                    }
                }
                stage('Deploy SGS multinode103') {
                    agent { label "test-multinode103" }
                    steps {
                        script {
                            node3Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE3, 'beanstalk', true)
                        }
                    }
                }
                stage('Deploy SGS multinode104') {
                    agent { label "test-multinode104" }
                    steps {
                        script {
                            node4Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE4, 'beanstalk', true)
                        }
                    }
                }
                stage('Deploy SGS multinode301') {
                    agent { label "test-multinode301" }
                    steps {
                        script {
                            node5Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE5, 'beanstalk', true)
                        }
                    }
                }
                stage('Deploy SGS multinode302') {
                    agent { label "test-multinode302" }
                    steps {
                        script {
                            node6Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE6, 'beanstalk', true)
                        }
                    }
                }
                stage('Deploy SGS multinode303') {
                    agent { label "test-multinode303" }
                    steps {
                        script {
                            node7Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE7, 'beanstalk', true)
                        }
                    }
                }
                stage('Deploy SGS multinode304') {
                    agent { label "test-multinode304" }
                    steps {
                        script {
                            node8Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE8, 'beanstalk', true)
                        }
                    }
                }
            }
        }

        /* Run App Boot Node */
        stage ('Upgradability Sync Test -  Run app on bootnode') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    lib.runAppBootNode(NODE_DATA.NODE1, null, null, null, 'beanstalk')
                }
            }
        }

        /* Vote Secondary Nodes */
        stage ('Upgradability Sync Test -  Vote in secondary nodes') {
        // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script{
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node2Address} --nonce=100 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node3Address} --nonce=150 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node4Address} --nonce=200 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node5Address} --nonce=250 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node6Address} --nonce=300 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node7Address} --nonce=350 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE6.HOST}:${NODE_DATA.NODE6.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node8Address} --nonce=400 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE6.HOST}:${NODE_DATA.NODE6.PORT},${NODE_DATA.NODE7.HOST}:${NODE_DATA.NODE7.PORT} --https"
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "8" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
            }
        }

        /* Run App Secondary Nodes */
        stage ('Upgradability Sync Test - Run app on secondary nodes') {
            parallel {
                stage('Run app on multinode102') {
                agent { label "multinode102" }
                steps {
                    script {
                    lib.runAppSecondaryNode(NODE_DATA.NODE2, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode103') {
                agent { label "multinode103" }
                steps {
                    script{
                    lib.runAppSecondaryNode(NODE_DATA.NODE3, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode104') {
                agent { label "multinode104" }
                steps {
                    script {
                    lib.runAppSecondaryNode(NODE_DATA.NODE4, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode301') {
                agent { label "multinode301" }
                steps {
                    script {
                    lib.runAppSecondaryNode(NODE_DATA.NODE5, null, null, null, 'beanstalk')
                    }
                }
                }
                stage('Run app on multinode302') {
                agent { label "multinode302" }
                    steps {
                        script {
                            lib.runAppSecondaryNode(NODE_DATA.NODE6, null, null, null, 'beanstalk')
                        }
                    }
                }
                stage('Run app on multinode303') {
                    agent { label "multinode303" }
                    steps {
                        script {
                            lib.runAppSecondaryNode(NODE_DATA.NODE7, null, null, null, 'beanstalk')
                        }
                    }
                }
                stage('Run app on multinode304') {
                    agent { label "multinode304" }
                    steps {
                        script {
                            lib.runAppSecondaryNode(NODE_DATA.NODE8, null, null, null, 'beanstalk')
                        }
                    }
                }
            }
        }
    
        stage ('Upgradability Sync Test - Approve memberships of secondary nodes') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    lib.approveAllMemberships()
                }
            }
        }
        stage ('Upgradability Sync Test') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    if (params.DEBUG_MODE) {
                        sh 'until [ -f /home/ubuntu/step2 ]; do sleep 5; echo "wait for file /home/ubuntu/step2 to be created by user"; done; echo "File found - continuing."'
                    }
                    lib.runBeanstalkLoadTest(${params.BEANSTALK_LOADTEST_BATCH_SIZE}, ${params.BEANSTALK_LOADTEST_BATCH_COUNT})
                }
            }
        }
        stage('Upgradability Sync Test - Deploy Monitor') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'upgrade8Nodes')
                }                
            }
        }

        /* Dropping Chains */
        /* Reboot All Nodes*/
        stage ('Dropping Chains test-multinode101') {
            // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains'
                    }
                }
            }
        }
        stage('Reboot test-multinode101') {
            // agent { label "test-multinode101" } // is default
            steps {
                script {
                    rootNodeAddress=lib.deployStratoWithApp(null, NODE_DATA.NODE1, 'beanstalk', false)
                    sh 'until curl --silent localhost:8080; do sleep 1; done'
                    sh 'sudo docker ps'
                    lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                }
            }
        }

        stage ('Dropping Chains test-multinode102') {
            agent { label "multinode102" } // is default
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains'
                    }

                }
            }
        }
        stage('Reboot test-multinode102') {
            agent { label "test-multinode102" }
            steps {
                script {
                    lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE2, 'beanstalk', false)
                    sh 'until curl --silent localhost:8080; do sleep 1; done'
                    sh 'sudo docker ps'
                    lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                }
            }
        }
        stage ('Dropping Chains test-multinode103') {
            agent { label "multinode103" } // is default
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains'
                    }

                }
            }
        }
        stage('Reboot test-multinode103') {
            agent { label "test-multinode103" }
