        stage ('Redeployed Contract Test -  Run beanstalk app on bootnode') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    lib.runAppBootNode(NODE_DATA.NODE1, null, null, null, 'beanstalk')
                }
            }
        }

        
        stage('Upgrade w/ node chain data - Check if Node 5 was added to Chain') {
            agent { label "test-multinode301" }
            steps {
                script {
                    def numOfPrivChains = sh(
                        returnStdout: true,
                        script: "sudo docker exec strato_postgres_1 psql -U postgres -d `sudo docker exec strato_postgres_1 psql -U postgres -t -c \"select datname from pg_database where datname like '%eth_%';\" | tr -d \"[:space:]\"` -t -c \"select count(*) from chain_info_ref;\" | tr -d -c 0-9"
                    ).trim()

                    if(numOfPrivChains == 0) {
                        assert condition : "Build failed to add Node 5 to private chain"
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Deploy Monitor') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'nodeChainUpgrade')
                }                
            }
        }

        stage('Upgrade w/ node chain data - Upgrade Node 4') {
            agent { label "test-multinode104" }
            steps {
                dir('strato-getting-started') {
