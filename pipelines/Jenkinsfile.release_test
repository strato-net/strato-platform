        // stage('x509 Posting a certificate associates a user with an organization - Upload Simple Storage') {
        //     steps {
        //         script {
        //             def accessToken = sh(
        //             returnStdout: true,
        //             script: "curl -s -X POST 'https://keycloak.blockapps.net/auth/realms/beanstalk/protocol/openid-connect/token' -H 'Content-Type: application/x-www-form-urlencoded' -H 'Authorization: Basic ZGV2OjFkMmU5NzRhLTc0ZmUtNDhkOS1iNzI5LTFkZTk0Y2M5NWExZQ==' --data-urlencode 'grant_type=password' --data-urlencode 'username=grower' --data-urlencode 'password=1234' | jq -r .access_token"
        //             ).trim()  
        //             def createUser = sh(
        //                 returnStdout: true,
        //                 script: "curl -X POST -H \"Authorization: Bearer ${accessToken}\" -H \"Accept: application/json\" \"https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/key\""
        //             ).trim()

        //         }
        //     }
        // }

        /* DEVNET SYNC TESTS */
        stage ('Single Node Sync with Devnet - Clean Node') {
             // agent { label "multinode101" } // is default
            steps { 
                script {
                    lib.cleanNode()
                }
            }
        }

        stage ('Single Node Sync with Devnet - Deploy Node') {
            steps {
                script {
                    lib.deployStrato(NODE_DATA.NODE1)
                }
            }
        }

        stage('Single Node Sync with Devnet - Deploy Monitor') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GITHUB_TOKEN', usernameVariable: 'GITHUB_USERNAME'),
                ]) {
                    script {
                        sh "rm -rf monitor"
                        sh "git clone https://${GITHUB_USERNAME}:${GITHUB_TOKEN}@github.com/blockapps/monitor/"
                        lib.runMonitor(NODE_DATA.NODE1, null)
                    }
                }
            }
        }

        stage('Single Node Sync with Devnet - Wait for Healthy Network') {
            steps {
                script {
                    lib.waitForHealthySync(NODE_DATA.LOAD_TEST_HEALTH_URL)
                }
            }
        }

        /* Stability Test - Restart Node */
        stage('Restart Node after Devnet Sync') {
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --stop'
                        sh 'sudo ./strato --start'
                        sh 'PASSWORD=123 ./strato --set-password'
                    }
                }
            }
        }

        stage('Wait For Restarted Node to Sync') {
            steps {
                script {
                    lib.waitForHealthySync(NODE_DATA.MONITOR)
                }
            }
        }

        /* Performance Test - Sync Network to Devnet */

        stage('Sync Network To Devnet - Redeploy Monitor w/ 4 nodes') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'networkSynctoDevnet')
                }                
            }
        }

        stage('Sync Network To Devnet') {
            parallel {
                stage('Sync multinode101') {
                    // agent { label "multinode101" } // is default
                    steps {
                        script {
                            lib.deployStrato(NODE_DATA.NODE1)
                        }
                    } 
                }
                stage('Sync multinode102') {
                    agent { label "multinode102" }
                    steps {
                        script {
                            lib.deployStrato(NODE_DATA.NODE2)
                        }
                    }
                }
                stage('Sync multinode103') {
                    agent { label "multinode102" }
                    steps {
                        script {
                            lib.deployStrato(NODE_DATA.NODE3)
                        }
                    }
                }
                stage('Sync multinode104') {
                    agent { label "multinode104" }
                    steps {
                        script {
                            lib.deployStrato(NODE_DATA.NODE4)
                        }
                    }
                }
            }
        }
        
    }
}