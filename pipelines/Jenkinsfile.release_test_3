pipeline {
    agent {
        label "multinode101"
    }

    parameters {
        string(name: 'STRATO_BUILD', defaultValue: 'develop', description: 'The STRATO version to be used for deployment (where to fetch the docker-compose.yml from). \n' +
            'Default: "develop" (latest develop).\n\n' +
            'Formats supported:\n' +
            ' - "latest" - for latest public release\n' +
            ' - "X.Y.Z" (i.e. "7.5.0") - for specific public release version\n' +
            ' - "branch_name/build_number" (i.e. "develop/206") - for the custom build of STRATO_autobuild multibranch job in Jenkins.'
        )
    }

    stages {
        /* PREP STAGE */
        stage('Prep') {
            steps {
                sh "sudo rm -rf strato-getting-started"
                sh "git clone https://github.com/blockapps/strato-getting-started"
                dir('strato-getting-started') {
                    script {
                        if (env.STRATO_BUILD == 'latest') {
                            sh 'sudo ./strato --compose'
                            } else if (env.STRATO_BUILD == 'develop') {
                            // Fetching artifact from last successful build of STRATO_autobuild multibranch develop job
                            step([
                                    $class: 'CopyArtifact',
                                    fingerprintArtifacts: true,
                                    flatten: true,
                                    projectName: "STRATO_autobuild/develop",
                                    selector: [$class: 'StatusBuildSelector'],
                                    filter: "docker-compose.yml",
                                    target: '.',
                                    optional: false
                            ])
                        }
                        else {
                            if (env.STRATO_BUILD.contains(".") && !env.STRATO_BUILD.contains("/")) {
                                sh "curl -s -L https://github.com/blockapps/strato-getting-started/releases/${env.STRATO_BUILD} | egrep -o '/blockapps/strato-getting-started/releases/download/.*/docker-compose.yml' | wget --base=http://github.com/ -i - -O docker-compose.yml"
                                }
                            else {
                                if (!env.STRATO_BUILD.contains("/")) {
                                    echo "Unexpected STRATO_BUILD format: ${env.STRATO_BUILD}"
                                    currentBuild.result = 'FAILURE'
                                    sh "exit 1"
                                    }
                                def (AUTOBUILD_JOB_BRANCH_NAME, AUTOBUILD_JOB_BUILD_NUMBER) = "${env.STRATO_BUILD}".tokenize( '/' )
                                // Fetching artifact from STRATO_autobuild multibranch job
                                step([
                                    $class: 'CopyArtifact',
                                    fingerprintArtifacts: true,
                                    flatten: true,
                                    projectName: "STRATO_autobuild/${AUTOBUILD_JOB_BRANCH_NAME}",
                                    selector: [$class: 'SpecificBuildSelector', buildNumber: "${AUTOBUILD_JOB_BUILD_NUMBER}"],
                                    filter: "docker-compose.yml",
                                    target: '.',
                                    optional: false
                                ])
                                }
                            }
                        }
                    withCredentials([
                        usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'),
                    ]) {
                        sh "sudo docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000"
                        }
                    }
                stash includes: 'strato-getting-started/**', name: 'stratoGettingStarted'
            }
        }

        stage('Init') {
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GITHUB_TOKEN', usernameVariable: 'GITHUB_USERNAME'),
                ]) {
                    script {
                        lib = load("${env.WORKSPACE}/pipelines/Jenkinsfile.library")
                        NODE_DATA = load("${env.WORKSPACE}/pipelines/Jenkinsfile.release_config").NODE_DATA
                    }
                }
            }
        }

        /* Upgrade with single node chain data */
        stage('Upgrade w/ node chain data - Clean all nodes') {
            parallel {
                stage('Clean test-multinode101') {
                    // agent { label "test-multinode101" } // is default
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode102') {
                    agent { label "test-multinode102" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode103') {
                agent { label "test-multinode103" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean test-multinode104') {
                agent { label "test-multinode104" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
                stage('Clean additional-node301') {
                agent { label "test-multinode301" }
                    steps { 
                        script {
                            lib.cleanNode()
                        }
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Deploy SGS boot') {    
            // agent { label "test-multinode101" } // is default
            steps { 
                script {
                    rootNodeAddress = lib.deployStratoWithApp(null, NODE_DATA.NODE1, 'traceharvest', true) 
                }
            }            
        }

        stage('Upgrade w/ node chain data - Launch other nodes') {
            parallel {
                stage('Deploy SGS multinode102') {
                    agent { label "test-multinode102" }
                    steps {
                        script {
                            node2Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE2, 'traceharvest', true)
                        }
                    }
                }
                stage('Deploy SGS multinode103') {
                    agent { label "test-multinode103" }
                    steps {
                        script {
                            node3Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE3, 'traceharvest', true)
                        }
                    }
                }
                stage('Deploy SGS multinode104') {
                    agent { label "test-multinode104" }
                    steps {
                        script {
                            node4Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE4, 'traceharvest', true)
                        }
                    }
                }
            }
        }

        stage ('Upgrade w/ node chain data -  Vote in secondary nodes') {
            // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script{
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node2Address} --nonce=100 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node3Address} --nonce=150 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node4Address} --nonce=200 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "4" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
            }
        }

        stage ('Upgrade w/ node chain data - Run traceharvest app on bootnode') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    lib.runAppBootNode(NODE_DATA.NODE1, true, null, null, 'traceharvest')
                }
            }
        }

        stage ('Upgrade w/ node chain data - Create Private Chains') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    def successExitCodes = [0, 124]
                    def exitCode = sh(returnStatus: true, script: "sudo timeout 60s docker exec beanstalk_backend_1 npm run deploy:csv")
                    if (!successExitCodes.contains(exitCode)) {
                      echo "failure in csv deployment"
                      currentBuild.result = 'FAILURE'
                      sh "exit 1"
                    }
                    // def createChains = sh(
                    //     returnStdout: true,
                    //     script: "sudo timeout 60s docker exec beanstalk_backend_1 npm run deploy:csv"
                    // ).trim
                    // sh "createChains=$(sudo docker exec beanstalk_backend_1 npm run deploy:csv)"
                    // sh "export -f createChains"
                    // sh "timeout 60s bash -c createChains"
                }
            }
        }

        stage ('Upgrade w/ node chain data - Check the number of chains') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    int numOfPrivChains = sh(
                        returnStdout: true,
                        script: "sudo docker exec strato_postgres_1 psql -U postgres -d `sudo docker exec strato_postgres_1 psql -U postgres -t -c \"select datname from pg_database where datname like '%eth_%';\" | tr -d \"[:space:]\"` -t -c \"select count(*) from chain_info_ref;\" | tr -d -c 0-9"
                    ).trim()
                    echo "${numOfPrivChains}"
                    if(numOfPrivChains == 0) {
                        assert condition : "Build failed to create private chains"
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Deploy SGS multinode301') {
            agent { label "test-multinode301" }
            steps {
                script {
                    node5Address = lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE5, 'traceharvest', false)
                    dir('strato-getting-started') {
                        node5Pubkey = readFile(file: 'publicKey')
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Add new node to private chain') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    def accessToken = sh(
                        returnStdout: true,
                        script: "curl -s -X POST 'https://keycloak.blockapps.net/auth/realms/traceharvest-demo-tech/protocol/openid-connect/token' -H 'Content-Type: application/x-www-form-urlencoded' -H 'Authorization: Basic dGhkZW1vLXRlY2g6ZjY3Y2I0MWMtMGFjMC00N2FjLWE1OWYtMmFkZWQxN2IwMzI1' --data-urlencode 'grant_type=password' --data-urlencode 'username=tech1' --data-urlencode 'password=123' | jq -r .access_token"
                    ).trim()

                    def privChainId = sh(
                        returnStdout: true,
                        script: "sudo docker exec strato_postgres_1 psql -U postgres -d `sudo docker exec strato_postgres_1 psql -U postgres -t -c \"select datname from pg_database where datname like '%eth_%';\" | tr -d \"[:space:]\"` -t -c \"select chain_id from chain_info_ref limit 1;\""
                    ).trim()

                    sh "curl -X POST -H \"Authorization: Bearer ${accessToken}\" -H \"Accept: application/json\" \"https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/key\""
                    sh """curl -s -X POST 'https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/transaction/parallel?resolve=true' -H 'Authorization: Bearer ${accessToken}' \
                        -H 'Content-Type: application/json' --data-raw '{
                        \"txs\": [
                            {
                            \"payload\": {
                        \"contractName\": \"Governance\",
                        \"contractAddress\": \"0000000000000000000000000000000000000100\",
                        \"method\": \"addMember\",
                        \"args\": {
                            \"_member\": \"${node5Address}\",
                            \"_enode\": \"enode://${node5Pubkey}@${NODE_DATA.NODE5.IP}:30303\"
                        },
                        \"chainid\": \"${privChainId}\"
                            },
                            \"type\": \"FUNCTION\"
                            }
                        ]
                        }'"""
                }
            }
        }

        stage('Upgrade w/ node chain data - Check if Node 5 was added to Chain') {
            agent { label "test-multinode301" }
            steps {
                script {
                    int numOfPrivChains = sh(
                        returnStdout: true,
                        script: "sudo docker exec strato_postgres_1 psql -U postgres -d `sudo docker exec strato_postgres_1 psql -U postgres -t -c \"select datname from pg_database where datname like '%eth_%';\" | tr -d \"[:space:]\"` -t -c \"select count(*) from chain_info_ref;\" | tr -d -c 0-9"
                    ).trim()
                    echo "${numOfPrivChains}"
                    if(numOfPrivChains == 0) {
                        assert condition : "Build failed to add Node 5 to private chain"
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Deploy Monitor') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'nodeChainUpgrade')
                }                
            }
        }

        stage('Upgrade w/ node chain data - Upgrade Node 4') {
            agent { label "test-multinode104" }
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains'
                        lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE4, 'traceharvest', false)
                        sh 'until curl --silent localhost:8080; do sleep 1; done'
                        sh 'sudo docker ps'
                        lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Upgrade Node 3') {
            agent { label "test-multinode103" }
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains'
                        lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE3, 'traceharvest', false)
                        sh 'until curl --silent localhost:8080; do sleep 1; done'
                        sh 'sudo docker ps'
                        lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Upgrade Node 2') {
            agent { label "test-multinode102" }
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains'
                        lib.deployStratoWithApp(rootNodeAddress, NODE_DATA.NODE2, 'traceharvest', false)
                        sh 'until curl --silent localhost:8080; do sleep 1; done'
                        sh 'sudo docker ps'
                        lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Upgrade Node 1') {
            // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script {
                        sh 'sudo ./strato --drop-chains -f'
                        lib.deployStratoWithApp(null, NODE_DATA.NODE1, 'traceharvest', false)
                        sh 'until curl --silent localhost:8080; do sleep 1; done'
                        sh 'sudo docker ps'
                        lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                    }
                }
            }
        }

        stage('Upgrade w/ node chain data - Confirm Chain Sync was Successful') {
            // agent { label "multinode101" } // is default
            steps {
                script{
                    int numOfPrivChains = sh(
                        returnStdout: true,
                        script: "sudo docker exec strato_postgres_1 psql -U postgres -d `sudo docker exec strato_postgres_1 psql -U postgres -t -c \"select datname from pg_database where datname like '%eth_%';\" | tr -d \"[:space:]\"` -t -c \"select count(*) from chain_info_ref;\" | tr -d -c 0-9"
                    ).trim()
                    echo "${numOfPrivChains}"
                    if(numOfPrivChains != 1) {
                        assert condition : "Build failed to sync private chains"
                    }
                }
            }
        }

        /* Add/Remove Node on an Upgraded Network */

        stage('Add/Remove Node on an Upgraded Network - Vote in 5th Node') {
            // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script{
                        sh "sudo ./strato.sh --blockstanbul-vote --recipient=${node5Address} --nonce=250 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE2.HOST}:${NODE_DATA.NODE2.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "5" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Confirm the 5th Node was Voted In on Another Node') {
            agent { label "multinode103" }
            steps {
                dir('strato-getting-started') {
                    script {
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "5" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Confirm the New Node Accepts Transactions and Syncs') {
            agent { label "multinode301" }
            steps {
                script {
                    def accessToken = sh(
                        returnStdout: true,
                        script: "curl -s -X POST 'https://keycloak.blockapps.net/auth/realms/traceharvest-demo-tech/protocol/openid-connect/token' -H 'Content-Type: application/x-www-form-urlencoded' -H 'Authorization: Basic dGhkZW1vLXRlY2g6ZjY3Y2I0MWMtMGFjMC00N2FjLWE1OWYtMmFkZWQxN2IwMzI1' --data-urlencode 'grant_type=password' --data-urlencode 'username=tech1' --data-urlencode 'password=123' | jq -r .access_token"
                    ).trim()
                    def createUser = sh(
                        returnStdout: true,
                        script: "curl -X POST -H \"Authorization: Bearer ${accessToken}\" -H \"Accept: application/json\" \"https://${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT}/strato/v2.3/key\""
                    ).trim()
                    def txResponse = sh(
                        returnStdout: true,
                        script: "curl 'https://${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT}/strato/v2.3/transaction?resolve=true' \
                            -X 'POST' \
                            -H \"Authorization: Bearer ${accessToken}\"  \
                            -H 'Accept: application/json;charset=utf-8' \
                            -H 'Content-Type: application/json' \
                            --data-binary '{\"txs\":[{\"payload\":{\"contract\":\"SimpleStorage\",\"src\":\"contract SimpleStorage {  uint storedData;  function SimpleStorage() {    storedData = 1;  }  function set(uint x) {    storedData = x;  }  function get() constant returns (uint) {    return storedData;  }}\",\"args\":{},\"metadata\":{\"VM\":\"SolidVM\",\"history\":\"SimpleStorage\",\"index\":\"SimpleStorage\"}},\"type\":\"CONTRACT\"}]}' | jq -r .[0].status"
                    ).trim()
                    if(txResponse != 'Success') {
                        assert condition : "Build failed to accept new Transaction"
                    }

                    lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                }
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Vote Out and Remove Node from Network') {
            // agent { label "multinode101" } // is default
            steps {
                dir('strato-getting-started') {
                    script{
                        sh "sudo ./strato.sh --blockstanbul-vote --remove --recipient=${node2Address} --nonce=300 --nodes=${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT},${NODE_DATA.NODE5.HOST}:${NODE_DATA.NODE5.PORT},${NODE_DATA.NODE3.HOST}:${NODE_DATA.NODE3.PORT},${NODE_DATA.NODE4.HOST}:${NODE_DATA.NODE4.PORT} --https"
                        sleep(time:10,unit:"SECONDS")
                        sh '''
                        set -x
                        counter=0
                        until [ "$counter" -eq "4" ]
                        do
                            voteList=$(sudo docker exec -i strato_strato_1 bash -c "tail -n 100 logs/strato-sequencer | grep showctx/validators | tail -n 1 | cut -d '|' -f 4 ")
                            counter=$(echo "$voteList" | jq ". | length")
                            echo $counter
                        done
                        '''
                    }
                }
                script {
                    def accessToken = sh(
                        returnStdout: true,
                        script: "curl -s -X POST 'https://keycloak.blockapps.net/auth/realms/traceharvest-demo-tech/protocol/openid-connect/token' -H 'Content-Type: application/x-www-form-urlencoded' -H 'Authorization: Basic dGhkZW1vLXRlY2g6ZjY3Y2I0MWMtMGFjMC00N2FjLWE1OWYtMmFkZWQxN2IwMzI1' --data-urlencode 'grant_type=password' --data-urlencode 'username=tech1' --data-urlencode 'password=1234' | jq -r .access_token"
                    ).trim()  
                    def createUser = sh(
                        returnStdout: true,
                        script: "curl -X POST -H \"Authorization: Bearer ${accessToken}\" -H \"Accept: application/json\" \"https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/key\""
                    ).trim()
                    lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                }       
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Shut off voted out node') {
            agent { label "multinode102" }
            steps {
                script {
                    lib.cleanNode()
                }
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Redeploy Monitor w/ 4 nodes') {
            agent { label "multinode305" }
            steps {
                script {
                    lib.runMonitor(NODE_DATA.NODE1, 'removedChainUpgrade')
                }                
            }
        }

        stage('Add/Remove Node on an Upgraded Network - Confirm Network Syncs after Voted out Node shuts off') {
            // agent { label "multinode101" } // is default
            steps {
                script {
                    def accessToken = sh(
                        returnStdout: true,
                        script: "curl -s -X POST 'https://keycloak.blockapps.net/auth/realms/traceharvest-demo-tech/protocol/openid-connect/token' -H 'Content-Type: application/x-www-form-urlencoded' -H 'Authorization: Basic dGhkZW1vLXRlY2g6ZjY3Y2I0MWMtMGFjMC00N2FjLWE1OWYtMmFkZWQxN2IwMzI1' --data-urlencode 'grant_type=password' --data-urlencode 'username=tech1' --data-urlencode 'password=123' | jq -r .access_token"
                    ).trim()  
                    def txResponse = sh(
                        returnStdout: true,
                        script: "curl 'https://${NODE_DATA.NODE1.HOST}:${NODE_DATA.NODE1.PORT}/strato/v2.3/transaction?resolve=true' \
                            -X 'POST' \
                            -H \"Authorization: Bearer ${accessToken}\"  \
                            -H 'Accept: application/json;charset=utf-8' \
                            -H 'Content-Type: application/json' \
                            --data-binary '{\"txs\":[{\"payload\":{\"contract\":\"SimpleStorage\",\"src\":\"contract SimpleStorage {  uint storedData;  function SimpleStorage() {    storedData = 1;  }  function set(uint x) {    storedData = x;  }  function get() constant returns (uint) {    return storedData;  }}\",\"args\":{},\"metadata\":{\"VM\":\"SolidVM\",\"history\":\"SimpleStorage\",\"index\":\"SimpleStorage\"}},\"type\":\"CONTRACT\"}]}' | jq -r .[0].status"
                    ).trim()
                    if(txResponse != 'Success') {
                        assert condition : "Build failed to accept new Transaction"
                    }

                    lib.waitForHealthySync(NODE_DATA.MONITOR.LOAD_TEST_HEALTH_URL)
                }      
            }
        }
    }
}