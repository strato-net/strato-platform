pipeline {
  agent { label "utility" }
  stages {
    stage('Update Testnet2-Marketplace with latest Develop') {
      agent { label "mercata-testnet2-marketplace" }
      steps {
        copyArtifacts filter: 'docker-compose.yml', fingerprintArtifacts: true, projectName: 'STRATO_autobuild/develop', selector: lastSuccessful()
        
        
        dir ('/datadrive/testnet2/strato-getting-started') {
          sh 'mv docker-compose.yml docker-compose.$(date \'+%Y%m%d\').yml || true'
        }
        sh 'mv docker-compose.yml /datadrive/testnet2/strato-getting-started'
        
        dir ('/datadrive/testnet2/strato-getting-started') {
          sh 'sudo ./strato --pull'
          sh 'sudo ./strato --wipe && sudo ./strato-run.sh'
        }
        sh 'sudo docker image prune'
      }
    }
  }
  post {
    success {
      slackSend (
          color: 'good',
          message: "MERCATA_update_testnet2_marketplace_node build success: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
    }
    
    failure {
      slackSend (
          color: 'danger',
          message: "MERCATA_update_testnet2_marketplace_node build failed: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
      slackSend(
          channel: '#engineering',
          color: 'danger',
          message: "MERCATA_update_testnet2_marketplace_node build failed: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL}"
      )
    }
  }
}
