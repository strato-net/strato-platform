              echo "Diskspace freed on test3: $diskspaceFreed kilobytes"
            }
          }
        }

        stage('Cleanup test4') {
          when {
            beforeAgent true
            expression {
              if (nodesByLabel("test4").size() == 0) {
                currentBuild.result = 'UNSTABLE'
                return false
              } else return true
            }
          }
