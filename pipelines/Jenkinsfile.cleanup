              echo "Diskspace freed on test4: $diskspaceFreed kilobytes"
            }
          }
        }

        stage('Cleanup test5') {
          when {
            beforeAgent true
            expression {
              if (nodesByLabel("test5").size() == 0) {
                currentBuild.result = 'UNSTABLE'
                return false
              } else return true
            }
          }
          agent { label "test5" }
          steps {
            script {
              def diskspaceFreed = cleanOldWorkspaces(4, '/')
              echo "Diskspace freed on test5: $diskspaceFreed kilobytes"
            }
          }
        }
        
        stage('Cleanup test6') {
          when {
            beforeAgent true
            expression {
              if (nodesByLabel("test6").size() == 0) {
                currentBuild.result = 'UNSTABLE'
                return false
              } else return true
            }
          }
          agent { label "test6" }
          steps {
            script {
              def diskspaceFreed = cleanOldWorkspaces(4, '/')
              echo "Diskspace freed on test6: $diskspaceFreed kilobytes"
            }
          }
        }
        
        stage('Cleanup testsync1') {
          when {
            beforeAgent true
            expression {
              if (nodesByLabel("testsync1").size() == 0) {
                currentBuild.result = 'UNSTABLE'
                return false
              } else return true
            }
          }
          agent { label "testsync1" }
          steps {
            script {
              def diskspaceFreed = cleanOldWorkspaces(4, '/datadrive')
              echo "Diskspace freed on testsync1: $diskspaceFreed kilobytes"
            }
          }
        }
        
        stage('Cleanup testsync2') {
          when {
            beforeAgent true
            expression {
              if (nodesByLabel("testsync2").size() == 0) {
                currentBuild.result = 'UNSTABLE'
                return false
              } else return true
            }
          }
          agent { label "testsync2" }
          steps {
            script {
              def diskspaceFreed = cleanOldWorkspaces(4, '/datadrive')
              echo "Diskspace freed on testsync2: $diskspaceFreed kilobytes"
            }
          }
        }
        
        stage('Cleanup testsync3') {
          when {
            beforeAgent true
            expression {
              if (nodesByLabel("testsync3").size() == 0) {
                currentBuild.result = 'UNSTABLE'
                return false
              } else return true
            }
          }
          agent { label "testsync3" }
          steps {
            script {
              def diskspaceFreed = cleanOldWorkspaces(4, '/datadrive')
              echo "Diskspace freed on testsync3: $diskspaceFreed kilobytes"
            }
          }
        }
      }
    }
  }

  post {

    success {
      slackSend(
          color: 'good',
          message: "Workspace cleanup nightly build success: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
    }

    failure {
      slackSend(
          color: 'danger',
          message: "Workspace cleanup nightly build failure: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
      slackSend(
          channel: '#engineering',
          color: 'danger',
          message: "Workspace cleanup nightly build failure: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL}"
      )
    }

    unstable {
      slackSend(
          color: 'warning',
          message: "Workspace cleanup nightly build is unstable (some agents were offline): Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
      slackSend(
          channel: '#engineering',
          color: 'warning',
          message: "Workspace cleanup nightly build is unstable (some agents were offline): Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL}"
      )
    }

  }
}


