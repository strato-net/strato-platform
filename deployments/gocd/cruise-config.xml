<?xml version="1.0" encoding="utf-8"?>
<cruise xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="cruise-config.xsd" schemaVersion="81">
  <server artifactsdir="artifacts" commandRepositoryLocation="default" serverId="9dcb89b0-ed18-47ec-969c-da142235759b">
    <security>
      <passwordFile path="/var/go/password" />
      <admins>
        <user>admin</user>
      </admins>
    </security>
  </server>
  <pipelines group="strato">
    <pipeline name="javascript_test">
      <materials>
        <git url="https://github.com/blockapps/blockapps-js" branch="develop" dest="blockapps-js" materialName="blockapps-js" />
        <git url="https://github.com/blockapps/bloc" branch="develop" dest="bloc" materialName="bloc" />
      </materials>
      <stage name="on_push">
        <jobs>
          <job name="build">
            <tasks>
              <exec command="npm" workingdir="blockapps-js">
                <arg>install</arg>
                <runif status="passed" />
              </exec>
              <exec command="npm" workingdir="bloc">
                <arg>install</arg>
                <runif status="passed" />
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
    <pipeline name="strato_branch" isLocked="false">
      <params>
        <param name="BRANCH">develop</param>
        <param name="DEPLOYMENTS_BRANCH">apt-get-clean</param>
      </params>
      <environmentvariables>
        <variable name="stratoVersion">
          <value>v0.1</value>
        </variable>
        <variable name="stratoRepository">
          <value />
        </variable>
        <variable name="stratoRegistry">
          <value />
        </variable>
        <variable name="stratoHost">
          <value />
        </variable>
      </environmentvariables>
      <materials>
        <git url="https://github.com/blockapps/gocd.git" dest="stub" materialName="STUB" />
      </materials>
      <stage name="strato_to_registry">
        <jobs>
          <job name="setup_job">
            <tasks>
              <exec command="/bin/sh">
                <arg>-c</arg>
                <arg>mgit clone https://github.com/blockapps/strato.git -b #{BRANCH}</arg>
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments/docker/">
                <arg>-c</arg>
                <arg>./echoEnv.sh</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments">
                <arg>-c</arg>
                <arg>git fetch; git checkout #{DEPLOYMENTS_BRANCH};</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato">
                <arg>-c</arg>
                <arg>deployments/docker/stackSetup.sh</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments/docker/">
                <arg>-c</arg>
                <arg>./build-all --push</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments/docker/">
                <arg>-c</arg>
                <arg>./removeImages.sh</arg>
                <runif status="passed" />
              </exec>
            </tasks>
            <resources>
              <resource>local</resource>
            </resources>
          </job>
        </jobs>
      </stage>
    </pipeline>
    <pipeline name="strato_latest" isLocked="false">
      <materials>
        <git url="https://github.com/blockapps/ethereum-vm" branch="develop" dest="tmp/ethereum-vm" materialName="ethereum-vm" />
        <git url="ssh://github.com/blockapps/strato-api" branch="develop" dest="tmp/strato-api" materialName="strato-api" />
        <git url="https://github.com/blockapps/strato-p2p-server" branch="develop" dest="tmp/strato-p2p-server" materialName="strato-p2p-server" />
        <git url="https://github.com/blockapps/ethereum-encryption" branch="develop" dest="tmp/ethereum-encryption" materialName="ethereum-encryption" />
        <git url="https://github.com/blockapps/ethereum-rlp" branch="develop" dest="tmp/ethereum-rlp" materialName="ethereum-rlp" />
        <git url="https://github.com/blockapps/strato-p2p-client" branch="develop" dest="tmp/strato-p2p-client" materialName="strato-p2p-client" />
        <git url="https://github.com/blockapps/ethereum-discovery" branch="develop" dest="tmp/ethereum-discovery" materialName="ethereum-discovery" />
        <git url="ssh://github.com/blockapps/strato-index" branch="develop" dest="tmp/strato-index" materialName="strato-index" />
        <git url="https://github.com/blockapps/strato-adit" branch="develop" dest="tmp/strato-adit" materialName="strato-adit" />
        <git url="https://github.com/blockapps/strato-quarry" branch="develop" dest="tmp/strato-quarry" materialName="strato-quarry" />
        <git url="https://github.com/blockapps/blockapps-tools" branch="develop" dest="tmp/blockapps-tools" materialName="blockapps-tools" />
        <git url="https://github.com/blockapps/solidity-abi" branch="develop" dest="tmp/solidity-abi" materialName="solidity-abi" />
        <git url="https://github.com/blockapps/miner-ethash" branch="develop" dest="tmp/miner-ethash" materialName="miner-ethash" />
        <git url="https://github.com/blockapps/merkle-patricia-db" branch="develop" dest="tmp/merkle-patricia-db" materialName="merkle-patricia-db" />
        <git url="https://github.com/blockapps/blockapps-util" branch="develop" dest="tmp/blockapps-util" materialName="blockapps-util" />
        <git url="https://github.com/blockapps/strato-conf" branch="develop" dest="tmp/strato-conf" materialName="strato-conf" />
        <git url="https://github.com/blockapps/blockapps-data" branch="develop" dest="tmp/blockapps-data" materialName="blockapps-data" />
        <git url="https://github.com/blockapps/strato-scripts" branch="develop" dest="tmp/strato-scripts" materialName="strato-scripts" />
        <git url="https://github.com/blockapps/bloc.git" branch="develop" dest="tmp/bloc" materialName="bloc" />
        <git url="https://github.com/blockapps/strato-explorer.git" branch="develop" dest="tmp/strato-explorer" materialName="strato-explorer" />
        <git url="https://github.com/blockapps/strato.git" branch="develop" dest="tmp/strato" />
        <git url="https://github.com/blockapps/deployments" branch="develop" dest="tmp/deployment" materialName="deployment" />
        <git url="https://github.com/blockapps/blockapps-js" branch="develop" dest="tmp/blockapps-js" materialName="blockapps-js" />
      </materials>
      <stage name="strato_to_registry">
        <jobs>
          <job name="setup_job">
            <tasks>
              <exec command="/bin/sh">
                <arg>-c</arg>
                <arg>mgit clone https://github.com/blockapps/strato.git -b develop</arg>
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments/docker/">
                <arg>-c</arg>
                <arg>./echoEnv.sh</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato">
                <arg>-c</arg>
                <arg>deployments/docker/stackSetup.sh</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments/docker/">
                <arg>-c</arg>
                <arg>./build-all --push</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="strato/deployments/docker/">
                <arg>-c</arg>
                <arg>./removeImages.sh</arg>
                <runif status="passed" />
              </exec>
            </tasks>
            <resources>
              <resource>local</resource>
            </resources>
          </job>
        </jobs>
      </stage>
    </pipeline>
    <pipeline name="run_e2e" isLocked="false">
      <params>
        <param name="DEPLOYMENTS_BRANCH">121601623_RunE2eTests</param>
        <param name="zzz">121601623_RunE2eTests</param>
      </params>
      <materials>
        <git url="https://github.com/blockapps/strato.git" autoUpdate="false" />
      </materials>
      <stage name="defaultStage">
        <jobs>
          <job name="defaultJob">
            <tasks>
              <exec command="/bin/sh">
                <arg>-c</arg>
                <arg>git clone ssh://github.com/blockapps/deployments.git -b #{DEPLOYMENTS_BRANCH}</arg>
                <runif status="passed" />
              </exec>
              <exec command="/bin/sh" workingdir="deployments/docker/">
                <arg>-c</arg>
                <arg>./start-strato.sh single</arg>
              </exec>
              <exec command="/bin/sh" workingdir="deployments/gocd/">
                <arg>-c</arg>
                <arg>./dockerLogs.sh</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
    <pipeline name="test_exit_code" isLocked="false">
      <materials>
        <git url="https://github.com/blockapps/strato.git" autoUpdate="false" />
      </materials>
      <stage name="defaultStage">
        <jobs>
          <job name="defaultJob">
            <tasks>
              <exec command="/bin/sh">
                <arg>-c</arg>
                <arg>exit 0</arg>
                <runif status="passed" />
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
  </pipelines>
  <agents>
    <agent hostname="blockapps-cd" ipaddress="10.10.0.6" uuid="12e2bd7f-1bbd-46bd-98da-abba346b8730">
      <resources>
        <resource>local</resource>
      </resources>
    </agent>
    <agent hostname="55f4629ad19d" ipaddress="172.17.0.2" uuid="373fc7b8-69c7-4a79-8564-6939ab9ae4a8">
      <resources>
        <resource>remote</resource>
      </resources>
    </agent>
  </agents>
</cruise>

