
set -e

apt-key adv --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys 575159689BEFB442
echo 'deb http://download.fpcomplete.com/ubuntu xenial main' | tee /etc/apt/sources.list.d/fpco.list

apt-get update

apt-get install -y git emacs postgresql postgresql-server-dev-9.5 libleveldb-dev stack

echo "you need to add ~/.local/bin/ to your path"

export PATH=$PATH:~/.local/bin/

if [ ! -e mgit ]
then
	git clone http://github.com/blockapps/mgit
fi
cd mgit/
stack setup
stack install alex
stack install
cd ..

apt-get install -f emacs

if [ ! -e strato ]
then
	mgit clone http://github.com/blockapps/strato -b develop
fi

cd strato/

stack install
