pipeline {
  agent none
  parameters {string(name: 'SILO_TEST_BUILD_NUMBER', defaultValue: '', description: 'The number of SILO_INT_DEV-build-test build to fetch docker-compose.release.yml from.')}
  stages {
    stage('Prepare to deploy') {
      steps {
        parallel (
          "demo1": {
            node('demo1') {
              step ([$class: 'CopyArtifact', filter: 'docker-compos*.yml', fingerprintArtifacts: true, flatten: true, projectName: 'SILO_INT_DEV-build-test', selector: [$class: 'SpecificBuildSelector', buildNumber: '${SILO_TEST_BUILD_NUMBER}'], target: '/tmp/']);
              withDockerRegistry([credentialsId: 'registry-aws-blockapps', url: 'https://registry-aws.blockapps.net:5000/']) {
                withCredentials([usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'), usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GH_PASSWD', usernameVariable: 'GH_USER')]) {
                  sh '''#!/bin/bash -le
                  set -x
                  docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
                  sudo rm -rf silo strato-getting-started || true
                  git config --global credential.helper store
                  git clone https://$GH_USER:$GH_PASSWD@github.com/blockapps/silo.git
                  git clone https://github.com/blockapps/strato-getting-started
                  cd strato-getting-started
                  mv /tmp/docker-compose.release.yml docker-compose.release.multinode.yml
                  docker-compose -f docker-compose.release.multinode.yml pull
                  '''
                }
              }
            }
          },
          "demo2": {
            node('demo2') {
              step ([$class: 'CopyArtifact', filter: 'docker-compos*.yml', fingerprintArtifacts: true, flatten: true, projectName: 'SILO_INT_DEV-build-test', selector: [$class: 'SpecificBuildSelector', buildNumber: '${SILO_TEST_BUILD_NUMBER}'], target: '/tmp/']);
              withDockerRegistry([credentialsId: 'registry-aws-blockapps', url: 'https://registry-aws.blockapps.net:5000/']) {
                withCredentials([usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'), usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GH_PASSWD', usernameVariable: 'GH_USER')]) {
                  sh '''#!/bin/bash -le
                  set -x
                  docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
                  sudo rm -rf silo strato-getting-started || true
                  git config --global credential.helper store
                  git clone https://$GH_USER:$GH_PASSWD@github.com/blockapps/silo.git
                  git clone https://github.com/blockapps/strato-getting-started
                  cd strato-getting-started
                  mv /tmp/docker-compose.release.yml docker-compose.release.multinode.yml
                  docker-compose -f docker-compose.release.multinode.yml pull
                  '''
                }
              }
            }
          },
          "demo3": {
            node('demo3') {
              step ([$class: 'CopyArtifact', filter: 'docker-compos*.yml', fingerprintArtifacts: true, flatten: true, projectName: 'SILO_INT_DEV-build-test', selector: [$class: 'SpecificBuildSelector', buildNumber: '${SILO_TEST_BUILD_NUMBER}'], target: '/tmp/']);
              withDockerRegistry([credentialsId: 'registry-aws-blockapps', url: 'https://registry-aws.blockapps.net:5000/']) {
                withCredentials([usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'), usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GH_PASSWD', usernameVariable: 'GH_USER')]) {
                  sh '''#!/bin/bash -le
                  set -x
                  docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
                  sudo rm -rf silo strato-getting-started || true
                  git config --global credential.helper store
                  git clone https://$GH_USER:$GH_PASSWD@github.com/blockapps/silo.git
                  git clone https://github.com/blockapps/strato-getting-started
                  cd strato-getting-started
                  mv /tmp/docker-compose.release.yml docker-compose.release.multinode.yml
                  docker-compose -f docker-compose.release.multinode.yml pull
                  '''
                }
              }
            }
          }
        )
      }
    }
    stage('Deploy multinode') {
      steps {
        parallel (
          "demo1": {
            node('demo1') {
              sh '''#!/bin/bash -le
              set -x
              docker rm -f $(docker ps -aq) || true; docker system prune -f --volumes; docker system prune -f
              cd strato-getting-started
              sleep 5
              STRATO_GS_MODE="1" NODE_HOST=sa1.eastus2.cloudapp.azure.com ./strato-multinode-run.sh --stable
              docker ps
              '''
            }
          },
          "demo2": {
            node('demo2') {
              sh '''#!/bin/bash -le
              set -x
              docker rm -f $(docker ps -aq) || true; docker system prune -f --volumes; docker system prune -f
              cd strato-getting-started
              sleep 10
              STRATO_GS_MODE="1" NODE_HOST=sa2.eastus2.cloudapp.azure.com BOOT_NODE_HOST=40.79.67.179 ./strato-multinode-run.sh --stable
              docker ps
              '''
            }
          },
          "demo3": {
            node('demo3') {
              sh '''#!/bin/bash -le
              set -x
              docker rm -f $(docker ps -aq) || true; docker system prune -f --volumes; docker system prune -f
              cd strato-getting-started
              sleep 15
              STRATO_GS_MODE="1" NODE_HOST=sa3.eastus2.cloudapp.azure.com BOOT_NODE_HOST=40.79.67.179 ./strato-multinode-run.sh --stable
              docker ps
              '''
            }
          }
        )
      }
    }
  }
}
