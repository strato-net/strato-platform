{
  "name": "silo-test",
  "version": "0.0.1",
  "description": "platform tests",
  "scripts": {
    "mocha-ts": "mocha -r ts-node/register",
    "test": "npm run mocha-ts e2e/**/*.test.ts",
    "test:long": "npm run mocha-ts to_be_determined",
    "test:e2e__to_be_revised": "npm run mocha-ts e2e__toberevised/**/*.test.ts",
    "test:regressions__to_be_revised": "npm run mocha-ts regressions/**/*.test.ts",
    "test:loadtests__to_be_revised": "npm run test:load && npm run test:load10k && npm run test:upload && npm run test:upload10k && npm run test:loadFF",
    "test:load": "npm run mocha-ts load/stratoLoad.test.ts --batchCount 20 --batchSize 20 && npm run mocha-ts load/stratoLoadFactory.test.ts --batchCount 20 --batchSize 20",
    "test:load10k": "npm run mocha-ts load/stratoLoad.test.ts --batchCount 100 --batchSize 100",
    "test:loadecho": "npm run mocha-ts load/stratoLoadEcho.test.ts --batchCount 20 --batchSize 20 --config config/localhost.config.yaml",
    "test:upload": "npm run mocha-ts load/uploadString.test.ts --batchCount 10 --batchSize 10 && npm run mocha-ts load/uploadUniqueAddresses.test.ts --batchCount 10 --batchSize 10",
    "test:upload10k": "npm run mocha-ts load/uploadString.test.ts --batchCount 100 --batchSize 100",
    "test:loadFF": "npm run mocha-ts load/stratoLoadFiscalFactory.test.ts --batchCount 100 --batchSize 100",
    "test:loadFFEvents": "npm run mocha-ts load/stratoLoadFiscalFactoryEvent.test.ts --batchCount 100 --batchSize 100"
  },
  "dependencies": {
    "@types/mocha": "^8.0.3",
    "@types/node": "^14.14.6",
    "axios": "^0.19.2",
    "bignumber.js": "^9.0.0",
    "blockapps-rest": "file:../blockapps-rest",
    "chai": "^4.0.2",
    "chai-bignumber": "^3.0.0",
    "co": "^4.6.0",
    "co-mocha": "^1.2.0",
    "enum": "^2.5.0",
    "json-to-csv": "^1.0.0",
    "mocha": "^3.4.2",
    "moment": "^2.22.2",
    "request": "^2.88.0",
    "request-promise": "4.2.2",
    "ts-node": "^9.0.0",
    "typescript": "^4.0.5"
  }
}
