pipeline {
  agent {
    label "test"
  }
  stages {
    stage('Prepare') {
      steps {
        wrap([$class: 'BuildUser']) {
          script {
            try {
              currentBuild.description = "Agent ${env.NODE_NAME}// ${BUILD_USER_FIRST_NAME}"
            } catch (Exception e) {
              currentBuild.description = "Agent ${env.NODE_NAME}// github"
            }
          }
        }
        sh '''#!/bin/bash -le
          docker rm -f $(docker ps -aq) || true; docker system prune -f --volumes
        '''
      }
    }

    stage('Build') {
      steps {
        echo 'skipped'
      }
    }

    stage('Deploy') {

      steps {
          sh '''#!/bin/bash -le
            set -x
          '''
      }
    }

    stage('Test and Push Images') {
      steps {
        parallel (
          'Push images': {
            withCredentials([
                usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER')
            ]) {
              archiveArtifacts artifacts: "docker-compose.yml"
              sh '''#!/bin/bash -le
                set -x
                
              '''
            }
          },
            
          'Apex tests': {
            sh '''#!/bin/bash -le
              set -x
             
            '''
          },

          'Strato unit tests': {
            sh '''#!/bin/bash -le
              set -x
              
            '''
          },
/*
          'Track And Trace': {
            withEnv([
                "ADMIN_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJWY0N4SEpnUjFOdnJ4UWR5QXhQcEI5VEowM205SVRDdWt0b1JfTENVSE1VIn0..s-0MRMAEsG532YLM1k6GaXr3RKFUFpB13vR0WuYP8R1je2cP83hvE7Ll-N8hHbyAy8lumfEgSS6NXVIBCRrm0DEqX-XICOIEEkE6d6H-BPXqKZhfFV_HItfVWbWPDRHsCwvTI2ZAR8rgt19Dd8tWNOUVT_demsi20XYj8H2HuMo9vNMT7AN2wl1qRQPHffEppBrtPAx-PSauQpHm51xPgJSJMJPVhaVMWoM1tL91Ef6TOldZS8y89hReRaxeSZJP9kQWtIMLYe41AWcIKzrteOMBhPwa5e8PFfcDFJjvT6N_ASDtPldsxlNGrceMb0JVMwqmbcoetoE5_lMNKzGTkw",
