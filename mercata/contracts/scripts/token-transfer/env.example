# Required: Target user address(es) (without 0x prefix)
# Use either USER_ADDRESS for single user OR USER_ADDRESSES for multiple users
USER_ADDRESS=877903695e9914afc56ca8cad93b544db0d75b4b
# USER_ADDRESSES=877903695e9914afc56ca8cad93b544db0d75b4b,1234567890abcdef1234567890abcdef12345678,abcdef1234567890abcdef1234567890abcdef12

# Optional: Token amounts (in token units, not wei)
# Set only the tokens you want to transfer

# Single amounts (transferred to all users)
USDST=100
bCSPXST=50
SILVST=25
GOLDST=10
WBTCST=0.5
ETHST=2.5

# Array amounts (comma-separated, each amount transferred to all users)
# Uncomment and use these instead of single amounts for multiple transfers per token
# USDST_ARRAY=50,100,200
# bCSPXST_ARRAY=25,50,75
# SILVST_ARRAY=10,25,50
# GOLDST_ARRAY=5,10,20
# WBTCST_ARRAY=0.1,0.25,0.5
# ETHST_ARRAY=1,2.5,5

# Required: Admin credentials (from existing config)
GLOBAL_ADMIN_NAME=your_admin_username
GLOBAL_ADMIN_PASSWORD=your_admin_password

# Required: Node and OAuth configuration
NODE_URL=https://node5.mercata-testnet.blockapps.net
OAUTH_URL=https://keycloak.blockapps.net/auth/realms/mercata/.well-known/openid-configuration
OAUTH_REALM=mercata
OAUTH_CLIENT_ID=localhost
OAUTH_CLIENT_SECRET=your_client_secret_here 