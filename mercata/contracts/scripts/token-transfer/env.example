# Required: Target user addresses (without 0x prefix)
# Comma-separated list for multiple users
USER_ADDRESSES=877903695e9914afc56ca8cad93b544db0d75b4b,1234567890abcdef1234567890abcdef12345678

# Optional: Token amounts (in token units, not wei)
# Set only the tokens you want to transfer
# The same amount will be transferred to each address in USER_ADDRESSES
USDST=100
SILVST=25
GOLDST=10
WBTCST=0.5
ETHST=2.5

# Required: Admin credentials (from existing config)
GLOBAL_ADMIN_NAME=your_admin_username
GLOBAL_ADMIN_PASSWORD=your_admin_password

# Required: Node and OAuth configuration
NODE_URL=https://node5.mercata-testnet.blockapps.net
OAUTH_URL=https://keycloak.blockapps.net/auth/realms/mercata/.well-known/openid-configuration
OAUTH_REALM=mercata
OAUTH_CLIENT_ID=localhost
OAUTH_CLIENT_SECRET=your_client_secret_here 