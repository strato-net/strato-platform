    // ═══════════════════════════════════════════════════════════════════════════════
    // FIXED-POINT HELPERS (RAY MATH)
    // ═══════════════════════════════════════════════════════════════════════════════

    // Exponentiation by squaring for RAY base. Returns (x^n) with base b.
    function rpow(uint x, uint n, uint b) internal pure returns (uint z) {
        z = b;
        if (n == 0) return z;
        uint y = x;
        while (n > 0) {
            if (n % 2 == 1) {
                // z = z * y / b
                z = (z * y) / b;
            }
            n /= 2;
            if (n > 0) {
                // y = y * y / b
                y = (y * y) / b;
            }
        }
        return z;
    }

