# Generic node / auth (used for Cirrus lookups)
NODE_URL=https://node1.testnet.strato.nexus
BA_USERNAME=
BA_PASSWORD=
CLIENT_ID=
CLIENT_SECRET=
OPENID_DISCOVERY_URL=

# Direct bearer token (if omitted, scripts use OAuth credentials above)
ACCESS_TOKEN=

# Required
ALCHEMY_API_KEY=
ROUTER_IMPL_ETH=
ROUTER_IMPL_BASE=

# Safe proposer config
SAFE_PROPOSER_ADDRESS=0x0000000000000000000000000000000000000000
SAFE_PROPOSER_PRIVATE_KEY=YOUR_SAFE_PROPOSER_PRIVATE_KEY
SAFE_API_KEY=

# RPC URLs (defaults are generated from ALCHEMY_API_KEY)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
BASE_RPC_URL=https://mainnet.base.org

# Etherscan/BaseScan (optional verification tooling)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# Legacy compatibility (existing flows/tools still use these)
# Network RPC URLs above are still used by legacy scripts.

# Your deployer wallet private key (without 0x prefix)
PRIVATE_KEY=YOUR_PRIVATE_KEY

# ETHERSCAN_API_KEY above is used by verification flows.

# DepositRouter contract address required for tokenConfig scan
DEPOSIT_ROUTER_ADDRESS=0x0
