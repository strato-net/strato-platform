ALCHEMY_API_KEY=xxxxxxxxxxxxx                         # Alchemy API key for interacting with Ethereum nodes
SAFE_ADDRESS=xxxxxxxxxxxxx                            # Safe (Gnosis) wallet address used for transactions
BRIDGE_ADDRESS=xxxxxxxxxxxxx                          # Bridge contract address (exlude 0x prefix for Safe service test case)
NODE_URL=xxxxxxxxxxxxx                                # STRATO node URL for interacting with Mercata blockchain
ETHEREUM_RPC_URL=xxxxxxxxxxxxx                        # Ethereum RPC endpoint (e.g., Infura or Alchemy)
BA_USERNAME=xxxxxxxxxxxxx                             # BlockApps login username
BA_PASSWORD=xxxxxxxxxxxxx                             # BlockApps login password
SAFE_PROPOSER_PRIVATE_KEY=xxxxxxxxxxxxx               # Private key of Safe wallet owner (used to sign transactions)
SAFE_PROPOSER_ADDRESS=xxxxxxxxxxxxx                   # Public address of Safe wallet owner
SAFE_API_KEY=xxxxxxxxxxxxx                            # Safe Wallet API key

# Login secrets for OpenID authentication
CLIENT_SECRET=xxxxxxxxxxxxx                           # OAuth client secret for login
CLIENT_ID=xxxxxxxxxxxxx                               # OAuth client ID for login
OPENID_DISCOVERY_URL=xxxxxxxxxxxxx                    # OpenID configuration URL for Keycloak or identity provider

TRANSACTION_APPROVER_EMAILS=xxxxxxxxxxxxxxxxxx        # Comma-separated list of email addresses to notify for transaction approvals
SHOW_TESTNET=xxxxxxxxxx                               # Boolean flag to enable testnet environment for bridgeIn and bridgeOut flow
SENDGRID_API_KEY=xxxxxxxxxxxxx                        # SendGrid API key for sending transaction email notifications

# Across Protocol
ACROSS_SIGNER_PRIVATE_KEY=xxxxxxxxxxxxx               # Private key for signing Across depositV3 transactions on external chains (also used as relayer EOA for vault operations)

# Vault addresses (ExternalBridgeVault per chain, replaces Safe-as-custody)
CHAIN_11155111_VAULT_ADDRESS=xxxxxxxxxxxxx             # ExternalBridgeVault on Sepolia
CHAIN_84532_VAULT_ADDRESS=xxxxxxxxxxxxx                # ExternalBridgeVault on Base Sepolia
# CHAIN_${chainId}_VAULT_ADDRESS=<vault-address>       # Additional chains

# StratoRepresentationBridge addresses (per chain, for STRATO-native asset bridging)
CHAIN_11155111_REP_BRIDGE_ADDRESS=xxxxxxxxxxxxx        # StratoRepresentationBridge on Sepolia
CHAIN_84532_REP_BRIDGE_ADDRESS=xxxxxxxxxxxxx           # StratoRepresentationBridge on Base Sepolia
# CHAIN_${chainId}_REP_BRIDGE_ADDRESS=<bridge-address> # Additional chains

# STRATO-side custody vault
STRATO_CUSTODY_VAULT_ADDRESS=xxxxxxxxxxxxx             # StratoCustodyVault on STRATO

# Rebalancing (disabled by default; enable after monitoring period)
REBALANCING_ENABLED=false
REBALANCING_CHECK_INTERVAL=300000                      # 5 minutes
REBALANCING_MIN_THRESHOLD=500000000000000000000        # $500 equivalent in 18-decimal wei
REBALANCING_RESERVE_PCT=10                             # Minimum reserve % per vault
# REBALANCING_MAX_PER_TRANSFER=0                       # 0 = unlimited

# Circuit breaker (disabled by default)
CIRCUIT_BREAKER_ENABLED=false
# CB_ANOMALY_THRESHOLD=0                               # Volume threshold (0 = disabled)
# CB_WINDOW_DURATION_MS=3600000                        # 1 hour rolling window
# CB_COOLDOWN_MS=1800000                               # 30 min cooldown after trip

# Reconciliation
# RECONCILIATION_INTERVAL=300000                       # 5 minutes
# RECONCILIATION_DISCREPANCY_PCT=1                     # Alert if >1% drift
# RECONCILIATION_ABS_FLOOR=1000000000000000000         # 1 token minimum

# RPC config
# Chain RPC URLs (Dynamically Validated)
# The service automatically validates that RPC URLs are configured for all enabled chains from the bridge contract:
CHAIN_11155111_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}   # Sepolia
CHAIN_1_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}          # Ethereum mainnet
CHAIN_8453_RPC_URL=https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}    # Base mainnet
CHAIN_84532_RPC_URL=https://base-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}    # Base Sepolia
CHAIN_59144_RPC_URL=https://linea-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}  # Linea mainnet
CHAIN_59141_RPC_URL=https://linea-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}  # Linea Sepolia
# CHAIN_${chainId}_RPC_URL=<rpc-url-for-other-enabled-chain>                     # Any additional enabled chains
