ALCHEMY_API_KEY=xxxxxxxxxxxxx                         # Alchemy API key for interacting with Ethereum nodes
SAFE_ADDRESS=xxxxxxxxxxxxx                            # Safe (Gnosis) wallet address used for transactions
BRIDGE_ADDRESS=xxxxxxxxxxxxx                          # Bridge contract address (exlude 0x prefix for Safe service test case)
NODE_URL=xxxxxxxxxxxxx                                # STRATO node URL for interacting with Mercata blockchain
ETHEREUM_RPC_URL=xxxxxxxxxxxxx                        # Ethereum RPC endpoint (e.g., Infura or Alchemy)
BA_USERNAME=xxxxxxxxxxxxx                             # BlockApps login username
BA_PASSWORD=xxxxxxxxxxxxx                             # BlockApps login password
SAFE_OWNER_PRIVATE_KEY=xxxxxxxxxxxxx                  # Private key of Safe wallet owner (used to sign transactions)
SAFE_OWNER_ADDRESS=xxxxxxxxxxxxx                      # Public address of Safe wallet owner

# Login secrets for OpenID authentication
CLIENT_SECRET=xxxxxxxxxxxxx                           # OAuth client secret for login
CLIENT_ID=xxxxxxxxxxxxx                               # OAuth client ID for login
OPENID_DISCOVERY_URL=xxxxxxxxxxxxx                    # OpenID configuration URL for Keycloak or identity provider

TRANSACTION_APPROVER_EMAILS=xxxxxxxxxxxxxxxxxx        # Comma-separated list of email addresses to notify for transaction approvals
SHOW_TESTNET=xxxxxxxxxx                               # Boolean flag to enable testnet environment for bridgeIn and bridgeOut flow
SENDGRID_API_KEY=xxxxxxxxxxxxx                        # SendGrid API key for sending transaction email notifications

# RPC config
# Chain RPC URLs (Dynamically Validated)
# The service automatically validates that RPC URLs are configured for all enabled chains from the bridge contract:
CHAIN_11155111_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}   # Sepolia
CHAIN_1_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}          # Ethereum mainnet
# CHAIN_${chainId}_RPC_URL=<rpc-url-for-other-enabled-chain>                     # Any additional enabled chains
