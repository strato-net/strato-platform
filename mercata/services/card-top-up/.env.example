# Mercata backend base URL (for watcher-config and execute-top-up)
MERCATA_API_URL=http://localhost:3001

# Operator token; must match backend OPERATOR_ACCESS_TOKEN (Bearer auth for operator routes)
OPERATOR_ACCESS_TOKEN=

# JSON map: chainId -> RPC URL for balance checks (e.g. {"84532":"https://sepolia.base.org"})
EXTERNAL_CHAIN_RPC_URLS={}

# Poll interval in milliseconds (default 300000 = 5 min)
POLL_INTERVAL_MS=300000

# Health check server port
PORT=3004
