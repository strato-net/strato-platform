# STRATO Blockchain Configuration
STRATO_NODE_URL=https://node1.mercata-testnet.blockapps.net/
PRICE_ORACLE_ADDRESS=0000000000000000000000000000000000001002

# OAuth Configuration
OAUTH_DISCOVERY_URL=https://keycloak.blockapps.net/auth/realms/mercata/.well-known/openid-configuration
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
USERNAME=your_strato_username
PASSWORD=your_strato_password

# API Keys
ALCHEMY_API_KEY=your_alchemy_api_key_here
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here
METALS_DEV_API_KEY=your_metals_dev_api_key_here
METALS_API_API_KEY=your_metals_api_api_key_here

# Health Check Configuration
HEALTH_PORT=3000

# Oracle Update Configuration
# CRON_SCHEDULE: Cron minute pattern (e.g., '0 */15 * * * *' for :00, :15, :30, :45 or '30 7,22,37,52 * * * *' for :07:30, :22:30, :37:30, :52:30)
CRON_SCHEDULE="0 */15 * * * *"

# Token Configuration
USDST_ADDRESS=937efa7e3a77e20bbdbd7c0d32b6514f368c1010  # USDST contract address
VOUCHER_ADDRESS=000000000000000000000000000000000000100e  # Voucher contract address
GAS_FEE_USDST=1  # Gas fee in USDST (0.01 = 1, default: 1) 
GAS_FEE_VOUCHER=100  # Gas fee in Vouchers (1 = 100, default: 100)

# AWS Configuration (for CloudWatch Metrics)
# Leave CLOUDWATCH_NAMESPACE empty to disable metrics
AWS_REGION=us-east-1
CLOUDWATCH_NAMESPACE=Testnet/Oracle/Transactions
