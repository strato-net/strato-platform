{
  "name": "price-oracle-service",
  "version": "1.0.0",
  "description": "Generic price oracle service with configurable feeds and sources",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && source .env && node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "validate": "npm run build && node dist/utils/validateConfig.js"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/node-cron": "^3.0.0",
    "@types/axios": "^1.6.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.0.1"
  },
  "keywords": ["oracle", "price-feeds", "blockchain", "defi"],
  "author": "Mercata",
  "license": "MIT"
} 