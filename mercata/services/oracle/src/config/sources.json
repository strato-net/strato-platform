{
  "Alchemy": {
    "url": "https://api.g.alchemy.com/prices/v1/${API_KEY}/tokens/by-symbol",
    "params": "symbols[]",
    "parse": "data[].prices[0].value",
    "timestamp": "data[0].prices[0].lastUpdatedAt",
    "apiKeyEnvVar": "ALCHEMY_API_KEY",
    "assets": ["ETH", "WBTC", "PAXG", "XAUT", "SUSDS", "KAG", "WSTETH", "SYRUPUSDC"]
  },
  "CoinMarketCap": {
    "url": "https://pro-api.coinmarketcap.com/v2/cryptocurrency/quotes/latest",
    "params": "symbol,convert=USD",
    "headers": "X-CMC_PRO_API_KEY",
    "parse": "data.{symbol}[0].quote.USD.price",
    "timestamp": "data.{firstSymbol}[0].quote.USD.last_updated",
    "apiKeyEnvVar": "COINMARKETCAP_API_KEY",
    "assets": ["ETH", "WBTC", "PAXG", "XAUT", "WSTETH", "SYRUPUSDC"]
  },
  "Metals.dev": {
    "url": "https://api.metals.dev/v1/latest",
    "params": "api_key,currency=USD,unit=toz,metals",
    "parse": "metals.{metal}",
    "timestamp": "timestamps.metal",
    "apiKeyEnvVar": "METALS_DEV_API_KEY",
    "assets": ["XAU", "XAG"],
    "symbolMapping": {
      "XAU": "gold",
      "XAG": "silver"
    }
  },
  "MetalsAPI": {
    "url": "https://metals-api.com/api/latest",
    "params": "access_key,base=USD,symbols",
    "parse": "rates.USD{symbol}",
    "timestamp": "timestamp",
    "apiKeyEnvVar": "METALS_API_API_KEY",
    "assets": ["XAU", "XAG"]
  },
  "CoinGecko": {
    "url": "https://pro-api.coingecko.com/api/v3/simple/price",
    "params": "x_cg_pro_api_key,ids,vs_currencies=usd,include_last_updated_at=true",
    "parse": "{id}.usd",
    "timestamp": "{id}.last_updated_at",
    "apiKeyEnvVar": "COINGECKO_API_KEY",
    "assets": ["ETH", "WBTC", "PAXG", "XAUT", "SUSDS", "KAG", "WSTETH", "SYRUPUSDC"],
    "symbolMapping": {
      "ETH": "ethereum",
      "WBTC": "wrapped-bitcoin",
      "PAXG": "pax-gold",
      "XAUT": "tether-gold",
      "SUSDS": "susds",
      "KAG": "kinesis-silver",
      "WSTETH": "wrapped-steth",
      "SYRUPUSDC": "syrupusdc"
    }
  },
  "CoinAPI": {
    "url": "https://rest.coinapi.io/v1/assets",
    "params": "filter_asset_id",
    "headers": "X-CoinAPI-Key",
    "parse": "assets",
    "timestamp": "data_quote_start",
    "apiKeyEnvVar": "COINAPI_API_KEY",
    "assets": ["ETH", "WBTC", "PAXG", "XAUT"]
  },
  "DefiLlama": {
    "url": "https://coins.llama.fi/prices/current/${SYMBOLS}",
    "parse": "defiLlama",
    "assets": ["ETH", "WBTC", "PAXG", "XAUT", "SUSDS", "KAG", "WSTETH", "SYRUPUSDC"],
    "symbolMapping": {
      "ETH": "coingecko:ethereum",
      "WBTC": "coingecko:wrapped-bitcoin",
      "PAXG": "coingecko:pax-gold",
      "XAUT": "coingecko:tether-gold",
      "SUSDS": "coingecko:susds",
      "KAG": "coingecko:kinesis-silver",
      "WSTETH": "coingecko:wrapped-steth",
      "SYRUPUSDC": "coingecko:syrupusdc"
    }
  },
  "Commodities-API": {
    "url": "https://commodities-api.com/api/latest",
    "params": "access_key,base=USD,symbols",
    "parse": "data.rates.{symbol}",
    "timestamp": "data.timestamp",
    "apiKeyEnvVar": "COMMODITIES_API_KEY",
    "assets": ["XAU", "XAG"]
  },
  "CommodityPriceAPI": {
    "url": "https://api.commoditypriceapi.com/v2/rates/latest",
    "params": "symbols",
    "headers": "x-api-key",
    "parse": "rates.{symbol}",
    "timestamp": "timestamp",
    "apiKeyEnvVar": "COMMODITY_PRICE_API_KEY",
    "assets": ["XAU", "XAG"]
  },
  "TwelveData": {
    "url": "https://api.twelvedata.com/price",
    "params": "apikey,symbol",
    "parse": "{symbol}.price",
    "apiKeyEnvVar": "TWELVEDATA_API_KEY",
    "comment": "Also supports crypto: ETH/USD, BTC/USD, WBTC/USD, PAXG/USD, XAUT/USD. XAG requires Grow plan ($29/mo)",
    "assets": ["XAU", "XAG"],
    "symbolMapping": {
      "XAU": "XAU/USD",
      "XAG": "XAG/USD"
    }
  },
  "OANDA": {
    "url": "https://api-fxpractice.oanda.com/v3/accounts/${ACCOUNT_ID}/pricing",
    "params": "instruments",
    "headers": "Authorization",
    "parse": "oanda.prices",
    "apiKeyEnvVar": "OANDA_API_KEY",
    "accountIdEnvVar": "OANDA_ACCOUNT_ID",
    "comment": "Practice API. Use api-fxtrade.oanda.com for live",
    "assets": ["XAU", "XAG"],
    "symbolMapping": {
      "XAU": "XAU_USD",
      "XAG": "XAG_USD"
    }
  },
  "constant": {
    "parse": "constant",
    "assets": ["USDST"]
  }
}
