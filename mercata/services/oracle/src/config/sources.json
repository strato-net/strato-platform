{
  "Alchemy": {
    "urlTemplate": "https://api.g.alchemy.com/prices/v1/${API_KEY}/tokens/by-address",
    "apiKeyEnvVar": "ALCHEMY_API_KEY",
    "apiKeyType": "bearer",
    "method": "POST",
    "requestBody": {
      "addresses": [
        {
          "network": "eth-mainnet",
          "address": "${tokenAddress}"
        }
      ]
    },
    "parsePath": "data[0].prices[0].value",
    "feedTimestampPath": "data[0].prices[0].lastUpdatedAt"
  },
  "Metals.dev": {
    "urlTemplate": "https://api.metals.dev/v1/latest?api_key=${API_KEY}&currency=USD&unit=toz",
    "apiKeyEnvVar": "METALS_API_KEY",
    "apiKeyType": "url",
    "parsePath": "metals.${metal}",
    "feedTimestampPath": "timestamps.metal"
  },
  "MetalPriceAPI": {
    "urlTemplate": "https://api.metalpriceapi.com/v1/latest?api_key=${API_KEY}&base=USD&currencies=EUR,XAU,XAG",
    "apiKeyEnvVar": "METALPRICE_API_KEY",
    "apiKeyType": "url",
    "parsePath": "rates.${symbol}",
    "feedTimestampPath": "timestamp"
  },
  "CoinMarketCap": {
    "urlTemplate": "https://pro-api.coinmarketcap.com/v2/cryptocurrency/quotes/latest?address=${tokenAddress}&convert=USD",
    "apiKeyEnvVar": "COINMARKETCAP_API_KEY",
    "apiKeyType": "header",
    "headers": {
      "X-CMC_PRO_API_KEY": "${API_KEY}"
    },
    "parsePath": "data.${tokenAddress}.quote.USD.price",
    "feedTimestampPath": "data.${tokenAddress}.quote.USD.last_updated"
  }
} 