# Liquidation Bot Configuration

# Service Configuration
PORT=3006
NODE_ENV=development

# Blockchain Configuration
STRATO_URL=http://localhost:3000
OAUTH_URL=http://localhost:3001

# Bot Account Credentials (OAuth)
BOT_ADDRESS=
BOT_PRIVATE_KEY=
BOT_OAUTH_TOKEN=

# Polling Configuration
POLL_INTERVAL_MS=30000
MAX_LIQUIDATIONS_PER_BATCH=10

# CDP Configuration
CDP_ENGINE_ADDRESS=
CDP_REGISTRY_ADDRESS=

# Lending Configuration
LENDING_POOL_ADDRESS=
LENDING_REGISTRY_ADDRESS=

# Liquidation Strategy
MIN_PROFIT_THRESHOLD_USD=10
MAX_GAS_PRICE_GWEI=100
ENABLE_CDP_LIQUIDATIONS=true
ENABLE_LENDING_LIQUIDATIONS=true

# Managed Vault Configuration
VAULT_ENABLED=true
MIN_INVESTMENT_USD=100
VAULT_FEE_BPS=500

# Logging
LOG_LEVEL=info
