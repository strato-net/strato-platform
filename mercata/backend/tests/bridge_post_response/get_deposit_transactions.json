const schemas = pm.require('@blockapps/mercata-schema');

const json = pm.response.json();

pm.test("Valid response format", function () {
    pm.expect(json).to.be.an('object');
    pm.expect(json).to.have.property("data");
    pm.expect(json).to.have.property("totalCount");
})

pm.test("AI Likes the Schema", function () {
    const schema = schemas.bridgeDepositTransactions;
    pm.expect(json).to.have.jsonSchema(schema);
});
