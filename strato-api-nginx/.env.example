# OAuth Configuration
OAUTH_CLIENT_ID=your-client-id-here
OAUTH_CLIENT_SECRET=your-client-secret-here
OAUTH_DISCOVERY_URL=https://your-keycloak-domain/auth/realms/your-realm/.well-known/openid-configuration

# Strato API Configuration
IDENTITY_SERVER_URL=https://your-identity-server/strato/v2.3
VAULT_URL=http://vault:8093

# Node URL (for reference)
NODE_URL=https://your-node-url-here
