    function createBid(string name, string supplier, uint amount) public returns (ErrorCodes, uint) {
        if (!exists(name))
      return (ErrorCodes.NOT_FOUND, 0);
    bidId++;
    Bid bid = new Bid(bidId, name, supplier, amount);
    return (ErrorCodes.SUCCESS, bidId);
  
    }
    function createProject(string name, string buyer, string description, string spec, uint price, uint created, uint targetDelivery) public returns (ErrorCodes) {
        if (bytes(name).length > 32)
      return ErrorCodes.ERROR;
    if (exists(name))
      return ErrorCodes.EXISTS;
    uint index = projects.length;
    nameToIndexMap[b32(name)] = index;
    projects.push(new Project(
      name,
      buyer,
      description,
      spec,
      price,
      created,
      targetDelivery
    ));
    return ErrorCodes.SUCCESS;
  
    }
    function exists(string name) public returns (bool) {
        return nameToIndexMap[b32(name)] != 0;
  
    }
    function fsm(ProjectState state, ProjectEvent projectEvent) public returns (ErrorCodes, ProjectState) {
        if (state == ProjectState.NULL)
      return (ErrorCodes.ERROR, state);
    if (state == ProjectState.OPEN) {if (projectEvent == ProjectEvent.ACCEPT)
        return (ErrorCodes.SUCCESS, ProjectState.PRODUCTION);
    }if (state == ProjectState.PRODUCTION) {if (projectEvent == ProjectEvent.DELIVER)
        return (ErrorCodes.SUCCESS, ProjectState.INTRANSIT);
    }if (state == ProjectState.INTRANSIT) {if (projectEvent == ProjectEvent.RECEIVE)
        return (ErrorCodes.SUCCESS, ProjectState.RECEIVED);
    }return (ErrorCodes.ERROR, state);
  
    }
    function getProject(string name) public returns (address) {
        uint index = nameToIndexMap[b32(name)];
    return projects[index];
  
    }
    function handleEvent(address projectAddress, ProjectEvent projectEvent) public returns (ErrorCodes, ProjectState) {
        Project project = Project(projectAddress);
    ProjectState state = project.getState();
    var (errorCode, newState) = fsm(state, projectEvent);
    if (errorCode != ErrorCodes.SUCCESS) {return (errorCode, state);
    }project.setState(newState);
    return (ErrorCodes.SUCCESS, newState);
  
    }
    function settleProject(string name, address supplierAddress, address bidAddress) public returns (ErrorCodes) {
        if (!exists(name))
      return (ErrorCodes.NOT_FOUND);
    address projectAddress = getProject(name);
    var (errorCode, state) = handleEvent(projectAddress, ProjectEvent.RECEIVE);
    if (errorCode != ErrorCodes.SUCCESS)
      return errorCode;
    Bid bid = Bid(bidAddress);
    return bid.settle(supplierAddress);
  
    }
