ifeq ($(BASIL_DOCKER_TAG),)
  $(error BASIL_DOCKER_TAG is not set)
endif

all: build

build:
	docker build -f Dockerfile.buildbase -t blockapps-docs-buildbase .
	rm -rf dist_built
	docker rm -f extract
	docker create --name extract blockapps-docs-buildbase
	docker cp extract:/dist_built/ dist_built
	docker rm -f extract
	docker build -t $(BASIL_DOCKER_TAG) .
