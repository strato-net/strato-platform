                sh 'pwd'
                sh 'cd $WORKSPACE/devops/eks/strato'
                sh 'ls -l'
                //sh '$KUBECTL delete -f strato-platform-manifest.yaml'
                //sh '$KUBECTL apply -f strato-platform-manifest.yaml'
            }
