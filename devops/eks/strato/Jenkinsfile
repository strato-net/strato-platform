        KUBECTL='home/ubuntu/bin/kubectl'
        AWS_CONFIG="AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID} AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY} AWS_DEFAULT_REGION=us-east-1"
    }
    stages {
        stage('Stage 1') {
            steps {
                sh '$AWS_CONFIG aws eks update-kubeconfig --name ba-dev3 --region us-east-1'
