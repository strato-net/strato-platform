pipeline {
    agent { label "test3" }
    environment {
        AWS_ACCESS_KEY_ID     = credentials('BLOCKAPPS_SERVICE_USER_AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('BLOCKAPPS_SERVICE_USER_AWS_SECRET_ACCESS_KEY')
    }
    stages {
        stage('Stage 1') {
            steps {
                sh 'AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY aws eks update-kubeconfig --name ba-dev3 --region us-east-1'
                sh 'AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY AWS_DEFAULT_REGION="us-east-1" /home/ubuntu/bin/kubectl get pods -n strato-platform'
            }
        }
    }
}
