{{/* vim: set ft=html: */}}

{{/* Navbar, should be passed . */}}
{{ define "navbar" }}
<nav class="navbar navbar-inverse navbar-static-top">
  <div class="container-fluid">
    <!-- Brand and toggle get grouped for better mobile display -->
    <div class="navbar-header">
      <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#bs-example-navbar-collapse-1">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <a class="navbar-brand" href="{{ pathPrefix }}/">Prometheus</a>
    </div>

    <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
      <ul class="nav navbar-nav">
        <li><a href="{{ pathPrefix }}/alerts">Alerts</a></li>
        <li><a href="https://www.pagerduty.com/">PagerDuty</a></li>
      </div>
    </ul>
  </div>
</nav>
{{ end }}

{{/* LHS menu, should be passed . */}}
{{ define "menu" }}
<div class="prom_lhs_menu">
<ul>
{{ template "_menuItem" (args . "index.html.example" "Overview") }}

{{ template "_menuItem" (args . "p2p-overview.html" "P2P") }}
{{ if match "^p2p" .Path }}
  {{ if .Params.instance }}
  <ul>
    <li {{ if eq .Path "p2p-overview.html" }}class="prom_lhs_menu_selected"{{ end }}>
      <a href="p2p-overview.html?instance={{ .Params.instance }}">{{ reReplaceAll "(.*?://)([^:/]+?)(:\\d+)?/.*" "$2" .Params.instance }}</a>
    </li>
  </ul>
  {{ end }}
{{ end }}

{{ template "_menuItem" (args . "evm-overview.html" "Ethereum-VM") }}
{{ if match "^prometheus" .Path }}
  {{ if .Params.instance }}
  <ul>
    <li {{ if eq .Path "evm-overview.html" }}class="prom_lhs_menu_selected"{{ end }}>
      <a href="evm-overview.html?instance={{ .Params.instance }}">{{.Params.instance }}</a>
    </li>
  </ul>
  {{ end }}
{{ end }}

{{ template "_menuItem" (args . "pbft-overview.html" "PBFT") }}
{{ if match "^pbft" .Path }}
  {{ if .Params.instance }}
  <ul>
    <li {{ if eq .Path "pbft-overview.html" }}class="prom_lhs_menu_selected"{{ end }}>
      <a href="pbft-overview.html?instance={{ .Params.instance }}">{{.Params.instance }}</a>
    </li>
  </ul>
  {{ end }}
{{ end }}

{{ template "_menuItem" (args . "seq-overview.html" "Sequencer") }}
{{ if match "^seq" .Path }}
  {{ if .Params.instance }}
  <ul>
    <li {{ if eq .Path "seq-overview.html" }}class="prom_lhs_menu_selected"{{ end }}>
      <a href="seq-overview.html?instance={{ .Params.instance }}">{{.Params.instance }}</a>
    </li>
  </ul>
  {{ end }}
{{ end }}

</ul>
</div>
{{ end }}

{{/* Helper, pass (args . path name) */}}
{{ define "_menuItem" }}
  <li {{ if eq .arg0.Path .arg1 }} class="prom_lhs_menu_selected" {{ end }}><a href="{{ .arg1 }}">{{ .arg2 }}</a></li>
{{ end }}

