{
  "name": "smd-ui",
  "version": "0.4.2",
  "private": true,
  "homepage": "/dashboard/",
  "dependencies": {
    "@blueprintjs/core": "^1.22.0",
    "@blueprintjs/table": "^1.19.0",
    "bignumber.js": "4.0.2",
    "bootstrap": "3.3.7",
    "mixpanel-browser": "2.11.1",
    "moment": "2.18.1",
    "plottable": "3.1.1",
    "react": "15.5.4",
    "react-addons-css-transition-group": "15.5.2",
    "react-copy-to-clipboard": "^5.0.1",
    "react-dom": "15.5.4",
    "react-dropzone": "^3.13.3",
    "react-joyride": "^1.10.1",
    "react-loading": "^1.0.1",
    "react-monaco-editor": "0.11.0",
    "react-redux": "5.0.5",
    "react-redux-loading-bar": "^2.9.3",
    "react-router-dom": "4.1.1",
    "react-router-redux": "4.0.8",
    "redux": "3.6.0",
    "redux-form": "6.8.0",
    "redux-saga": "0.15.3",
    "reselect": "^3.0.1",
    "socket.io-client": "^2.0.4"
  },
  "devDependencies": {
    "node-sass": "4.5.3",
    "npm-run-all": "4.0.2",
    "react-scripts": "1.0.5"
  },
  "scripts": {
    "build-css": "node-sass src/ -o src/",
    "watch-css": "npm run build-css && node-sass src/ -o src/ --watch --recursive",
    "start-js": "react-scripts start",
    "start": "REACT_APP_VERSION=$npm_package_version npm-run-all -p watch-css start-js",
    "build": "npm run build-css && REACT_APP_VERSION=$npm_package_version react-scripts build",
    "test": "echo 'No tests to run'",
    "eject": "react-scripts eject"
  }
}
