{
	"name": "strato-vscode",
	"publisher": "BlockApps",
	"displayName": "STRATO IDE",
	"description": "VSCode Integration for BlockApps STRATO",
	"icon": "resources/rebrand-logo.png",
	"version": "0.3.0",
	"repository": "https://github.com/blockapps/strato-platform/strato-vscode-images",
	"engines": {
		"vscode": "^1.53.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onDebugDynamicConfigurations:strato",
		"onLanguage:solidity",
		"onView:contracts",
		"onView:nodes",
		"onView:cirrus",
		"onCommand:extension.strato-debug.debugEditorContents"
	],
	"main": "./out/extension.js",
	"contributes": {
		"breakpoints": [
			{
				"language": "solidity"
			}
		],
		"configuration": {
			"title": "STRATO IDE",
			"properties": {
				"strato-vscode.autoFuzz": {
					"type": "boolean",
					"default": true
				},
				"strato-vscode.configPath": {
					"type": "string",
					"default": "",
					"description": "The default configuration file containing STRATO node(s) information"
				}
			}
		},
		"configurationDefaults": {
			"[solidity]": {
				"editor.wordWrap": "off"
			}
		},
		"commands": [
			{
				"command": "contracts.refreshEntry",
				"title": "Refresh",
				"icon": "$(refresh)"
			},
			{
				"command": "contracts.uploadContract",
				"title": "Upload Contract",
				"icon": "$(add)"
			},
			{
				"command": "contracts.callFunction",
				"title": "Call Function",
				"icon": "$(play)"
			},
			{
				"command": "contracts.searchContract",
				"title": "Search",
				"icon": "$(search)"
			},
			{
				"command": "cirrus.queryCirrus",
				"title": "Search",
				"icon": "$(search)"
			},
			{
				"command": "nodes.addConfig",
				"title": "Select Configuration File",
				"icon": "$(new-file)"
			},
			{
				"command": "nodes.settings",
				"title": "Open Settings",
				"icon": "$(settings-gear)"
			},
			{
				"command": "extension.strato-debug.debugEditorContents",
				"title": "Debug SolidVM",
				"category": "Debug SolidVM",
				"enablement": "!inDebugMode",
				"icon": "$(debug-alt)"
			},
			{
				"command": "extension.copyToClipboard",
				"title": "Copy to Clipboard",
				"icon": "$(clippy)"
			},
			{
				"command": "extension.oauthLogin",
				"title": "Login",
				"icon": "$(log-in)"
			}
		],
		"debuggers": [
			{
				"type": "strato",
				"label": "Debug SolidVM",
				"program": "./out/debugAdapter.js",
				"runtime": "node",
				"configurationAttributes": {
					"launch": {
						"properties": {
							"trace": {
								"type": "boolean",
								"description": "Enable logging of the Debug Adapter Protocol.",
								"default": true
							}
						}
					}
				},
				"initialConfigurations": [
					{
						"type": "strato",
						"request": "launch",
						"name": "Debug SolidVM"
					}
				],
				"configurationSnippets": [
					{
						"label": "Debug SolidVM",
						"description": "A new configuration for debugging SolidVM smart contracts.",
						"body": {
							"type": "strato",
							"request": "launch",
							"name": "Debug SolidVM"
						}
					}
				]
			}
		],
		"grammars": [
			{
				"language": "solidity",
				"scopeName": "source.solidity",
				"path": "./syntaxes/solidity.json"
			}
		],
		"languages": [
			{
				"id": "solidity",
				"extensions": [
					".sol"
				],
				"aliases": [
					"Solidity",
					"sol"
				],
				"configuration": "./solidity-configuration.json"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "extension.strato-debug.debugEditorContents",
					"when": "resourceLangId == solidity",
					"group": "1_run@20"
				}
			],
			"commandPalette": [
				{
					"command": "extension.strato-debug.debugEditorContents",
					"when": "resourceLangId == solidity"
				}
			],
			"view/title": [
				{
					"command": "contracts.refreshEntry",
					"when": "view == contracts",
					"group": "navigation"
				},
				{
					"command": "contracts.searchContract",
					"when": "view == contracts",
					"group": "navigation"
				},
				{
					"command": "cirrus.queryCirrus",
					"when": "view == cirrus",
					"group": "navigation"
				},
				{
					"command": "nodes.addConfig",
					"when": "view == nodes && config.strato-vscode.configPath",
					"group": "navigation@0"
				},
				{
					"command": "nodes.settings",
					"when": "view == nodes",
					"group": "navigation@1"
				},
				{
					"command": "extension.oauthLogin",
					"when": "view == contracts",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "contracts.uploadContract",
					"when": "view == contracts && viewItem == node",
					"group": "inline"
				},
				{
					"command": "contracts.callFunction",
					"when": "view == contracts && viewItem == function",
					"group": "inline"
				},
				{
					"command": "extension.copyToClipboard",
					"when": "view == contracts && (viewItem == address || viewItem == stateItem)",
					"group": "inline"
				},
				{
					"command": "extension.copyToClipboard",
					"when": "view == nodes || view == cirrus",
					"group": "inline"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "strato-project",
					"title": "STRATO IDE",
					"icon": "resources/rebrand-logo.png"
				}
			]
		},
		"views": {
			"strato-project": [
				{
					"id": "nodes",
					"name": "Nodes"
				},
				{
					"id": "cirrus",
					"name": "Cirrus"
				},
				{
					"id": "contracts",
					"name": "Contracts"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "nodes",
				"contents": "To start using the STRATO IDE, import a valid BlockApps REST configuration file.\n[Import Configuration File](command:nodes.addConfig)\nTo learn more about how to configure the STRATO IDE, visit the [the docs](https://docs.blockapps.net/blockapps-rest/).",
				"when": "!config.strato-vscode.configPath"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "yarn run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "yarn run compile && yarn run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"dependencies": {
		"await-notify": "1.0.1",
		"axios": "^1.4.0",
		"blockapps-rest": "../blockapps-rest",
		"js-yaml": "^4.0.0",
		"qs": "^6.11.2",
		"vscode-debugadapter": "^1.43.0",
		"ws": "^7.4.2"
	},
	"devDependencies": {
		"@types/chai": "^4.2.15",
		"@types/glob": "^7.1.3",
		"@types/js-yaml": "^4.0.0",
		"@types/mocha": "^8.0.4",
		"@types/node": "^12.20.6",
		"@types/node-fetch": "^2.5.8",
		"@types/vscode": "^1.53.0",
		"@types/ws": "^7.4.0",
		"@typescript-eslint/eslint-plugin": "^4.14.1",
		"@typescript-eslint/parser": "^4.14.1",
		"eslint": "^7.19.0",
		"glob": "^7.1.6",
		"mocha": "^8.2.1",
		"typescript": "^4.1.3",
		"vscode-test": "^1.5.0"
	}
}
