#!/bin/bash

registry="auth.blockapps.net:5000/blockapps"

function buildWithDocker { :; }

function buildLocally
{
  cd $pkgdir
  ./BUILD
}

function deployWithDocker
{
  deploybase="$registry/$submoddir-base"
  docker tag $deploybase deploybase
  docker build -t $submoddir $pkgdir
}

function deployLocally
{
  cd $pkgdir
  ./setup-deployment
  sudo cp -a $builddir/* /
}

set -e
exec 2> >(while read line; do echo -e "\e[01;31m$line\e[0m" >&2; done)

if [[ $# -eq 0 ]]
then
  echo >&2 "Must pass a mode."
  exit 1
fi

build="buildWithDocker"
deploy="deployWithDocker"
case $1 in
  "local"|"local-to-docker")
    build="buildLocally"
    ;;&
  "local"|"docker-to-local")
    deploy="deployLocally"
    ;;&
  "docker"|"docker-to-local")
    echo >&2 "'docker' build mode not supported currently"
    exit 1
    ;;&
  "local"|"docker"|"local-to-docker"|"docker-to-local")
    ;;
  *)
    echo >&2 "Mode must be: local, docker, local-to-docker, docker-to-local"
    exit 1
    ;;
esac

for i in $(<mgitmods)
do
  export submoddir=`basename $i`
  export pkgdir=$submoddir/pkg
  export builddir=$pkgdir/build
  if [[ -x $submoddir/BUILD ]]
  then
    echo "############### Building: $submoddir"
    ($build)
    echo "############### Deploying: $submoddir"
    ($deploy)
    echo
  fi
done

