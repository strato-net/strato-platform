
set -e

builddir=`mktemp -d /tmp/build.XXXX`

for i in `cat mgitmods`
do
	submoddir=`basename $i`
	packagedir=$builddir/$submoddir
	mkdir $packagedir
	if [ -e $submoddir/BUILD ]
	then
		echo "############### Building: $submoddir"
		cd $submoddir
		PKGDIR=$packagedir BINDIR=~/.local/bin ./BUILD
		cd ..
	fi
done

