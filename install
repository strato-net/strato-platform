#!/bin/bash

set -e
exec 2> >(while read line; do echo -e "\e[01;31m$line\e[0m" >&2; done)

export registry="auth.blockapps.net:5000/blockapps"

function buildWithDocker { :; }

function buildLocally
{
  cd $submod
  $pkgdir/BUILD
}

function deployWithDocker
{
  deploybase="$registry/$submod-base"
  if [[ -z $(docker images | awk '{print $1;}' | grep $deploybase) ]]
  then
    echo >&2 "Error: missing deployment base image for $submod."
    echo >&2 "       Have you run \`$0 deploybase docker\`?"
    exit 1
  fi

  cp $pkgdir/doit.sh $workdir
  cp -f buildDocker/Dockerfile $workdir
  docker tag $deploybase deploybase
  docker build -t $submod $workdir
  docker rmi deploybase
  rm -f $workdir/Dockerfile
}

function deployLocally
{
  cd $submod
  $pkgdir/setup-deployment.sh
  sudo cp -a $builddir/* /
}

function doInstallMod
{
  if [[ -x $pkgdir/BUILD ]]
  then
    echo "############### Building: $submod"
    ($build)
    echo "############### Deploying: $submod"
    ($deploy)
    echo
  fi
}

function doTagAndPush
{
  imageName="$registry/blockapps/$submod:$tag"
  docker tag $submod $imageName
  docker push $imageName
}

function doBuildEnvMod
{
  function dodocker
  {
      echo "############### Building build environment: $submod"
      cp -f $PWD/buildDocker/Dockerfile-buildenv $pkgdir/Dockerfile
      docker rmi $registry/$submod-build >&/dev/null || true
      docker build -t $registry/$submod-build $pkgdir
      rm -f $pkgdir/Dockerfile
  }

  function dolocal
  {
      echo "############### Installing build environment: $submod"
      sudo=sudo $pkgdir/setup-build.sh
  }

  if [[ -x $pkgdir/setup-build.sh ]]
  then 
    do$1
  fi
}

function doDeployBaseMod
{
  function dodocker
  {
      echo "############### Building deployment environment: $submod"
      cp -f $PWD/buildDocker/Dockerfile-deploybase $pkgdir/Dockerfile
      docker rmi $registry/$submod-base >&/dev/null || true
      docker build -t $registry/$submod-base $pkgdir
      rm -f $pkgdir/Dockerfile
  }

  function dolocal
  {
      echo "############### Installing deployment environment: $submod"
      sudo=sudo $pkgdir/setup-deployment.sh
  }

  if [[ -x $pkgdir/setup-deployment.sh ]]
  then
    do$1
  else
    echo >&2 "Error: $submod must have an executable $pkgdir/setup-deployment.sh"
    exit 1
  fi
}

if [[ $# -eq 0 ]]
then
  echo >&2 "Must pass a mode."
  exit 1
fi

case $1 in
  "docker"|"docker-to-local")
    echo >&2 "'docker' build mode not supported currently"
    exit 1
    ;;
  "docker"|"docker-to-local")
    build="buildWithDocker"
    ;;&
  "local"|"local-to-docker")
    build="buildLocally"
    ;;&
  "docker"|"local-to-docker")
    deploy="deployWithDocker"
    ;;&
  "local"|"docker-to-local")
    deploy="deployLocally"
    ;;&
  "local"|"docker"|"local-to-docker"|"docker-to-local")
    doit=doInstallMod
    shift
    ;;
  "tag-and-push")
    if [[ -n $2 ]]
    then 
      tag=$2
      shift 2
    else
      echo >&2 "Mode '$1' takes a tag name as an argument"
      exit 1;
    fi
    doit=doTagAndPush
    ;;
  "build-env")
    case $2 in
      "docker")
        doit="doBuildEnvMod docker"
        ;;
      "local")
        doit="doBuildEnvMod local"
        ;;
      *)
        echo >&2 "Mode '$1' takes a second argument: docker, local"
        exit 1;
        ;;
    esac
    shift 2
    ;;
  "deploy-env")
    case $2 in
      "docker")
        doit="doDeployBaseMod docker"
        ;;
      "local")
        doit="doDeployBaseMod local"
        ;;
      *)
        echo >&2 "Mode '$1' takes a second argument: docker, local"
        exit 1
        ;;
    esac
    shift 2
    ;;
  *)
    echo >&2 "To install, mode may be: local, docker, local-to-docker, docker-to-local"
    echo >&2 "To create the build environment, mode may be: build-env"
    echo >&2 "To create the deployment environment, mode may be: deploy-env"
    echo >&2 "To tag and push images to the registry, mode may be: tag-and-push"
    exit 1
    ;;
esac

modsToBuild=${@:-$(<mgitmods)}
for i in $modsToBuild
do
  export submod=`basename $i`
  export pkgdir=$PWD/$submod/pkg
  export workdir=$PWD/.silo-work/$submod
  export builddir=$workdir/build
  mkdir -p $builddir
  if [[ -x $pkgdir/BUILD ]]
  then $doit
  fi
done

