# vim: syntax=yaml tabstop=2 shiftwidth=2 expandtab smarttab :
metadata:
  name: silo
  min_basil: "0.9.5.4"
  version: 1.0
  description: Test
  git_repo: https://github.com/blockapps/silo
  docker_repo: https://registry-aws.blockapps.net:5000
  hooks:
    init: "#include basil_extensions.js"

volumes:
  dapps:
    driver: local
  pgdata:
    driver: local

deployments:
  - name: smd-ui
    repo: https://github.com/blockapps/smd-ui.git
    ref: release/v0.4.5
    compose:
      restart: always
      depends_on:
        - apex
        - bloch
        - cirrus
        - strato
      environment:
        NODE_NAME: "${NODE_NAME}"
        BLOC_URL: "${BLOC_URL}"
        BLOC_DOC_URL: "${BLOC_DOC_URL}"
        STRATO_URL: "${STRATO_URL}"
        STRATO_DOC_URL: "${STRATO_DOC_URL}"
        CIRRUS_URL: "${CIRRUS_URL}"
        APEX_URL: "${APEX_URL}"
        STRATO_GS_MODE: "${STRATO_GS_MODE}"
        SINGLE_NODE: "${SINGLE_NODE}"
        ssl: "${ssl:-false}"

  - name: apex
    repo: https://github.com/blockapps/apex.git
    ref: master
    compose:
      restart: always
      depends_on:
        - bloch
        - cirrus
        - postgres
        - strato
      volumes:
        - dapps:/usr/src/app/apps
      environment:
        NODE_HOST: "${NODE_HOST}"
        SINGLE_NODE: "${SINGLE_NODE}"
        STRATO_GS_MODE: "${STRATO_GS_MODE}"
        PROD_DEV_MODE: "${PROD_ENV_MODE:-false}"
        blocHost: "bloch:8000"
        cirrusHost: "cirrus:3333"
        stratoHost: "strato:3000"
        postgres_host: "postgres"
        postgres_port: "5432"

  - name: dapp-store
    repo: https://github.com/blockapps/dapp-store.git
    ref: master
    compose:
      restart: always
      depends_on:
        - bloch
        - cirrus
        - strato
      environment:
        BLOC_URL: "${BLOC_URL}"
        STRATO_URL: "${STRATO_URL}"
        CIRRUS_URL: "${CIRRUS_URL}"

  - name: bloch
    repo: https://github.com/blockapps/blockapps-haskell.git
    ref: bloc-ingestion
    compose:
      restart: always
      depends_on:
        - strato
        - postgres
      environment:
        ssl: "${ssl:-false}"
        stratoHost: "strato:3000"
        cirrusHost: "cirrus:3333"
        postgres_host: "postgres"
        postgres_port: "5432"
        postgres_user: "postgres"
        postgres_password: "${postgres_password:-api}"

  - name: redis
    compose:
      image: redis:3.2
      restart: always
      command: redis-server --appendonly yes

  - name: cirrus
    repo: https://github.com/blockapps/cirrus.git
    ref: deduce-state-locally
    compose:
      restart: always
      depends_on:
        - strato
        - postgres
        - postgrest
        - kafka
        - bloch
      environment:
        blocHost: "bloch:8000"
        stratoHost: "strato:3000"
        postgrestHost: "postgrest:3001"
        zookeeper_conn: "kafka"
        postgres_host: "postgres"
        postgres_port: "5432"
        postgres_db: "cirrus"
        postgres_user: "postgres"
        postgres_password: "${postgres_password:-api}"
        stateDiffTopic: "${stateDiffTopic}"
        SINGLE_NODE: "${SINGLE_NODE}"

  - name: strato
    repo: https://github.com/blockapps/monstrato.git
    ref: performance-logging
    compose:
      restart: always
      ports:
        - "30303:30303"
        - "30303:30303/udp"
      environment:
        networkID : "${networkID}"
        genesis: "${genesis}"
        genesisBlock: "${genesisBlock}"
        bootnode: "${bootnode}"
        addBootnodes: "${addBootnodes}"
        lazyBlocks: "${lazyBlocks}"
        miningAlgorithm: "${miningAlgorithm}"
        miningThreads: "${miningThreads}"
        blockTime: "${blockTime}"
        minBlockDifficulty: "${minBlockDifficulty}"
        debugFail: "${debugFail}"
        evmDebugMode: "${evmDebugMode}"
        evmTraceMode: "${evmTraceMode}"
        backupblocks: "${backupblocks}"
        redisBDBNumber: "${redisBDBNumber}"
        useSyncMode: "${useSyncMode}"
        statsEnable: "${statsEnable}"
        statsHost: "${statsHost}"
        statsPort: "${statsPort}"
        statsFlush: "${statsFlush}"
        statsPrefix: "${statsPrefix}"
        statsSuffix: "${statsSuffix}"
        numMinPeers: "${numMinPeers}"
        mineBlocks: "${mineBlocks:-true}"
        kafkaHost: "kafka"
        zkHost: "kafka"
        redisHost: "redis"
        redisPort: "6379"
        postgres_user: "postgres"
        postgres_password: "${postgres_password:-api}"
        postgres_host: "postgres"
        #postgres_port: "5432" (not used)
      depends_on:
        - kafka
        - postgres
        - redis

  - name: postgrest
    repo: https://github.com/blockapps/postgrest-packager.git
    ref: master
    compose:
      restart: always
      environment:
        PG_ENV_POSTGRES_DB: "cirrus"
        PG_ENV_POSTGRES_USER: "postgres"
        PG_ENV_POSTGRES_PASSWORD: "${postgres_password:-api}"
        PG_ENV_POSTGRES_HOST: "postgres"
        PG_PORT_5432_TCP_PORT: "5432"
      depends_on:
        - postgres

  - name: postgres
    compose:
      image: postgres:9.6
      restart: always
      volumes:
      - pgdata:/var/lib/postgresql/data
      environment:
        POSTGRES_PASSWORD: "${postgres_password:-api}"
        POSTGRES_DB: "cirrus"

  - name: nginx
    repo: https://github.com/blockapps/nginx-packager.git
    ref: master
    compose:
      restart: always
      ports:
        - "80:80"
        - "443:443"
      depends_on:
        - bloch
        - cirrus
        - postgrest
        - smd-ui
        - strato
        - apex
      environment:
        ssl: "${ssl:-false}"
        sslCertFileType: "${sslCertFileType:-crt}"
        authBasic: "${authBasic}"
        uiPassword: "${uiPassword}"
        blockTime: "${blockTime}"
      volumes:
        - ./ssl:/tmp/ssl:ro

  - name: blockapps-docs
    repo: https://github.com/blockapps/blockapps-swagger.git
    ref: master
    compose:
      restart: always
      environment:
        API_URL: "/strato-api/eth/v1.2/swagger.json"

  - name: kafka
    compose:
      command: /bin/bash -c 'printf "\noffset.metadata.max.bytes=1048576\nmax.request.size=33554432\nmessage.max.bytes=33554432\n" >> opt/kafka_2.11-0.10.1.0/config/server.properties && supervisord -n'
      image: spotify/kafka:latest
      restart: always
      environment:
        ADVERTISED_HOST: "kafka"
        ADVERTISED_PORT: "9092"
        # AUTO_CREATE_TOPICS: "true"
