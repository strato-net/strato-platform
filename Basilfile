# vim: syntax=yaml tabstop=2 shiftwidth=2 expandtab smarttab :
metadata:
  name: silo
  min_basil: "0.9.5.4"
  version: 1.0
  description: Test
  git_repo: https://github.com/blockapps/silo
  docker_repo: https://registry-aws.blockapps.net:5000
  hooks:
    init: "#include basil_extensions.js"

volumes:
  dapps:
    driver: local
  pgdata:
    driver: local

deployments:
  - name: smd-ui
    repo: https://github.com/blockapps/smd-ui.git
    ref: master
    compose:
      restart: always
      depends_on:
        - strato
        - bloch
      environment:
        NODE_NAME: "${NODE_NAME}"
        BLOC_URL: "${BLOC_URL}"
        BLOC_DOC_URL: "${BLOC_DOC_URL}"
        STRATO_URL: "${STRATO_URL}"
        STRATO_DOC_URL: "${STRATO_DOC_URL}"
        CIRRUS_URL: "${CIRRUS_URL}"
        APEX_URL: "${APEX_URL}"
        STRATO_GS_MODE: "${STRATO_GS_MODE}"
        SINGLE_NODE: "${SINGLE_NODE}"

  - name: apex
    repo: https://github.com/blockapps/apex.git
    ref: master
    compose:
      restart: always
      depends_on:
        - bloch
        - cirrus
        - postgres
      volumes:
        - dapps:/usr/src/app/apps
      environment:
        NODE_HOST: "${NODE_HOST}"
        SINGLE_NODE: "${SINGLE_NODE}"

  - name: bloch
    repo: https://github.com/blockapps/blockapps-haskell.git
    ref: master
    compose:
      restart: always
      depends_on:
        - strato
        - postgres
      environment:
        ssl: "${ssl}"
        stratoHost: "${stratoHost}"
        stratourl: "${stratourl}"
        cirrusurl: "${cirrusurl}"
        pguser: "${pguser}"
        pgpasswd: "${pgpasswd}"
        pghost: "${pghost}"

  - name: redis
    compose:
      image: redis:3.2
      restart: always
      command: redis-server --appendonly yes

  - name: cirrus
    repo: https://github.com/blockapps/cirrus.git
    ref: master
    compose:
      restart: always
      links:
        - strato:strato
        - postgres-cirrus:postgres
      depends_on:
        - postgrest
      environment:
        blocurl: "${blocurl}"
        stratourl: "${stratourl}"
        zookeeper_conn: "${cirrus_zookeeper_conn}"
        postgres_db: "${cirrus_pg_db:-cirrus}"
        postgres_user: "${cirrus_pg_user:-postgres}"
        postgres_password: "${cirrus_pg_password}"
        postgres_host: "${cirrus_pg_host:-postgres}"
        postgres_port: "${cirrus_pg_port:-5432}"
        stateDiffTopic: "${stateDiffTopic}" 

  - name: strato
    repo: https://github.com/blockapps/monstrato.git
    ref: master
    compose:
      restart: always
      ports:
        - "30303:30303"
        - "30303:30303/udp"
      environment:
        networkID : "${networkID}"
        genesis: "${genesis}"
        genesisBlock: "${genesisBlock}"
        bootnode: "${bootnode}"
        addBootnodes: "${addBootnodes}"
        lazyBlocks: "${lazyBlocks}"
        miningAlgorithm: "${miningAlgorithm}"
        miningThreads: "${miningThreads}"
        blockTime: "${blockTime}"
        minBlockDifficulty: "${minBlockDifficulty}"
        debugFail: "${debugFail}"
        evmDebugMode: "${evmDebugMode}"
        evmTraceMode: "${evmTraceMode}"
        backupblocks: "${backupblocks}"
        redisBDBNumber: "${redisBDBNumber}"
        useSyncMode: "${useSyncMode}"
        statsEnable: "${statsEnable}"
        statsHost: "${statsHost}"
        statsPort: "${statsPort}"
        statsFlush: "${statsFlush}"
        statsPrefix: "${statsPrefix}"
        statsSuffix: "${statsSuffix}"
        numMinPeers: "${numMinPeers}"
        mineBlocks: "${mineBlocks:-true}"
      links:
        - zookeeper
        - kafka
        - postgres
        - redis
      depends_on:
        - zookeeper
        - kafka
        - postgres
        - redis

  - name: postgres-cirrus
    compose:
      image: postgres:9.6
      restart: always
      environment:
        POSTGRES_DB: cirrus
        POSTGRES_USER: postgres
        PG_ENV_POSTGRES_DB: cirrus
        PG_ENV_POSTGRES_USER: postgres

  - name: postgrest
    repo: https://github.com/blockapps/postgrest-packager.git
    ref: master
    compose:
      restart: always
      environment:
        PG_ENV_POSTGRES_DB: cirrus
        PG_ENV_POSTGRES_USER: postgres
        PG_ENV_POSTGRES_PASSWORD: ""
        PG_ENV_POSTGRES_HOST: "postgres-cirrus"
        PG_PORT_5432_TCP_PORT: "5432"
      depends_on:
        - postgres-cirrus

  - name: postgres
    compose:
      image: postgres:9.6
      restart: always
      volumes:
      - pgdata:/var/lib/postgresql/data
      environment:
        POSTGRES_PASSWORD: api

  - name: nginx
    repo: https://github.com/blockapps/nginx-packager.git
    ref: master
    compose:
      restart: always
      ports:
        - "443:443"
        - "80:80"
      depends_on:
        - bloch
        - cirrus
        - postgrest
        - smd-ui
        - strato
        - apex
      environment:
        ssl: "${ssl}"
        authBasic: "${authBasic}"
        uiPassword: "${uiPassword}"
        blockTime: "${blockTime}"

  - name: zookeeper
    compose:
      image: zookeeper:3.4.9
      restart: always
      environment:
        ZOO_MY_ID: "1"

  - name: blockapps-docs
    repo: https://github.com/blockapps/blockapps-swagger.git
    ref: master
    compose:
      restart: always
      environment:
        API_URL: "/strato-api/eth/v1.2/swagger.json"

  - name: kafka
    repo: https://github.com/blockapps/kafka-packager.git
    ref: master
    compose:
      restart: always
      links:
        - zookeeper
      environment:
        KAFKA_ZOOKEEPER_CONNECT: "zookeeper:2181"
        KAFKA_ADVERTISED_HOST_NAME: "kafka"
        KAFKA_ADVERTISED_PORT: "9092"
        KAFKA_DELETE_TOPIC_ENABLE: "true"
        KAFKA_LOG_CLEANER_ENABLE: "false"
        KAFKA_LOG_RETENTION_HOURS: "2147483647"
