# vim: syntax=yaml tabstop=2 shiftwidth=2 expandtab smarttab :
metadata:
  name: silo
  min_basil: "0.9.2"
  version: 1.0
  description: test bloch
  git_repo: https://github.com/blockapps/blockapps-haskell.git
  docker_repo: https://registry-aws.blockapps.net:5000/
  hooks:
    init: "#include basil_extensions.js"

deployments:
  - name: bloch
    repo: https://github.com/blockapps/blockapps-haskell.git
    ref: master
    compose:
      restart: always
      environment:
        ssl: "${ssl}"
        pghost: "${pghost}"
        pguser: "${pguser}"
        pgpasswd: "${pgpasswd}"
        cirrusurl: "${cirrusurl}"
        stratourl: "${stratourl}"
