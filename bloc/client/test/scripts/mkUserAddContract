
set -e

port=8000
#port=10001

contractName=${1%.*}

function customHttp { # set behavior of http I like....  crash on error, print body to stderr, timeout longer

  set +e
  output=`http -b --check-status --timeout=60 "$@"`
  returnVal=$?
  set -e
  

  if [ "$returnVal" == "0" ]
  then
    echo "$output"
  else
    echo "$output" >&2
    exit $returnVal
  fi
}

echo "#################################################"
echo "# Creating a new address and running the faucet #"
echo "#################################################"

address=`customHttp --form http://localhost:$port/users/fred password=qqqq faucet=1`

echo "Here are the details of the new address '$address':"

customHttp http://bayar4a.eastus.cloudapp.azure.com/strato-api/eth/v1.2/account?address=$address | jq 

echo ""

src=`cat $1`

echo $src

request=`echo '{"password":"qqqq", "args": {}, "value": 0, "txParams":{}}' | jq --arg src "$src" '.src= $src ' | jq --arg contractName "$contractName" '.contract= $contractName '`

echo "########################"
echo "# Uploading a contract #"
echo "########################"

echo "$request" | customHttp POST http://localhost:$port/users/fred/$address/contract "Accept: */*"

echo ""

echo "##################################"
echo "# querying state in new contract #"
echo "##################################"

customHttp http://localhost:$port/contracts/$contractName/Latest/state | jq





