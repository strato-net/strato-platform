name: blockapps-bloc-api
version: 0.1.0.0
synopsis: Bloc microservice
description: Bloc microservice
homepage: https://github.com/blockapps/blockapps-haskell/blockapps-bloc
license: BSD3
license-file: LICENSE
author: Eitan Chatav
maintainer: eitan@blockapps.net
copyright: 2016 BlockApps
category: Web
build-type: Simple
cabal-version: >=1.10

library
  hs-source-dirs: src
  exposed-modules:
    BlockApps.Bloc.API
    BlockApps.Bloc.Crypto
    BlockApps.Bloc.API.Addresses
    BlockApps.Bloc.API.Contracts
    BlockApps.Bloc.API.Search
    BlockApps.Bloc.API.Users
    BlockApps.Bloc.API.Utils
  default-language: Haskell2010
  ghc-options: -Wall -Werror
  build-depends: base
               , aeson
               , aeson-casing
               , blockapps-ethereum
               , blockapps-solidity
               , blockapps-strato-api
               , containers
               , cryptonite
               , bytestring
               , generic-random
               , http-api-data
               , http-media
               , QuickCheck
               , quickcheck-instances
               , saltine
               , secp256k1
               , servant
               , servant-docs
               , text

source-repository head
  type: git
  location: https://github.com/blockapps/blockapps-haskell/bloc/bloc
