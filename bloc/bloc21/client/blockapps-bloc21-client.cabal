name: blockapps-bloc21-client
version: 0.1.0.0
synopsis: Bloc microservice client
description: Bloc microservice client
homepage: https://github.com/blockapps/blockapps-haskell/bloc/client
license-file: LICENSE
author: Eitan Chatav
maintainer: eitan@blockapps.net
copyright: 2016 BlockApps
category: Web
build-type: Simple
cabal-version: >=1.10

library
  hs-source-dirs: src
  exposed-modules:
    BlockApps.Bloc21.Client
  default-language: Haskell2010
  ghc-options: -Wall
  build-depends: base
    , blockapps-bloc21-api
    , blockapps-ethereum
    , blockapps-solidity
    , blockapps-strato-api
    , containers
    , servant-client
    , text

test-suite blockapps-bloc21-client-test
  default-language: Haskell2010
  type: exitcode-stdio-1.0
  hs-source-dirs: test
  ghc-options: -Wall -Werror
  main-is: Spec.hs
  other-modules:
    BlockApps.Bloc21.APISpec
    BlockApps.Bloc21.API.AddressesSpec
    BlockApps.Bloc21.API.ContractsSpec
    BlockApps.Bloc21.API.E2ESpec
    BlockApps.Bloc21.API.SearchSpec
    BlockApps.Bloc21.API.UsersSpec
    BlockApps.Bloc21.API.SpecUtils
  other-modules:
  build-depends: base >=4 && < 5
    , blockapps-bloc-api
    , blockapps-bloc-client
    , blockapps-strato-api
    , blockapps-strato-client
    , blockapps-solidity
    , blockapps-ethereum
    , containers
    , directory
    , generic-random
    , hspec
    , http-client
    , QuickCheck
    , quickcheck-instances
    -- , servant-aeson-specs
    , servant-client
    , text
    , vector

source-repository head
  type: git
  location: https://github.com/blockapps/blockapps-haskell/
