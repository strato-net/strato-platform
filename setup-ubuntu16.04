#!/bin/bash

set -e

if [[ $EUID -ne 0 ]]; then
  echo >&2 "Must be run as root"
  exit 1
fi

echo "Installing docker..."
apt-key adv --keyserver hkp://p80.pool.sks-keyservers.net:80 \
  --recv-keys 58118E89F3A912897C070ADBF76221572C52609D &>/dev/null
echo "deb https://apt.dockerproject.org/repo ubuntu-xenial main" \
  | tee /etc/apt/sources.list.d/docker.list >/dev/null
apt-get update >&/dev/null
apt-get -y install docker-engine &>/dev/null
echo "Adding $USER to the docker group..."
usermod -aG docker $USER >&/dev/null
echo "You will need to log out and back in to activate your group membership"

echo "Installing docker-compose..."
curl -L "https://github.com/docker/compose/releases/download/1.8.1/docker-compose-$(uname -s)-$(uname -m)"  -o /usr/local/bin/docker-compose >& /dev/null
chmod +x /usr/local/bin/docker-compose

echo "Copying certs if present..."
if [[ -f server.pem ]]; then
  mv server.pem /etc/ssl/certs
fi

if [[ -f server.key ]]; then
  mv server.key /etc/ssl/private
fi

if ! [[ -r docker-compose.yml ]]
then 
  echo
  echo "Now get the 'Raw' URL for blockapps/silo/docker-compose.yml on your"
  echo "favorite branch from github and wget it into ./docker-compose.yml."
  echo
  echo "Run the following sed command, replacing <tag> with your tag:"
  echo "    sed -i 's@image: \(.*\)@image: auth.blockapps.net:5000/blockapps/\1:<tag>@' docker-compose.yml"
  echo "and set and export any environment variables you want that are mentioned."
  echo "Finally, run"
  echo "    docker login -u blockapps -p blockAPPS123 auth.blockapps.net:5000"
  echo "    docker-compose up -d"
  echo
fi
