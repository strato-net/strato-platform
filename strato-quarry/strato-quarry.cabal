name:                strato-quarry
version:             0.2.0.0
-- synopsis:            
-- description:         
license:             Apache-2.0
license-file:        LICENSE
author:              Ryan Reich
maintainer:          ryan@blockapps.net
-- copyright:           
-- category:            
build-type:          Simple
-- extra-source-files:  
cabal-version:       >=1.10

library
  default-language:    Haskell2010
  build-depends:       base >=4.8 && <4.9,
                       bytestring,
                       persistent,
                       persistent-postgresql,
                       postgresql-simple,
                       blockapps-data,
                       merkle-patricia-db,
                       mtl,
                       ethereum-rlp,
                       blockapps-util,
                       containers,
                       text,
                       time,
                       haskoin,
                       strato-conf,
                       resourcet,
                       transformers,
                       hflags,
                       monad-logger,
                       esqueleto,
                       blockapps-util,
                       strato-sequencer,
                       extra
  exposed-modules:     Blockchain.Bagger
                       Blockchain.Bagger.BaggerState
  other-modules:       Blockchain.Bagger.TransactionList
  ghc-options:         -Wall -O2 -fno-warn-unused-do-bind
  hs-source-dirs:      src
