                         "DISTRIBUTOR_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJTTlRQNXpMTzNHVVhtdzhxRGRNazlDYnY5LUZNeUFhY1JTWmRoUExQaWVFIn0..jqEWDOzU-uHRi4M_MKWsyygvKUk6oryppDCcKlVMVO0f-xXs1zlQxyEWwZGiHcYFLsJu3eyWTBkeeLoA4eyXnuTtAxQsRsLPW9NtdVp4h8X3kB7oxswxPPm78VnRJjUEbCVgNkWE9BuBND4M4i9n28VRT95ZL7Rn5hkLQjJBZdQgi6348Ns0qUvRm9bfTerisCbKwp5Ezqv9uy_6r-Uo1MsR5XTHOKbIttS9RL7Q6Un2-_K4-SSWf62Us0QMSBvM8BgqeYY0ILkVIhpfF_hCv7qJFNKk0_m2D3x9kVjaUnXkXudapCcq-SleboxdBweVteSyw1mvDBDrVhV93K-0OQ",
                         "MANUFACTURER_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJTTlRQNXpMTzNHVVhtdzhxRGRNazlDYnY5LUZNeUFhY1JTWmRoUExQaWVFIn0..Lt0XENyA1QFcGG3N2vJ16Ej-5h3bvQN_v1NeN_wGk9ZhefZUctB_bL2RgLAWN9rF61CKzMc0R15Fc_RwNIoBMkns7lL33EVKj82EJg91HzKTxMyhkuQyrFdq_X19xLOdn-ZJS-0bvwsSOiN5PHbqgst0WT3FPBaC3cGh_nygOc4sQq6JXNx7ClP8hZon5BQqPd002h8HDEl8ZRL0D7smWpSAyH54jDlywlkj1lBT1Ue0gPlKaGQJLQJabzCUBKhZUJjWXfhIaVFuGkj8MNHu3KTA39HADL2A7p6fqTmXjd0DsuFcCmt2xL5dLayQhQjeUqQRPF0rBpu3toeW0kaHSQ",
                         "REGULATOR_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJTTlRQNXpMTzNHVVhtdzhxRGRNazlDYnY5LUZNeUFhY1JTWmRoUExQaWVFIn0..gYZuxO6WDiNDZ9dclmFTN1Xa0Eh_y7EYieVcXlnwrfn7KnyKTxURLzJzDJx28nZqaSeZx4zbSbPWoMvDCsKT3DxZ6FasPmLDWuWEPQjKO2jJSYuJTKnpKcpmIYf165ouWRosfIc9cNRBh06EFf2vXIRGE227KPss3W05jTf3Yrx0pFkJYKP3JmRLJH9s2XSqwhb623Bo2KkTshchCO1sGmBckwv0UXJP1pprkXPgm0k5gjbBZK8nnGiXQyehJ0OA9GMGswPTLKP1iQ2mnvLtw7RWzoTvNziYcchnlZ3tn5FLC_hY3L6nJsIQk84sS0DFNLI67XTCgeH_DAmC2QYOqw",
                         "RETAILER_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJTTlRQNXpMTzNHVVhtdzhxRGRNazlDYnY5LUZNeUFhY1JTWmRoUExQaWVFIn0..lu_HcxNuHJbPYsnw7Qq4skUzbqR5W9P5SHUSdRqfP1P0HClob4AocyKE6fnQtfJNvX-niKNigWd0hCv7yXHT5v-rQykKf1A2xMz7VYF51pOpR5ghbWM3O3NtNCShjiD6lKhMdHUnXovvmPsGUHiUSICfvqG_NEpZ8oPDgMne-7XtE1flrvK_qGKVPdfRl28VeDxBQGjpBIZ532u31wekhHXoyK1MuUkO4zTqOlwWCWVabonA6dVeABD64EkgbetMCrjTX7oX-WihxhVomC7wY7FQt52Gc6ghJPpKD8UFZEXA1A1PgfT9kqSgaGRBadZ2UzVQS3pt6AgrCmNrdjXG7Q"]) {
                  sh 'yarn test'
                }
              }
            }
          },


          'Core Strato tests': {
            sh '''#!/bin/bash -le
              set -x
              echo "Running core-strato unit tests"
              cd strato-worktree/core-strato
              ./run_unit_tests.sh
            '''
          },

          'Bloch tests': {
            sh '''#!/bin/bash -le
              set -x
              echo 'Running BlockApps Haskell tests'
              cd strato-worktree/blockapps-haskell
              ./run_unit_tests.sh
            '''
          },

          'Shared tests': {
            dir('strato-worktree/') {
              sh 'stack test ./shared-util/'
            }
          },

          'SMD tests': {
            sh '''#!/bin/bash -le
              set -x
              echo 'Running SMD tests'
              cd strato-worktree/smd-ui
              docker build -f Dockerfile.test .
            '''
          },
          '(quick) Integration tests' : {
            sh '''#!/bin/bash -le
              set -x
              echo 'Running local integration tests'
              pushd strato-worktree/tests
              rm -rf node_modules
              npm install
              npm run test:blockhash
              npm run test:truchainz
              npm run test:multicontract
              npm run test:slipstream
              npm run test:solidvm
              npm run test:uploadOrder
              popd
              pushd strato-worktree/core-strato/strato-init
              ./check_genesis_ingestion.sh
              popd
            '''
          }
        )
      }
    }

  }

  post {
    always {
      dir ('strato-getting-started') {
          sh 'rm -rf strato_logs*'
          sh './fetchlogs --as-dir'
          sh 'mv strato_logs strato_logs_oauth'
          sh 'mv strato_logs_oauth strato_pipeline_logs/'
          archiveArtifacts artifacts: 'strato_pipeline_logs/**', fingerprint: true
      }
    }

    success {
      slackSend (
        color: 'good',
        message: "Build Successful: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL}) on node ${env.NODE_NAME}"
      )
    }

    failure {
      slackSend (
        color: 'danger',
        message: "Build failed: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL} on node ${env.NODE_NAME})"
      )


      script {
        if (env.PLATFORM_BRANCH_NAME == 'develop') {
          slackSend(
              channel: '#engineering',
              color: 'danger',
              message: "Develop branch build failed: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL} on node ${env.NODE_NAME})"
          )
        }
      }
    }
  }
}