pipeline {
  agent {
    label "test"
  }
  stages {
    stage('Prepare') {
      steps {
        wrap([$class: 'BuildUser']) {
          script {
            try {
              currentBuild.description = "Agent ${env.NODE_NAME}// ${BUILD_USER_FIRST_NAME}"
            } catch (Exception e) {
              currentBuild.description = "Agent ${env.NODE_NAME}// github"
            }
          }
        }
        sh '''#!/bin/bash -le
          docker rm -f $(docker ps -aq) || true; docker system prune -f --volumes
        '''
      }
    }

    stage('Build') {
      steps {
        sh 'rm -rf .docker-work'
        sh 'REPO=private make docker-compose'
        sh 'rm -rf .docker-work'
        dir ('blockapps-rest') {
          sh 'yarn install --pure-lockfile'
          sh 'yarn build'
        }
      }
    }

    stage('Test and Push Images') {
      steps {
        parallel (
          'Push images': {
            withCredentials([
              string(credentialsId: 'BLOCKAPPS_SERVICE_USER_AWS_ACCESS_KEY_ID', variable: 'BLOCKAPPS_SERVICE_USER_AWS_ACCESS_KEY_ID'),
              string(credentialsId: 'BLOCKAPPS_SERVICE_USER_AWS_SECRET_ACCESS_KEY', variable: 'BLOCKAPPS_SERVICE_USER_AWS_SECRET_ACCESS_KEY')
            ]) {
              archiveArtifacts artifacts: "docker-compose.yml"
              sh '''#!/bin/bash -le
                set -x
                echo $BLOCKAPPS_SERVICE_USER_AWS_ACCESS_KEY_ID
                echo $BLOCKAPPS_SERVICE_USER_AWS_SECRET_ACCESS_KEY
                AWS_ACCESS_KEY_ID=$BLOCKAPPS_SERVICE_USER_AWS_SECRET_ACCESS_KEY AWS_SECRET_ACCESS_KEY=$BLOCKAPPS_SERVICE_USER_AWS_SECRET_ACCESS_KEY AWS_DEFAULT_REGION=us-east-1 aws s3 ls
              '''
            }
          }
        )
      }
    }

  }

}
