pipeline {
  agent {
    label "cd10"
  }
  options { disableConcurrentBuilds() }
  parameters { string(name: 'SILO_BRANCH_NAME', defaultValue: 'test-', description: 'Silo git branch name to build upon. Skip the \"origin/\" part.\nThis job will build using the pipeline from Jenkinsfile.test and all the code in this branch.') }

  stages {
    stage('Prepare') {
      steps {
        sh '''#!/bin/bash -le
          docker rm -f $(docker ps -aq) || true; docker system prune -f
          docker ps
        '''
       }
    }
    
    stage('Build') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER'), usernamePassword(credentialsId: 'blockapps-cd-github', passwordVariable: 'GH_PASSWD', usernameVariable: 'GH_USER')]) {
          sh '''#!/bin/bash -le
            docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
            # Make sure all repos are cloned
            basil clone
            # Checkout branches specified in Basilfile
            basil checkout
            # Git pull all the latest
            dirs=($(find ./repos -mindepth 1 -maxdepth 1 -type d))
            for dir in "${dirs[@]}"; do
              (cd "$dir" && git pull)
            done
            basil compose --release > docker-compose.release.yml
            basil snapshot > Basilfile.snapshot
            basil build
         	'''
        }
      }
    }
    stage('Deploy') {
      steps {
        sh '''#!/bin/bash -le
          basil compose > docker-compose.yml
          export NODE_HOST=${NODE_HOST:-cd10.eastus.cloudapp.azure.com}
          export NODE_NAME=${NODE_NAME:-$NODE_HOST}
          export BLOC_URL=${BLOC_URL:-http://$NODE_HOST/bloc/v2.2}
          export BLOC_DOC_URL=${BLOC_DOC_URL:-http://$NODE_HOST/docs/?url=/bloc/v2.2/swagger.json}
          export STRATO_URL=${STRATO_URL:-http://$NODE_HOST/strato-api/eth/v1.2}
          export STRATO_DOC_URL=${STRATO_DOC_URL:-http://$NODE_HOST/docs/?url=/strato-api/eth/v1.2/swagger.json}
          export CIRRUS_URL=${CIRRUS_URL:-http://$NODE_HOST/cirrus/search}
          export XAPI_URL=${XAPI_URL:-http://$NODE_HOST/x-api}
          export cirrusurl=nginx/cirrus
          export stratoHost=nginx
          export ssl=false
          docker-compose up -d
          sleep 32 # wait for cirrus to restart (remove when container dependencies are fixed)
          docker ps
          # Few quick tests
          curl -f http://localhost/cirrus/search/
          curl -f http://localhost/strato-api/eth/v1.2/stats/difficulty
          curl -f http://localhost/bloc/v2.2/users
        '''
      }
    }

    stage('E2E-Test') {
      steps {
        sh '''#!/bin/bash -le
          echo 'Running BlockApps BA deploy script and tests to verify the build to be healthy'
          rm -rf blockapps-ba
          git clone https://github.com/blockapps/blockapps-ba.git -b master
          cd blockapps-ba
          npm i
          SERVER=localhost npm run deploy
          SERVER=localhost npm run test
        '''
      }
    }

    stage('Release') {
          steps {
            withEnv(["TAG_NAME=build-${env.BUILD_NUMBER}", "PATH=$PATH:/usr/local/go/bin"]) {
              withCredentials([
                usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER')
              ]) {
                sh '''#!/bin/bash -le
                  docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
                  basil build --release
                  basil push
                '''
              }
            }
          }
        }
  }

  post {
    success {
      archive "docker-compose.release.yml"
      slackSend (
        color: 'good',
        message: "Build Successful: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
        )
      sh '''
        echo "Build Successful for Git branch: $BRANCH_NAME"
      '''
    }

    failure {
      slackSend (
        color: 'danger',
        message: "Build failed: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
    }
  }
}
