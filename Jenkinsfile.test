            '''
          },

          'Track And Trace': {
            sh 'rm -rf track-and-trace && git clone https://github.com/blockapps/track-and-trace.git'
            dir('track-and-trace') {
              sh 'git checkout oauth42style'
              sh 'git submodule update --init --recursive'
              sh 'sed -i "s/localhost:8080/localhost/g" server/config/localhost.config.yaml'
              dir('server') {
                sh 'touch .env'
                sh 'yarn build'
                sh 'yarn install'
                sh 'export SERVER=oauth-test'
                dir('config'){
                  sh '''cat << EOF > ./oauth-test.config.yaml
                  apiDebug: false
                  restVersion: 6
                  timeout: 120000
                  dappPath: ./dapp
                  libPath: blockapps-sol/dist
                  apiUrl: /api/v1
                  deployFilename: ./config/localhost.deploy.yaml
                  nodes:
                    - id: 0
                      url: "http://test1.ci.blockapps.net:8080"
                      publicKey: "6d8a80d14311c39f35f516fa664deaaaa13e85b2f7493f37f6144d86991ec012937307647bd3b9a82abe2974e1407241d54947bbb39763a4cac9f77166ad92a0"
                      port: 30303
                      oauth:
                        appTokenCookieName: "tt_session"
                        scope: "email openid"
                        appTokenCookieMaxAge: 7776000000 # 90 days: 90 * 24 * 60 * 60 * 1000
                        clientId: "all-test-ci-blockapps-net-infinite"
                        clientSecret: "a7f199dc-9f50-45fc-9f50-13b40727ba31"
                        openIdDiscoveryUrl: "https://keycloak.blockapps.net/auth/realms/track-and-trace/.well-known/openid-configuration"
                        redirectUri: "http://test1.ci.blockapps.net/api/v1/authentication/callback"
                        logoutRedirectUri: "http://test1.ci.blockapps.net"
                  EOF
                  '''
                }
                withEnv(["ADMIN_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJTTlRQNXpMTzNHVVhtdzhxRGRNazlDYnY5LUZNeUFhY1JTWmRoUExQaWVFIn0..X7fHjYj_R1TEZnGrRvF1XnG68Y9KdBmdboOs6KUxtXm9SwqG8WX419yxQhrgECsdYF9sBnaZP6kIUs8c8PL7nBFFrRUqscugfdV4BMcIUmfjQr1glAyjdsUQkINQSvqyP_Up9LokPK34pANek1CJSbmuggK4M-MDp2OXCH1XqcqFqzM5yr-5EhNGZc_aUxqtWKwnV6Js6LvhwIb8RYt1WgrYs87Q4ccnrecbAGClDyec_hqoA0PzLp-vvhSWxo8AwF4e5AAITPj6M2-pTRZOnsMPzmHUdWkm8_7q-W2BNZIrO0fgSTGfWcECtdS9FaCT7i-H9kFhw6vn9K1pGyOrUQ",
