pipeline {
  agent {
    label "cd10"
  }
  options { disableConcurrentBuilds() }
  stages {
    stage('Prepare') {
      steps {
        sh '''#!/bin/bash -le
          set -x
          docker rm -f $(docker ps -aq) || true; docker system prune -f --volumes
          docker ps
        '''
       }
    }

    stage('Build') {
      steps {
        sh '''#!/bin/bash -le
          set -x
          REPO=private make all
        '''
      }
    }

    stage('Deploy') {
      steps {
        sh '''#!/bin/bash -le
          set -x
         
        '''
      }
    }

    stage('Test') {
      steps {
        parallel (
          'Apex tests': {
            sh '''#!/bin/bash -le
              set -x

            '''
          },


        )
      }
    }

    stage('Release') {
      steps {
        withCredentials([
          usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER')
        ]) {
          sh '''#!/bin/bash -le
            set -x
            docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
            docker-compose -f docker-compose.push.yml push
          '''
        }
      }
    }
  }

  post {
    success {
      archive "docker-compose.yml"
      slackSend (
        color: 'good',
        message: "Build Successful: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
        )
      sh '''
        echo "Build Successful for Git branch: $BRANCH_NAME"
      '''
    }

    failure {
      slackSend (
        color: 'danger',
        message: "Build failed: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]' (${env.BUILD_URL})"
      )
    }
  }
}
