#!/bin/bash
set -e

# Variable Declarations
installDockerCompose=false
startDocker=false
killDocker=false
enableSsl=false
testDir="strato/deployments/test"
rootDir=$PWD

# Parse command line arguments
for arg in "$@"
do
  echo $arg
  case "$arg" in
    "install-docker-compose")
      installDockerCompose=true
      ;;
    "start-docker")
      startDocker=true
      ;;
    "kill-docker")
      killDocker=true
      ;;
    "enable-ssl")
      enableSsl=true
      ;;
    esac
done

# Check if we need to install docker compose
if [[ "$installDockerCompose" == true ]]
then
  echo "Installing deployment dependencies"
  sudo ./setup-ubuntu16.04
fi

# Start docker based on the ssl flag
if [[ "$startDocker" == true ]]
then
  echo "Starting docker containers with ssl=$enableSsl"
  ssl=$enableSsl docker-compose up -d
fi

# Install npm packages for testing
echo "Installing test dependencies..."
cd $testDir
npm install
cd $rootDir

# Run the tests
echo "Running tests..."
if [[ "$enableSsl" == true ]]
then
  $testDir/node_modules/mocha/bin/mocha --config test-https.config.yaml $testDir/e2e
else
  $testDir/node_modules/mocha/bin/mocha --config test.config.yaml $testDir/e2e
fi

# Stop docker if requested
if [[ "$killDocker" == true ]]
then
  echo "Killing docker processes..."
  docker-compose kill && docker-compose down -v
fi
