pipeline {
    agent {
        label "test-multinode102"
    }

    stages {
        stage('Init') {
            steps {
                script {
                    lib = load("${env.WORKSPACE}/utils/dev-scripts/syncspeedtest/pipelines/Jenkinsfile.library")
                    NODE_DATA = load("${env.WORKSPACE}/utils/dev-scripts/syncspeedtest/pipelines/Jenkinsfile.config").NODE_DATA
                }
            }
        }

        stage('Test') {
            steps {
              script {
                  lib.deployStrato(NODE_DATA.NODE2)
                  lib.runTests()
              }
            }
        }
    }
}