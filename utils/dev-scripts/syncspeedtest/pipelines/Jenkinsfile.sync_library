def approveAllMemberships() {
  script {
    sleep 10 // to make sure that secondary apps can send their approvals before we look for them
    def membershipRequests = sh(returnStdout: true, script: "sudo docker exec upbring_backend_1 bash -c \"npm run membership-util ls | grep 'NEW' \" | awk '{print \$4,\$6}'").trim()
    echo "${membershipRequests}"
    sh """#!/bin/bash -lex
      while IFS= read -r request; do
        echo \$request
        ORG_ADDRESS=\$(echo "\${request}" | awk '{print \$1}')
        ORG_NAME=\$(echo "\${request}" | awk '{print \$2}')
        echo "Approving membership for org: '\$ORG_NAME' with orgAddress: '\$ORG_ADDRESS'"
        # Approve
        sudo docker exec upbring_backend_1 bash -c \"npm run membership-util -- approve -a "\${ORG_ADDRESS}"\"
        # Process
      done <<< '''${membershipRequests}'''
    """
  }
}

// TODO: rewrite with recursive or get sync=true|false status from monitor/node once implemented in STRATO. Extra sleeps also give node more time to finish cirrus indexing.
def waitForHealthyNetwork(MONITOR_DATA) {
  script {
    echo "Waiting for network nodes to be in-sync and healthy..."
    for (int i = 0; i < 3000; i++) {
      if (sh(returnStatus: true, script: "curl --silent ${MONITOR_DATA.NETWORK_HEALTH_URL} | grep '\"needsAttention\":false'") != 0) {
        sleep 2
      } else {
        // If healthy - check in few seconds again to make sure it wasn't temporary while syncned to the same block number. Monitor should probably be handling this itself in the future before showing network healthy.
        sleep 20
        if (sh(returnStatus: true, script: "curl --silent ${MONITOR_DATA.NETWORK_HEALTH_URL} | grep '\"needsAttention\":false'") != 0) {
          sleep 2
        } else {
          sleep 20
          if (sh(returnStatus: true, script: "curl --silent ${MONITOR_DATA.NETWORK_HEALTH_URL} | grep '\"needsAttention\":false'") != 0) {
            sleep 2
          } else {
            return true
          }
        }
      }
    }
    error ("Failed to get the STRATO nodes healthy after resync")
  }
}

def getCurrentNodeAddressAndPubkey() {
  script {
    sh 'if [ ! -d "strato-getting-started" ]; then git clone https://github.com/blockapps/strato-getting-started; fi'
    dir ('strato-getting-started') {
      sh 'if [ ! -f "docker-compose.yml" ]; then sudo ./strato --compose; fi'
      def address = sh(
          returnStdout: true,
          script: "sudo ./strato --get-address"
      ).trim()
      def pubkey = sh(
          returnStdout: true,
          script: "sudo ./strato --get-pubkey"
      ).trim()
      
      return [address: address, pubkey: pubkey]
    }
  }
}

return this