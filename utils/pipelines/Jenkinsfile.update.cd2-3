pipeline {
  agent none
  parameters {string(name: 'STRATO_TEST_BUILD_NUMBER', defaultValue: '', description: 'The build number of "STRATO_test_build" to fetch docker-compose.yml from.')}
  stages {
    stage('Prepare to deploy') {
      steps {
        parallel (
          "cd-multinode-2": {
            node('cd-multinode-2') {
              step ([$class: 'CopyArtifact', filter: 'docker-compos*.yml', fingerprintArtifacts: true, flatten: true, projectName: 'STRATO_test_build', selector: [$class: 'SpecificBuildSelector', buildNumber: '${STRATO_TEST_BUILD_NUMBER}'], target: '/tmp/']);
              withDockerRegistry([credentialsId: 'registry-aws-blockapps', url: 'https://registry-aws.blockapps.net:5000/']) {
                withCredentials([usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER')]) {
                  sh '''#!/bin/bash -le
                  set -x
                  set -e
                  docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
                  sudo rm -rf strato-getting-started || true
                  git clone https://github.com/blockapps/strato-getting-started
                  cd strato-getting-started
                  mv /tmp/docker-compose.yml docker-compose.release.multinode.yml
                  docker-compose -f docker-compose.release.multinode.yml pull
                  '''
                }
              }
            }
          },
          "cd-multinode-3": {
            node('cd-multinode-3') {
              step ([$class: 'CopyArtifact', filter: 'docker-compos*.yml', fingerprintArtifacts: true, flatten: true, projectName: 'STRATO_test_build', selector: [$class: 'SpecificBuildSelector', buildNumber: '${STRATO_TEST_BUILD_NUMBER}'], target: '/tmp/']);
              withDockerRegistry([credentialsId: 'registry-aws-blockapps', url: 'https://registry-aws.blockapps.net:5000/']) {
                withCredentials([usernamePassword(credentialsId: 'docker-aws-registry-login', passwordVariable: 'DOCKER_PASSWD', usernameVariable: 'DOCKER_USER')]) {
                  sh '''#!/bin/bash -le
                  set -x
                  set -e
                  docker login -u $DOCKER_USER -p $DOCKER_PASSWD registry-aws.blockapps.net:5000
                  sudo rm -rf strato-getting-started || true
                  git clone https://github.com/blockapps/strato-getting-started
                  cd strato-getting-started
                  mv /tmp/docker-compose.yml docker-compose.release.multinode.yml
                  docker-compose -f docker-compose.release.multinode.yml pull
                  '''
                }
              }
            }
          }
        )
      }
    }
    stage('Deploy multinode') {
      steps {
        parallel (
          "cd-multinode-2": {
            node('cd-multinode-2') {
              sh '''#!/bin/bash -le
              set -x
              set -e
              docker rm -f $(docker ps -aq) || true; docker system prune -f # Keeping the volumes
              cd strato-getting-started
              STRATO_GS_MODE="1" NODE_HOST=cd-multinode-2.southcentralus.cloudapp.azure.com BOOT_NODE_IP=13.84.167.234 ./strato.sh
              docker rmi $(docker images -aq) || true #removing unused images only
              docker ps
              '''
            }
          },
          "cd-multinode-3": {
            node('cd-multinode-3') {
              sh '''#!/bin/bash -le
              set -x
              set -e
              docker rm -f $(docker ps -aq) || true; docker system prune -f # Keeping the volumes
              cd strato-getting-started
              STRATO_GS_MODE="1" NODE_HOST=cd-multinode-3.southcentralus.cloudapp.azure.com BOOT_NODE_IP=13.84.167.234 ./strato.sh
              docker rmi $(docker images -aq) || true #removing unused images only
              docker ps
              '''
            }
          }
        )
      }
    }
  }
}