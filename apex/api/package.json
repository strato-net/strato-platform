{
  "name": "APEX",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "start": "# npm-run-all -p start-dev",
    "start:prod": "PORT=3001 NODE_HOST=${NODE_HOST} NODE_ENV=production node ./bin/www --config config-prod.yaml",
    "start:prod:node-health": "NODE_ENV=production node daemons/node-health-check.js",
    "start:dev": "PORT=${PORT:-3001} NODE_HOST=${NODE_HOST:-localhost} node $NODE_DEBUG_OPTION ./bin/www --config config-local.yaml",
    "start:dev:node-health": "node daemons/node-health-check.js",
    "start:dev:db-cleaner": "node daemons/db-cleaner.js",
    "start:dev:stall-check": "node daemons/stall-check.js",
    "node-ping": "# DELAY=5000 RETENTION=1 node node-ping/index.js",
    "migrate": "# sequelize db:migrate",
    "test": "NODE_ENV=development ./run-tests.sh",
    "test:app-metadata:local": "mocha --config=config-local.yaml lib/appMetadata/test/appMetadata.test.js --api-debug"
  },
  "dependencies": {
    "adm-zip": "0.4.7",
    "aws-sdk": "2.254.1",
    "bcrypt": "1.0.3",
    "big-integer": "^1.6.26",
    "blockapps-rest": "git://github.com/blockapps/blockapps-rest.git#develop",
    "body-parser": "1.18.2",
    "chai": "4.1.2",
    "chai-http": "3.0.0",
    "co": "4.6.0",
    "co-mocha": "1.2.0",
    "cookie-parser": "1.4.3",
    "cors": "2.8.4",
    "debug": "3.1.0",
    "download": "6.2.5",
    "expect": "latest",
    "express": "4.16.1",
    "fs-extra": "4.0.2",
    "is-reachable": "2.3.3",
    "jwt-simple": "0.5.1",
    "md5-file": "^3.2.3",
    "mocha": "5.0.0",
    "moment": "^2.18.1",
    "moment-duration-format": "^2.2.2",
    "morgan": "1.9.0",
    "multer": "1.3.0",
    "multer-s3": "2.7.0",
    "path": "0.12.7",
    "pg": "7.3.0",
    "pg-hstore": "2.3.2",
    "pgtools": "0.3.0",
    "rand-token": "0.3.0",
    "request": "2.83.0",
    "request-promise": "4.2.2",
    "rewire": "^4.0.1",
    "route-parser": "0.0.5",
    "sequelize": "4.13.5",
    "sequelize-cli": "3.0.0",
    "serve-favicon": "2.4.5",
    "sinon": "^4.5.0",
    "socket.io": "2.0.4",
    "sync-request": "4.1.0",
    "underscore": "1.8.3",
    "winston-color": "1.0.0"
  },
  "devDependencies": {
    "npm-run-all": "4.1.1"
  },
  "jshintConfig": {
    "esnext": true,
    "node": true
  }
}
