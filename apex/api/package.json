{
  "name": "APEX",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "start:prod": "export NODE_ENV=production; npm run db-create && npm run db-migrate && npm-run-all --parallel start:prod:www start:node-health start:stall-check start:db-cleaner",
    "start:prod:www": "NODE_ENV=production; PORT=3001 NODE_HOST=${NODE_HOST}  node ./bin/www --config config-prod.yaml",
    "start:dev": "NODE_ENV=development; npm run db-create && npm run db-migrate && PORT=${PORT:-3001} NODE_HOST=${NODE_HOST:-localhost} node $NODE_DEBUG_OPTION ./bin/www --config config-local.yaml",
    "start:node-health": "NODE_ENV=${NODE_ENV:-development} node $NODE_DEBUG_OPTION daemons/node-health-check-daemon.js",
    "start:stall-check": "NODE_ENV=${NODE_ENV:-development} node $NODE_DEBUG_OPTION daemons/stall-check-daemon.js",
    "start:db-cleaner": "NODE_ENV=${NODE_ENV:-development} node $NODE_DEBUG_OPTION daemons/db-cleaner.js",
    "db-create": "NODE_ENV=${NODE_ENV:-development} node -e 'require(\"./migrations/init-script/createdb.js\").createdb()'",
    "db-migrate": "NODE_ENV=${NODE_ENV:-development} sequelize db:migrate",
    "test": "NODE_ENV=${NODE_ENV:-development} ./run-tests.sh",
    "test:health": "mocha --config=config-local.yaml test/health.test.js --api-debug",
    "test:app-metadata:local": "mocha --config=config-local.yaml lib/appMetadata/test/appMetadata.test.js --api-debug"
  },
  "dependencies": {
    "@promster/express": "^3.1.0",
    "adm-zip": "0.4.7",
    "aws-sdk": "2.254.1",
    "bcrypt": "^3.0.6",
    "big-integer": "^1.6.26",
    "blockapps-rest": "git://github.com/blockapps/blockapps-rest.git#v6.4.1",
    "body-parser": "1.18.2",
    "chai": "4.1.2",
    "chai-http": "3.0.0",
    "co": "4.6.0",
    "co-mocha": "1.2.0",
    "cookie-parser": "1.4.3",
    "cors": "2.8.4",
    "debug": "3.1.0",
    "diskusage": "^1.1.1",
    "download": "6.2.5",
    "expect": "latest",
    "express": "4.16.1",
    "fs-extra": "4.0.2",
    "is-reachable": "2.3.3",
    "jwt-simple": "0.5.1",
    "md5-file": "^3.2.3",
    "mocha": "5.0.0",
    "moment": "^2.18.1",
    "moment-duration-format": "^2.2.2",
    "morgan": "1.9.0",
    "multer": "1.3.0",
    "multer-s3": "2.7.0",
    "node-diskfree": "^0.1.0",
    "path": "0.12.7",
    "pg": "^6.4.1",
    "pg-hstore": "2.3.2",
    "pgtools": "0.3.0",
    "prom-client": "11.5.3",
    "rand-token": "0.3.0",
    "request": "2.83.0",
    "request-promise": "4.2.2",
    "rewire": "^4.0.1",
    "route-parser": "0.0.5",
    "sequelize": "4.13.5",
    "sequelize-cli": "3.0.0",
    "serve-favicon": "2.4.5",
    "sinon": "^4.5.0",
    "socket.io": "2.0.4",
    "sync-request": "4.1.0",
    "systeminformation": "^4.6.0",
    "underscore": "1.8.3",
    "winston-color": "1.0.0"
  },
  "devDependencies": {
    "npm-run-all": "4.1.1"
  },
  "jshintConfig": {
    "esnext": true,
    "node": true
  }
}
