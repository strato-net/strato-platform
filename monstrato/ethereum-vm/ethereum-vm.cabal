name: ethereum-vm
version: 0.0.4
cabal-version: >=1.10
build-type: Simple
author: Jamshid
license-file:  LICENSE
maintainer:    jamshidnh@gmail.com
synopsis: A Haskell version of an Ethereum client
category:      Data Structures
license: Apache-2.0
description:
    The client described in the Ethereum Yellowpaper

source-repository this
  type:     git
  location: https://github.com/jamshidh/ethereum-vm
  branch:   master
  tag:      v0.0.4

library
    default-language: Haskell98
    build-depends:
                   base >= 4 && < 5
                 , base16-bytestring
                 , binary
                 , blockapps-data
                 , blockapps-util
                 , bytestring
                 , containers
                 , cryptohash
                 , directory
                 , either
                 , ethereum-encryption
                 , ethereum-rlp
                 , blockapps-haskoin
                 , hflags
                 , leveldb-haskell
                 , merkle-patricia-db
                 , blockapps-milena
                 , mtl
                 , monad-logger
                 , persistent-postgresql
                 , postgresql-simple
                 , resourcet
                 , strato-adit
                 , strato-conf
                 , strato-quarry
                 , strato-sequencer
                 , text
                 , time
                 , transformers
                 , vector
                 , ansi-wl-pprint
                 , strato-model
                 , strato-index
                 , strato-statediff
                 , strato-redis-blockdb
                 , hedis
                 , statsdi
    exposed-modules:
                     Blockchain.BlockChain
                     Blockchain.TheDAOFork
                     Blockchain.VMContext
                     Blockchain.VMOptions
                     Blockchain.Trigger
                     Blockchain.Verifier
                     Blockchain.VM
                     Blockchain.VM.Code
                     Blockchain.VM.Environment
                     Blockchain.VM.Opcodes
                     Blockchain.VM.VMState
                     Blockchain.VMMetrics
                     Executable.EthereumVM
                     Executable.EVMFlags
                     Executable.EVMCheckpoint
    other-modules:
                  Blockchain.DB.ModifyStateDB
                  Blockchain.JsonRpcCommand
                  Blockchain.VM.Memory
                  Blockchain.VM.OpcodePrices
                  Blockchain.VM.PrecompiledContracts
                  Blockchain.VM.VMM
    ghc-options: -Wall -O2
    buildable: True
    hs-source-dirs: src


executable ethereum-vm
    default-language: Haskell98
    build-depends:
                   base >= 4 && < 5
                 , blockapps-util
                 , ethereum-vm
                 , hflags
                 , monad-logger
    main-is: Main.hs
    ghc-options: -Wall -O2 -threaded
    buildable: True
    hs-source-dirs: exec_src

test-suite ethereum-vm-test
    type: exitcode-stdio-1.0
    hs-source-dirs: test
    main-is: Spec.hs
    other-modules: VM.VMSpec
    build-depends:       aeson,
                         base,
                         base16-bytestring,
                         blockapps-data,
                         blockapps-util,
                         bytestring,
                         containers,
                         data-default,
                         directory,
                         ethereum-rlp,
                         ethereum-vm,
                         hflags,
                         hspec,
                         leveldb-haskell,
                         merkle-patricia-db,
                         monad-logger,
                         mtl,
                         resourcet,
                         statsdi,
                         strato-model,
                         strato-quarry,
                         text
    ghc-options:         -Wall -Werror -threaded -rtsopts -with-rtsopts=-N
    default-language:    Haskell2010
