#!/usr/bin/env bash

if [[ -z "$1" ]]; then
    echo "Usage: strato-ps <node-directory>"
    exit 1
fi

cd "$1"

echo "######## STRATO Status: $(pwd)"

# Network
if [[ -f .ethereumH/ethconf.yaml ]]; then
    echo "Network: $(grep "^  network:" .ethereumH/ethconf.yaml | awk '{print $2}')"
fi

# Sync status
if [[ -f .strato.pid ]]; then
    source .strato.pid
    if kill -0 "$CONVOKE_PID" 2>/dev/null; then
        BAROMETER=$(strato-barometer syncstats 2>/dev/null)
        BLOCK=$(echo "$BAROMETER" | grep "bestBlockNumber:" | head -1 | awk '{print $2}')
        WORLD_BLOCK=$(echo "$BAROMETER" | sed -n '/^World Best Block:/,/bestBlockNumber:/p' | grep "bestBlockNumber:" | awk '{print $2}')
        SYNCED=$(echo "$BAROMETER" | grep -A2 "^Sync Status:$" | tail -1)
        if [[ -n "$BLOCK" && -n "$WORLD_BLOCK" ]]; then
            if [[ "$SYNCED" == "True" ]]; then
                echo "Sync: block $BLOCK (synced)"
            else
                PERCENT=$(awk "BEGIN {printf \"%.1f\", ($BLOCK / $WORLD_BLOCK) * 100}")
                echo "Sync: block $BLOCK / $WORLD_BLOCK ($PERCENT% syncing)"
            fi
        elif [[ -n "$BLOCK" ]]; then
            echo "Sync: block $BLOCK"
        fi
    fi
fi

echo ""
echo "Docker containers:"
docker compose -p strato ps --format "table {{.Name}}\t{{.Status}}" 2>/dev/null || echo "  None"

echo ""
echo "Convoke:"
if [[ -f .strato.pid ]]; then
    source .strato.pid
    if [[ -n "$CONVOKE_PID" ]] && kill -0 "$CONVOKE_PID" 2>/dev/null; then
        echo "  Running (PID $CONVOKE_PID)"
        echo "  Processes:"
        for pid in $(pgrep -P "$CONVOKE_PID" 2>/dev/null); do
            cmd=$(ps -p "$pid" -o args= 2>/dev/null | awk '{print $1}')
            echo "    $cmd ($pid)"
        done
    else
        echo "  Not running (stale pidfile)"
    fi
else
    echo "  No pidfile - STRATO may not be running"
fi
