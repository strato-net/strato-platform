#!/usr/bin/env bash

set -e

if [[ -z "$1" ]]; then
    echo "Usage: strato-up <node-directory> [strato-setup flags...]"
    echo "Example: strato-up mynode --network=lithium --httpPort=9000"
    exit 1
fi

NODE_DIR="$1"
shift

# Ensure credentials exist
strato-login --check || strato-login

# Setup node directory
mkdir -p "$NODE_DIR"
cd "$NODE_DIR"

if [[ ! -e .ethereumH/ethconf.yaml ]]; then
    echo "Running strato-setup..."
    strato-setup "$@"
fi

echo "Starting Docker containers..."
DOCKER_UID=$(id -u) DOCKER_GID=$(id -g) docker compose -p strato up -d --wait

echo "Starting convoke..."
mkdir -p logs
nohup convoke > logs/convoke.log 2>&1 &
CONVOKE_PID=$!
echo "CONVOKE_PID=$CONVOKE_PID" > .strato.pid

# Verify convoke started successfully
sleep 3
if ! kill -0 "$CONVOKE_PID" 2>/dev/null; then
    echo "ERROR: convoke crashed shortly after starting"
    echo "Last 20 lines of logs/convoke.log:"
    tail -20 logs/convoke.log
    echo ""
    echo "Shutting down docker containers..."
    docker compose -p strato down
    rm -f .strato.pid
    exit 1
fi

echo "STRATO started in: $(pwd)"
