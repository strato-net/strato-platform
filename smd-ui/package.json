{
  "name": "smd-ui",
  "version": "0.7.0",
  "private": true,
  "homepage": "/dashboard/",
  "dependencies": {
    "@blueprintjs/core": "^1.22.0",
    "@blueprintjs/table": "^1.19.0",
    "bignumber.js": "4.0.2",
    "bootstrap": "3.3.7",
    "enzyme-adapter-react-15": "^1.0.5",
    "js-cookie": "^2.2.0",
    "mixpanel-browser": "2.11.1",
    "moment": "2.18.1",
    "moment-timezone": "^0.5.14",
    "plottable": "3.1.1",
    "query-string": "^5.1.0",
    "react": "^15.5.4",
    "react-addons-css-transition-group": "15.5.2",
    "react-copy-to-clipboard": "^5.0.1",
    "react-dom": "^15.5.4",
    "react-dropzone": "^3.13.3",
    "react-joyride": "^1.10.1",
    "react-loading": "^1.0.1",
    "react-monaco-editor": "0.11.0",
    "react-redux": "5.0.5",
    "react-redux-loading-bar": "^2.9.3",
    "react-router-dom": "4.1.1",
    "react-router-redux": "4.0.8",
    "redux": "3.6.0",
    "redux-form": "6.8.0",
    "redux-saga": "0.15.3",
    "redux-saga-test-plan": "^3.3.1",
    "redux-saga-testing": "^1.0.5",
    "reselect": "^3.0.1",
    "socket.io-client": "^2.0.4"
  },
  "devDependencies": {
    "babel-jest": "^21.2.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-stage-2": "^6.24.1",
    "enzyme": "^3.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^21.2.1",
    "jest-fetch-mock": "^1.4.0",
    "jest-localstorage-mock": "^2.1.0",
    "mock-socket": "^7.1.0",
    "node-sass": "4.5.3",
    "npm-run-all": "4.0.2",
    "react-scripts": "1.0.5",
    "react-test-renderer": "^15.5.4",
    "redux-mock-store": "^1.3.0"
  },
  "scripts": {
    "build-css": "node-sass src/ -o src/",
    "watch-css": "npm run build-css && node-sass src/ -o src/ --watch --recursive",
    "start-js": "react-scripts start",
    "start": "REACT_STRATO_VERSION=${STRATO_VERSION} npm-run-all -p watch-css start-js",
    "build": "npm run build-css && REACT_STRATO_VERSION=${STRATO_VERSION} react-scripts build",
    "test": "jest",
    "test-watch": "jest --watch",
    "update-snapshots": "jest -u",
    "eject": "react-scripts eject"
  },
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "(.test)\\.(ts|tsx|js)$",
    "/distribution/.*\\.(ts|js)$"
  ],
  "jest": {
    "setupFiles": [
      "./src/tests/jestsetup.js"
    ],
    "verbose": true,
    "moduleNameMapper": {
      "\\.(css|less|png|pdf)$": "identity-obj-proxy"
    }
  }
}
