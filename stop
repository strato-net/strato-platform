#!/usr/bin/env bash

set -e

if [ "$1" = "" ]; then
    echo "error!  You must supply the strato directory"
    exit 1
fi

STRATO_DIR="$1"
PIDFILE="$STRATO_DIR/.strato.pid"

echo "######## Stopping Strato"

# Load PIDs if pidfile exists
if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    
    if [ -n "$CONVOKE_PID" ] && kill -0 "$CONVOKE_PID" 2>/dev/null; then
        echo "Stopping convoke (PID: $CONVOKE_PID)..."
        kill "$CONVOKE_PID" 2>/dev/null || true
        # Wait for convoke to clean up its children
        sleep 2
    fi
    
    rm -f "$PIDFILE"
else
    echo "No pidfile found at $PIDFILE"
fi

# Stop docker containers
echo "Stopping docker containers..."
docker compose -p strato down

echo ""
echo "######## Strato stopped"
