#!/usr/bin/env bash

if [ "$1" = "" ]; then
    echo "error!  You must supply the strato directory"
    exit 1
fi

STRATO_DIR="$1"
PIDFILE="$STRATO_DIR/.strato.pid"

# Load PIDs and check if convoke is running
CONVOKE_RUNNING=false
if [ -f "$PIDFILE" ]; then
    source "$PIDFILE"
    if [ -n "$CONVOKE_PID" ] && kill -0 "$CONVOKE_PID" 2>/dev/null; then
        CONVOKE_RUNNING=true
    fi
fi

echo "######## Strato Status"

# Show network name from ethconf
if [ -f "$STRATO_DIR/.ethereumH/ethconf.yaml" ]; then
    NETWORK=$(grep "^  network:" "$STRATO_DIR/.ethereumH/ethconf.yaml" | awk '{print $2}')
    echo "Network: $NETWORK"
fi

# Get sync status from strato-barometer (only if convoke is running)
if [ "$CONVOKE_RUNNING" = true ]; then
    BAROMETER=$(cd "$STRATO_DIR" && strato-barometer syncstats 2>/dev/null)
    if [ -n "$BAROMETER" ]; then
        # Get local Best Block number (first bestBlockNumber)
        BLOCK_NUM=$(echo "$BAROMETER" | grep "bestBlockNumber:" | head -1 | awk '{print $2}')
        # Get World Best Block number (highest known block)
        WORLD_BLOCK=$(echo "$BAROMETER" | sed -n '/^World Best Block:/,/bestBlockNumber:/p' | grep "bestBlockNumber:" | awk '{print $2}')
        # Get Sync Status (True/False)
        SYNC_STATUS=$(echo "$BAROMETER" | grep -A2 "^Sync Status:$" | tail -1)
        
        if [ -n "$BLOCK_NUM" ] && [ -n "$WORLD_BLOCK" ]; then
            if [ "$SYNC_STATUS" = "True" ]; then
                echo "Sync: block $BLOCK_NUM (synced)"
            else
                PERCENT=$(awk "BEGIN {printf \"%.1f\", ($BLOCK_NUM / $WORLD_BLOCK) * 100}")
                echo "Sync: block $BLOCK_NUM / $WORLD_BLOCK ($PERCENT% syncing)"
            fi
        elif [ -n "$BLOCK_NUM" ]; then
            echo "Sync: block $BLOCK_NUM"
        fi
    fi
fi

echo ""

# Check docker containers
echo "Docker containers (strato project):"
docker compose -p strato ps --format "table {{.Name}}\t{{.Status}}" 2>/dev/null || echo "  No containers running"
echo ""

# Check background processes
if [ -f "$PIDFILE" ]; then
    echo "Background processes:"
    if [ "$CONVOKE_RUNNING" = true ]; then
        echo "  convoke (PID $CONVOKE_PID): RUNNING"
        echo ""
        echo "Convoke child processes:"
        for pid in $(pgrep -P "$CONVOKE_PID" 2>/dev/null); do
            cmd=$(ps -p "$pid" -o args= 2>/dev/null | cut -c1-60)
            echo "  $cmd (PID $pid)"
        done
    else
        echo "  convoke (PID $CONVOKE_PID): NOT RUNNING"
    fi
else
    echo "No pidfile found at $PIDFILE"
    echo "Strato may not be running in background mode."
fi
