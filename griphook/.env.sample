# ============================================================================
# Griphook MCP Server - Environment Configuration
# ============================================================================
# Copy this file to .env and update values as needed.
# Authentication supports 3 modes (checked in this order):
#   1. Token mode: Set STRATO_ACCESS_TOKEN
#   2. Password mode: Set BLOCKAPPS_USERNAME + BLOCKAPPS_PASSWORD
#   3. Browser mode: Run `npm run login` (recommended)
# ============================================================================

# ----------------------------------------------------------------------------
# OAuth Client Configuration (required for all auth modes)
# ----------------------------------------------------------------------------
OAUTH_CLIENT_ID=localhost
OAUTH_CLIENT_SECRET=your-client-secret
OPENID_DISCOVERY_URL=https://keycloak.blockapps.net/auth/realms/mercata/.well-known/openid-configuration

# ----------------------------------------------------------------------------
# Token Mode Authentication (optional)
# Set this to skip OAuth entirely and use a pre-obtained token
# ----------------------------------------------------------------------------
#STRATO_ACCESS_TOKEN=eyJhbGciOiJSUzI1NiIs...

# ----------------------------------------------------------------------------
# Password Mode Authentication (legacy - optional)
# Only needed if not using browser login or token mode
# ----------------------------------------------------------------------------
#BLOCKAPPS_USERNAME=your-username@example.com
#BLOCKAPPS_PASSWORD=your-password

# ----------------------------------------------------------------------------
# STRATO Backend Configuration
# ----------------------------------------------------------------------------
# Available endpoints:
#   - Local development: http://localhost:3001/api
#   - Mercata testnet: https://buildtest.mercata-testnet.blockapps.net/api
#   - Production: https://your-strato-instance/api
STRATO_NODE_URL=https://buildtest.mercata-testnet.blockapps.net
STRATO_API_BASE_URL=https://buildtest.mercata-testnet.blockapps.net/api
STRATO_HTTP_TIMEOUT_MS=15000

# ----------------------------------------------------------------------------
# Griphook MCP Server Configuration
# ----------------------------------------------------------------------------
GRIPHOOK_HTTP_ENABLED=true
GRIPHOOK_HTTP_HOST=127.0.0.1
GRIPHOOK_HTTP_PORT=3005
GRIPHOOK_HTTP_PATH=/mcp
GRIPHOOK_HTTP_SSE_PATH=/mcp/events
