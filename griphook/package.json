{
  "name": "griphook",
  "version": "0.1.0",
  "description": "Griphook MCP server exposing STRATO web app functionality over the Model Context Protocol.",
  "main": "dist/server.js",
  "bin": {
    "griphook": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "login": "tsx src/cli.ts login",
    "logout": "tsx src/cli.ts logout",
    "status": "tsx src/cli.ts status"
  },
  "keywords": [
    "mcp",
    "griphook",
    "strato",
    "blockapps"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "axios": "^1.13.2",
    "open": "^10.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
