#!/usr/bin/env bash

set -e

if [ "$1" = "" ]
then
	echo "error!  You must supply a directory"
	exit
fi

if [ -e ~/.secrets/oauth_credentials ]
then
    source ~/.secrets/oauth_credentials
else
    export DEFAULT_OAUTH_DISCOVERY_URL="https://keycloak.blockapps.net/auth/realms/mercata/.well-known/openid-configuration"
    read -e -p "Enter the OAUTH_DISCOVERY_URL [${DEFAULT_OAUTH_DISCOVERY_URL}]: " OAUTH_DISCOVERY_URL

    OAUTH_DISCOVERY_URL=${OAUTH_DISCOVERY_URL:-$DEFAULT_OAUTH_DISCOVERY_URL}

    read -e -p "Enter the OAUTH_CLIENT_ID: " OAUTH_CLIENT_ID
    read -s -e -p "Enter the OAUTH_CLIENT_SECRET: " OAUTH_CLIENT_SECRET
    read -e -p "Save OAUTH credentials in "~/.secrets/"? (y/N)" SHOULD_SAVE
    if [ "$SHOULD_SAVE" = "y" ]
    then
	mkdir -p ~/.secrets
	echo -e "OAUTH_DISCOVERY_URL=$OAUTH_DISCOVERY_URL\nOAUTH_CLIENT_ID=$OAUTH_CLIENT_ID\nOAUTH_CLIENT_SECRET=$OAUTH_CLIENT_SECRET" > ~/.secrets/oauth_credentials
    fi
fi

export OAUTH_DISCOVERY_URL
export OAUTH_CLIENT_ID
export OAUTH_CLIENT_SECRET

export network=${network:-helium}
export svmTrace=${svmTrace:-false}
export VAULT_URL=https://vault.blockapps.net:8093

####################################

# "host.docker.internal" is set up in Windows/Mac (to point to the host's localhost),
# but for some reason wasn't set up to work in Linux
if [[ "$OSTYPE" == "linux-gnu"* ]]; then
  STRATO_HOSTNAME=172.17.0.1
  STRATO_IP=$STRATO_HOSTNAME
else
  STRATO_HOSTNAME=host.docker.internal
  STRATO_IP=127.0.0.1
fi

export STRATO_HOSTNAME

export HTTP_PORT=8081 #You can change this to 80 for Linux, Mac seems to forbid it
export NODE_HOST="localhost:8081"
export blocHost=$STRATO_HOSTNAME:3000

# Pre-create directories so they're owned by current user (not root)
mkdir -p $1
cp docker-compose.yml $1
cd $1
mkdir -p secrets

# Create YAML oauth credentials (needed by strato-setup for vault access)
if [ ! -f secrets/oauth_credentials.yaml ]; then
    cat > secrets/oauth_credentials.yaml << EOF
discoveryUrl: "$OAUTH_DISCOVERY_URL"
clientId: "$OAUTH_CLIENT_ID"
clientSecret: "$OAUTH_CLIENT_SECRET"
EOF
    chmod 600 secrets/oauth_credentials.yaml
fi

# Run strato-setup before Docker (creates config files only, no DB connections)
FIRST_RUN=false
if [ ! -e .ethereumH/ethconf.yaml ]
then
    FIRST_RUN=true
    echo "######## running strato-setup (config files)"
    strato-setup --network=$network --apiIPAddress=$STRATO_IP
    sed -i.bak "s|--svmTrace=false|--svmTrace=$svmTrace|g" commands.txt && rm commands.txt.bak
    cp ../docker-compose.yml .
fi

# Export postgres password for docker-compose
export postgres_password=$(cat secrets/postgres_password)

# Start containers (--wait blocks until healthchecked services are ready)
echo "Starting Docker containers..."
DOCKER_UID=$(id -u) DOCKER_GID=$(id -g) docker compose -p strato up -d --wait

# Run seed-genesis after Docker (needs PostgreSQL, Redis, Kafka)
if [ "$FIRST_RUN" = true ]
then
    echo "######## running seed-genesis (databases)"
    seed-genesis > logs/seed-genesis 2>&1
    echo "Setup complete"
fi

echo "######## convoking"
nohup convoke > logs/convoke.log 2>&1 &
CONVOKE_PID=$!

echo "CONVOKE_PID=$CONVOKE_PID" > .strato.pid

# Wait and verify convoke started successfully
sleep 3
if ! kill -0 "$CONVOKE_PID" 2>/dev/null; then
    echo "######## ERROR: convoke crashed shortly after starting"
    echo "Last 20 lines of logs/convoke.log:"
    tail -20 logs/convoke.log
    echo ""
    echo "Shutting down docker containers..."
    docker compose -p strato down
    rm -f .strato.pid
    exit 1
fi

echo "######## Strato started (stop with: ./stop $1)"
